<?xml version="1.0" ?>
<odoo>
    <record id="view_allinone_message" model="ir.ui.view">
        <field name="name">allinone.message.form</field>
        <field name="model">allinone.message</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="allinone">
                <h1>
                    <field name="message" nolabel="1" />
                </h1>
                <footer>
                    <button name="action_validate" string="_Apply"
                        type="object" class="oe_highlight" />
                    or
                    <button string="_Cancel" class="oe_link"
                        special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
