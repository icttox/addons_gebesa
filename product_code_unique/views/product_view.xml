<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='product_default_form_inherit_view'>
            <field name='name'>product.default.form.inherit.view</field>
            <field name='model'>product.template</field>
            <field name='inherit_id' ref="product.product_template_only_form_view"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="attrs">{'required': [('product_variant_count', '&lt;', 2)]}</attribute>
                </xpath>
            </field>
        </record>


        <record model='ir.ui.view' id='product_product_default_code_required_view'>
            <field name='name'>product.product.default_code.required.view</field>
            <field name='model'>product.product</field>
            <field name='inherit_id' ref="product.product_variant_easy_edit_view"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="required">True</attribute>
                </xpath>
            </field>
        </record>

        <record model='ir.ui.view' id='product_product_normal_default_code_required_view'>
            <field name='name'>product.product.normal.default_code.required.view</field>
            <field name='model'>product.product</field>
            <field name='inherit_id' ref="product.product_normal_form_view"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="required">True</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
