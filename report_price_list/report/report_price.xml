        <template id="report_price_list_document">
            <div class="header not-first-page">
                <t t-call="report_price_list.report_price_list_header"/>
            </div>
            <div class="page">
                <t t-if="doc.report_type =='normal'">
                    <t t-call="report_price_list.report_price_list_iso"/>
                    <t t-call="report_price_list.report_price_list_normales"/>
                </t>
                <t t-if="doc.report_type =='modulares'">
                    <t t-call="report_price_list.report_modular"/>
                </t>
            </div>
            <br/><br/> <br/>
            <div class="footer not-first-page">
                <t t-call="report_price_list.report_price_list_footer"/>
            </div>
        </template>

        <template id="report_price_list">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc" style="font-family: Century Gothic;">
                    <t t-call="report_price_list.report_price_list_portada"/>
                    <t t-call="report_price_list.report_price_list_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>