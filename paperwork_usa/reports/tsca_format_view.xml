<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="shipment_report_tsca_format"
            model="mrp.shipment"
            string="Export TSCA"
            report_type="qweb-pdf"
            name="paperwork_usa.report_tsca_format"
            file="paperwork_usa.report_tsca_format"
        />

        <template id="tsca_layout">
            <div class="header">
                <div class="row">
                    <div class="col-12 mt-4 text-center">
                         <strong style="font-size: 20pt;">Toxic Substance Control Act (TSCA) Certification</strong>
                    </div>
                </div>
            </div>
            <div class="article o_report_layout_standard">
                <t t-raw="0" />
            </div>
            <div class="footer">
            </div>
        </template>

        <template id="report_tsca_format_document">
            <t t-call="paperwork_usa.tsca_layout">
                <div class="page" style="font-size: 12pt;">
                    <div class="row">
                        <div class="col-4">
                            Date:
                        </div>
                        <div class="col-8">
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y')"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-4">
                            Entry No. / Invoice Number:
                        </div>
                        <div class="col-8">
                            <span t-esc="doc._get_invoices()" align="center"/>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-12">
                            <strong style="font-size: 14pt;">Check only one</strong>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-12">
                            <strong style="font-size: 14pt;">Positive Certification</strong>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-1 text-center">
                            &#9634;
                        </div>
                        <div class="col-11">
                            I certify that all chemical substances in this shipment comply with all applicable rules or orders under TSCA and that I am not offering a chemical substance for entry in violation of TSCA or any applicable rule or order thereunder.
                            <br/><br/>or
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <strong style="font-size: 14pt;">Negative Certification</strong>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-1 text-center">
                            &#9634;
                        </div>
                        <div class="col-11">
                            I certify that all chemicals in this shipment are not subject to TSCA.
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <table  class="table table-sm table-hover table-striped">
                                <tr>
                                    <th width="30%">Company name:</th>
                                    <td><span t-esc="user.company_id.name"/></td>
                                </tr>
                                <tr>
                                    <th>Company address:</th>
                                    <td><span t-esc="user.company_id.street"/> <span t-esc="user.company_id.street2"/></td>
                                </tr>
                                <tr>
                                    <th>Certifier name:</th>
                                    <td>HOMERO RAMOS LUEVANOS</td>
                                </tr>
                                <tr>
                                    <th>Certifier title:</th>
                                    <td>QUALITY ASSURANCE</td>
                                </tr>
                                <tr>
                                    <th>Certifier phone number:</th>
                                    <td>52-8717077777</td>
                                </tr>
                                <tr>
                                    <th>Certifier email address:</th>
                                    <td>homero.ramos@gebesa.com</td>
                                </tr>
                                <tr>
                                    <th>Certifier signature:</th>
                                    <td></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            Product Description
                            <br/>
                            <t t-set="count" t-value="1"/>
                            <table class="mt-1 table table-sm table-hover table-striped">
                                <t t-foreach='products[doc.id]' t-as='prod'>
                                    <tr>
                                        <td width="10%"><span t-esc="count"/></td>
                                        <td>[<span t-esc="prod.default_code"/>]<span t-esc="prod.name"/></td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-12">
                            If the certifier is unsure if their chemical substance is subject to TSCA compliance, contact the Environmental Protection Agency, TSCA Assistance Office at 1.202.554.1404 between 8:30 a.m. and 5:00 p.m.
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <template id="report_tsca_format">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="paperwork_usa.report_tsca_format_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>