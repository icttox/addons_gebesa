<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>
	<record model="ir.ui.view" id="diler_line">
		<field name="name">diler.line</field>
		<field name="model">sale.order</field>
		<field name="inherit_id" ref="sale.view_order_form"/>
		<field name="arch" type="xml">
			<xpath expr="//sheet/notebook/page/field[@name='order_line']/form/group/group/field[@name='product_id']" position="after">
				<field name="reference_code"/>
		 		<field name="dealer_order_line"/>
		 		<field name="line_tag_number"/>
			</xpath>
        </field>
	</record>
</data>
</odoo>