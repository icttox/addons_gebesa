<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="product_normal_tsca_form_view" model="ir.ui.view">
            <field name="name">product.normal.tsca.form.view</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page/group/group/field[@name='categ_id']" position="after">
                    <field name="is_tsca"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>