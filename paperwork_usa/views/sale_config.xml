<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.planned.delivery.date.form</field>
            <field name = "model">res.config.settings</field>
            <field name ="inherit_id" ref="sale.res_config_settings_view_form"/>
            <field name ="arch" type="xml">
                <xpath expr="//div[@data-key='sale_management']" position="inside">
                    <h2>Configuracion para documentacion de exportacion</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." groups="base.group_multi_company"/>
                                <div class="text-muted">
                                    Fecha de envio planeada por defecto
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="planned_delivery_date" class="col-md-3 o_light_label"/>
                                        <field name="planned_delivery_date"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." groups="base.group_multi_company"/>
                                <div class="text-muted">
                                    Líneas de productos que se excluyen de los formatos para USMCA y TMEC
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="foreign_line_ids" class="col-md-3 o_light_label"/>
                                        <field name="foreign_line_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_open': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
