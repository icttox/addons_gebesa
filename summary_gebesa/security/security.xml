<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="summary_date_dim_rule" model="ir.rule">
        <field name="name">Summary date dim</field>
        <field name="model_id" ref="model_summary_date_dim"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]</field>
    </record>

    <record id="summary_inventory_rule" model="ir.rule">
        <field name="name">Summary inventory</field>
        <field name="model_id" ref="model_summary_inventory"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]</field>
    </record>

    <record id="ssummary_purchase_rule" model="ir.rule">
        <field name="name">Summary purchase</field>
        <field name="model_id" ref="model_summary_purchase"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]</field>
    </record>

</odoo>