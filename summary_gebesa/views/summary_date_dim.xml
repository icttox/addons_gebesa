<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="summary_date_dim_form">
        <field name="name">summary.date.dim.form</field>
        <field name="model">summary.date.dim</field>
        <field name="arch" type="xml">
            <form string="Date">
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="year"/>
                            <field name="week"/>
                        </group>
                        <group>
                            <field name="month"/>
                            <field name="quarter"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Inventory">
                            <field name="inventory_ids">
                                <tree>
                                    <field name="location_id"/>
                                    <field name="family_id"/>
                                    <field name="group_id"/>
                                    <field name="line_id"/>
                                    <field name="net_cost"/>
                                    <field name="net_in_out"/>
                                    <field name="net_revaluation"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Purchase">
                            <field name="purchase_ids">
                                <tree>
                                    <field name="location_id"/>
                                    <field name="partner_id"/>
                                    <field name="family_id"/>
                                    <field name="group_id"/>
                                    <field name="line_id"/>
                                    <field name="pruchase_cost"/>
                                    <field name="pruchase_difference"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record model='ir.ui.view' id='summary_date_dim_tree'>
        <field name='name'>summary.date.dim.tree</field>
        <field name='model'>summary.date.dim</field>
        <field name='arch' type='xml'>
            <tree string='Dates'>
                <field name="year"/>
                <field name="quarter"/>
                <field name="month"/>
                <field name="week"/>
            </tree>
        </field>
    </record>

    <record id="action_summary_date_dim" model="ir.actions.act_window">
        <field name="name">summary.date.dim</field>
        <field name="res_model">summary.date.dim</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="summary_date_dim_menu" name="Dates" parent="gebesa_reports.gebesa_report_infor_menu" action="action_summary_date_dim"/>
</odoo>
