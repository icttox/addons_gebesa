<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_form_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='input_line_ids']" position="after">
                  <separator string="Salary assignments"/>
                    <field name="salary_assing_ids" colspan="4" nolabel="1">
                        <tree string="Salary assignments" editable="bottom" create="0">
                            <field name="name"/>
                            <field name="code" readonly="1" force_save="1"/>
                            <field name="amount"/>
                            <field name="total"/>
                            <field name="contract_id" readonly="1" force_save="1"/>
                            <field name="sequence" invisible="True"/>
                        </tree>
                    </field>
            </xpath>
            <xpath expr="//field[@name='credit_note']" position="attributes">
                <attribute name="readonly">True</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids'][1]" position="attributes">
                <attribute name="name">filtered_line_ids</attribute>
            </xpath>
        </field>
    </record>
</odoo>
