<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_hr_salary_assingments_batches_tree" model="ir.ui.view">
        <field name="name">hr.salary.assingments.batches.tree</field>
        <field name="model">hr.salary.assingments.batches</field>
        <field name="arch" type="xml">
            <tree string="Salary assignments batches">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="struct_id"/>
                <field name="date_assing"/>
                <field name="total_amount"/>
                <field name="filter_assing"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_hr_salary_assingments_batches_form" model="ir.ui.view">
        <field name="name">hr.salary.assingments.batches.form</field>
        <field name="model">hr.salary.assingments.batches</field>
        <field name="arch" type="xml">
            <form string="Assingments assignments batches">
            <header>
                <button name="validate_assings" type="object" states="in_progress" string="Validate" class="oe_highlight"/>
                <button name="init_assings" type="object" states="draft" string="Start assignments" class="oe_highlight"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,validated"/>
            </header>
            <sheet>
                <label for="name" class="oe_edit_only"/>
                <h1><field name="name" attrs="{'readonly':[('state','not in', ['draft'])]}"/></h1>
                <group>
                    <group>
                        <field name="filter_assing" widget="radio" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <!-- <field name="type_salary_rule" invisible="1"/>  'invisible': [('type_salary_rule', '!=', 'overtime')]-->
                        <field name="rate" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <field name="type_amount" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <field name="total_amount"/>
                        <field name="fixed_amount" attrs="{'invisible':[('type_amount','!=', 'fijo')]}"/>
                    </group>
                     <group>
                        <field name="company_id" groups="base.group_multi_company" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <field name="struct_id" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <field name="rule_id" required="1" attrs="{'readonly':[('state','not in', ['draft'])]}"/>
                        <field name="date_assing" attrs="{'readonly':[('state','not in', ['draft'])]}" required="1"/>
                        <field name="department_id" options="{'no_create': True, 'no_create_edit': True}"
                        attrs="{'readonly':[('state','not in', ['draft'])], 'invisible': [('filter_assing', '!=', 'department')]}"/>
                    </group>
                </group>
                <group string="Employees"
                attrs="{'invisible': [('filter_assing', '!=', 'employee')]}">
                    <field name="employee_ids" attrs="{'readonly': [('state', '!=', 'draft')]}" nolabel="1">
                        <tree editable="buttom">
                            <field name="name"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                        </tree>
                    </field>
                </group>
                <div class="mt32" string="Lines assignments"
                    attrs="{'invisible': [('state','in', ['draft'])]}">
                    <field name="line_ids" nolabel="1"
                        attrs="{'readonly':[('state', 'in', ['validated'])],
                               'invisible': [('state','in', ['draft'])]}">
                        <tree editable="buttom" decoration-info="parent.state=='draft'" create="false" widget="one2many_list">
                            <field name="name" invisible="1" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="contract_id" invisible="1" readonly="1"/>
                            <field name="date_assing" readonly="1"/>
                            <field name="date_paid" invisible="1"/>
                            <field name="salary_rule_id" readonly="1"/>
                            <field name="quantity" readonly="1"/>
                            <field name="rate" invisible="1"/> <!--attrs="{'column_invisible': [('parent.type_salary_rule', '!=', 'overtime')]}"-->
                            <field name="amount"/>
                            <field name="total"/>
                            <field name="state" readonly="1"/>
                        </tree>
                    </field>
                </div>
            </sheet>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_hr_salary_assingments_batches_view">
        <field name="name">Salary assingments batches</field>
        <field name="res_model">hr.salary.assingments.batches</field>
         <field name="view_id" ref="view_hr_salary_assingments_batches_tree"/>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="salary_assingments_batches" name="Salary assignments batches" sequence="6" parent="hr_salary_assignments.salary_assingments"
              groups="hr_payroll.group_hr_payroll_user" action="hr_salary_assignments.action_hr_salary_assingments_batches_view"/>

</odoo>
