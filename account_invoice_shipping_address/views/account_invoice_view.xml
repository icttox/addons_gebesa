<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    	<record model='ir.ui.view' id='account_invoice_shipping_form_view'>
    		<field name='name'>account_invoice_shipping_form_view</field>
    		<field name='model'>account.invoice</field>
    		<field name='inherit_id' ref='account.invoice_form'/>
    		<field name='arch' type='xml'>
    			<xpath expr="//notebook/page[@name='other_info']" position="after">
    				<page string="Delivery Address">
    					<group>
    						<group>
    							<field name='partner_shipping_id' domain="[('type', '=', 'delivery')]" required="1"/>
    						</group>
    					</group>
    				</page>
    			</xpath>
                <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>  		   		
    		</field>
        </record>
    </data>
</odoo>