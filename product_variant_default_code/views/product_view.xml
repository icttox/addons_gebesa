<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="product_template_only_form_view_inh_variantdefaultcode" model="ir.ui.view">
            <field name="name">product.template.only.form.view.inh.variantdefaultcode</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <header>
                    <button name="create_standar_price_variant" string="Create cost variants" type="object"/>
                </header>
                <xpath expr="//notebook/page/field[@name='attribute_line_ids']" position="before">
                    <button name="recreate_default_code" string="Recalcuar clave" type="object"/>
                    <attribute name="string">Variant Reference Mask         </attribute>
                    <field name="reference_mask" modifiers="{'invisible': [['attribute_line_ids', '=', False]]}" position="attributes"/>
                </xpath>
            </field>
        </record>

        <record id="product_normal_form_view_inh_variantdefaultcode" model="ir.ui.view">
            <field name="name">product.normal.form.view.inh.variantdefaultcode</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <field name="default_code" position="before">
                    <field name="manual_code" />
                    
                </field>
                <field name="default_code" position="attributes">
                    <attribute name="string">Clave       </attribute>
                </field>
            </field>
        </record>
        <record model='ir.ui.view' id='product_normal_form_view_inh_variantdefaultcode_dos'>
            <field name='name'>product.normal.form.view.inh.variantdefaultcode.dos</field>
            <field name='model'>product.template</field>
            <field name='inherit_id' ref="product.product_template_only_form_view"/>
            <field name='arch' type='xml'>
                <field name="default_code" position="before">
                    
                </field>
                <field name="default_code" position="attributes">
                    <attribute name="string">Clave       </attribute>
                </field>
            </field>
        </record>
    </data>
</odoo>