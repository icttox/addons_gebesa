<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="gebesa_mrp_production_form_view" model="ir.ui.view">
        <field name="name">gebesa.mrp.production.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
        	<xpath expr="//header/button[@name='button_plan']" position="after">
        		<button name="generate_procure_pickings" string="Genera Abastecimientos" type="object" groups="system_administrator.group_system_administrator_gebesa"/>
            </xpath>
        </field>
    </record>

    <record model="ir.actions.act_window" id="mrp.action_mrp_workorder_production">
        <field name="domain">[('production_state','not in',('done','cancel','transfer')),('state', 'not in', ('done','cancel'))]</field>
    </record>

    <record model="ir.actions.act_window" id="mrp.action_mrp_workorder_workcenter">
        <field name="domain">[('production_state','not in',('done','cancel','transfer')),('state', 'not in', ('done','cancel'))]</field>
    </record>
</odoo>
