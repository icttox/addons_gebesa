<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='catalog_product_service_tree'>
        	<field name='name'>catalog.product.service.tree</field>
        	<field name='model'>catalog.product.service</field>
        	<field name='arch' type='xml'>
        		<tree string='Catalog Product Service'>
        			<field name='code'/>
        			<field name='description'/>
                    <field name='include_iva'/>
                    <field name='include_ieps'/>
                    <field name='include_complement'/>
        		</tree>
        	</field>
        </record>

        <record model='ir.ui.view' id='catalog_product_service_form'>
        	<field name='name'>catalog.product.service.form</field>
        	<field name='model'>catalog.product.service</field>
        	<field name='arch' type='xml'>
        		<form string='Product Service'>
        			<header>
        			</header>
        			<sheet>
        				<div class="oe_title">
        					<label for="code" class="oe_edit_only" />
        					<h1>
        						<field name='code'/>
        					</h1>
        				</div>
        				<group>
        					<group>
        						<field name='description'/>
        						<field name='include_iva'/>        						
        					</group>
                            <group>
                                <field name='include_ieps'/>
                                <field name='include_complement'/>
                            </group>
        				</group>
        			</sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>  
        		</form>
        	</field>
        </record>

        <record id='catalog_product_service_action' model='ir.actions.act_window'>
        	<field name='name'>Catalog Product Service</field>
        	<field name='res_model'>catalog.product.service</field>
        	<field name='view_type'>form</field>
        	<field name='view_mode'>tree,form</field>
            <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to register a Product / Service for CFDI
            </p><p>
                Make your first record.
            </p>
            </field>
        </record>

        <menuitem id="catalog_product_service_menu" name="Catalog Product Service" parent="foreign_commerce_complement.foreign_commerce_menu" action="catalog_product_service_action" sequence="50"/>

    </data>
</odoo>