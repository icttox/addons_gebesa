<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_send_email_invoice_canceled" model="ir.cron">
            <field name="name">Send Email Invoice Canceled</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="model_id" ref="model_account_invoice"/>
            <!-- <field eval="'send_email_invoice_canceled'" name="function"/>
            <field eval="" name="args"/> -->
            <field name="state">code</field>
            <field name="code">model.send_email_invoice_canceled()</field>
            <field name="active" eval="False" />
        </record>

        <record id="email_cancelled_invoices_manufacturas" model="ir.config_parameter">
            <field name="key">cancelled_invoices_manufacturas.receivers_email</field>
            <field name="value"></field>
        </record>

    </data>
</odoo>