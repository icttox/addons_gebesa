<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="hr_department_form" model="ir.ui.view">
            <field name="name">hr.department.form</field>
            <field name="model">hr.department</field>
            <field name="inherit_id" ref="hr.view_department_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/field[@name='company_id']" position="after">
                    <field name="id_microsip"/>
                </xpath>
                <xpath expr="//form/sheet" position="before">
                    <header>
                        <button name="get_data_from_microsip" string="Departamentos microsip" type="object"/>
                    </header>
                </xpath>
            </field>
        </record>
    </data>
</odoo>