<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record model="res.groups" id="group_gebesa_security">
            <field name="name">Group gebesa security</field>
        </record>

        <record model="ir.rule" id="sale_order_warehouse_rule">
            <field name="name">Sales Order Warehouse</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('warehouse_id','in',user.employee_ids[0].warehouse_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('group_gebesa_security'))]"/>
        </record>

        <record model="ir.rule" id="purchase_order_warehouse_rule">
            <field name="name">Purchase Order Warehouse</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="domain_force">[('warehouse_id','in',user.employee_ids[0].warehouse_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('group_gebesa_security'))]"/>
        </record>

        <record model="ir.rule" id="account_invoice_analytic_rule">
            <field name="name">Account Invoice Analytic</field>
            <field name="model_id" ref="account.model_account_invoice"/>
            <field name="domain_force">[('account_analytic_id','child_of',user.employee_ids[0].warehouse_ids.mapped('account_analytic_id').mapped('id'))]</field>
            <field name="groups" eval="[(4, ref('group_gebesa_security'))]"/>
        </record>

        <record model="ir.rule" id="account_payment_analytic_rule">
            <field name="name">Account Payment Analytic</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <field name="domain_force">[('account_analytic_id','child_of',user.employee_ids[0].warehouse_ids.mapped('account_analytic_id').mapped('id'))]</field>
            <field name="groups" eval="[(4, ref('group_gebesa_security'))]"/>
        </record>

        <record model="ir.rule" id="crm_all_salesteam_gebesa_rule">
            <field name="name">All Salesteam Gebesa</field>
            <field name="model_id" ref="sales_team.model_crm_team"/>
            <field name="domain_force">[('team_type','in', ['sales', 'website'])]</field>
            <field name="groups" eval="[(4, ref('group_gebesa_security'))]"/>
        </record>
	</data>
</odoo>