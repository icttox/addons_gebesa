<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    	<record model='ir.ui.view' id='mrp_bom_cut_form_view'>
    		<field name='name'>mrp.bom.cut.form.view</field>
    		<field name='model'>mrp.bom</field>
    		<field name='inherit_id' ref="mrp.mrp_bom_form_view"/>
    		<field name='arch' type='xml'>
                <xpath expr="//sheet" position="before">
                    <header>
                    </header>
                </xpath>
                <xpath expr="/form/sheet/notebook/page/field[@name='bom_line_ids']" position="attributes">
                    <attribute name="context">{'default_bom_id': id}</attribute>
                </xpath>
    			<xpath expr="/form/sheet/notebook/page/field[@name='bom_line_ids']/tree" position="attributes">
    				<attribute name="editable"/>
    			</xpath>
                <xpath expr="//form/sheet/group/group/div/field[@name='product_qty']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
                <xpath expr="//form/sheet/group/group/div/field[@name='product_uom_id']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
    		</field>
    	</record>
    </data>
</odoo>