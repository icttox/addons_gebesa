<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='crm_canalizar_form'>
            <field name='name'>crm.canalizar.form</field>
            <field name='model'>crm.lead</field>
            <field name='inherit_id' ref='crm.crm_case_form_view_leads'/>
            <field name='arch' type='xml'>
                <xpath expr="//form/sheet/group/group[4]/field[@name='tag_ids']" position="after">
                    <field name='partners_id' domain="[('category_id.name','in',('Franquicias','Distribuidor','Consesionarios'))]"/>
                    <field name='state_free_text'/>
                </xpath>
            </field>
        </record>
        <record model='ir.ui.view' id='crm_partner_tree'>
            <field name='name'>crm.partner.tree</field>
            <field name='model'>crm.lead</field>
            <field name='inherit_id' ref='crm.crm_case_tree_view_leads'/>
            <field name='arch' type='xml'>
                <xpath expr="//tree/field[@name='team_id']" position="before">
                    <field name='partners_id'/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>