<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data>
        <record id="expense_import_cfdi_form" model="ir.ui.view">
            <field name="name">expense.import.cfdi.form</field>
            <field name="model">expense.import.cfdi</field>
            <field name="arch" type="xml">
                <form string="Import CFD-I file">
                    <group>
                        <label for="cfdi"/>
                        <field name="cfdi" filename="xml_name" nolabel="1"/>

                        <label for="file_pdf"/>
                        <field name="file_pdf" filename="pdf_name" nolabel="1"/>
                        
                        <field name="xml_name" invisible="1" class="oe_inline oe_right"/>
                        <field name="pdf_name" invisible="1" class="oe_inline oe_right"/>
                    </group>
                    <label for="check_sat"/>
                    <field name="check_sat"/>
                    <field invisible="True" name="state" readonly="True"/>
                    <footer>
                        <button icon="gtk-cancel" special="cancel" states="init" string="Cancel"/>
                        <button icon="gtk-ok" name="import_cfdi" states="init" string="Import" type="object"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_expense_import_cfdi" model="ir.actions.act_window">
            <field name="name">Attach CFD-I</field>
            <field name="res_model">expense.import.cfdi</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="expense_import_cfdi_form"/>
            <field name="target">new</field>
        </record>
        <menuitem action="action_expense_import_cfdi" id="expense_import_menu" name="Importar Gastos Médicos"  parent="med_exp_menu" sequence="10"/>
    </data>
</openerp>