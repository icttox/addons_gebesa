<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
    <record model="ir.actions.act_window" id="employee_medical_exp_action">
            <field name="name">Medical Expenses</field>
            <field name="res_model">hr.employee.medical.expense</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the medical expenses
                </p>
            </field>
        </record>

        <menuitem id="med_exp_menu" name="Medical Expenses" parent="hr.menu_hr_root"/>
        <menuitem id="med_expenses_menu" name="Medical Expenses" parent="med_exp_menu" action="employee_medical_exp_action" sequence="1"/>

        <record model="ir.ui.view" id="employee_medical_expense_form">
            <field name="name">hr.employee.medical.expense.form</field>
            <field name="model">hr.employee.medical.expense</field>
            <field name="arch" type="xml">
                <form string="Form Employee Medical Expenses">
                    <header>
                        <button name="action_validate" type="object" string="Validate" class="oe_highlight" groups="hr_employee_medical_expenses.group_medical_expense_validated"  attrs="{'invisible':[('status','!=', 'draft')]}"/>
                        <button name="action_refund" type="object" string="Refund" class="oe_highlight" groups="hr_employee_medical_expenses.group_medical_expense_refund" attrs="{'invisible':[('status','in', ['refund', 'cancel'])]}"/>
                        <button name="action_cancel" type="object" string="Cancel" class="oe_highlight" attrs="{'invisible':[('status','=', 'cancel')]}"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="employee_id" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="date_capture" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="date_cfdi" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="supplier" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="rfc_supplier" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="company_id" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                            </group>
                            <group>
                                <field name="total" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="uuid" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="supplier_folio" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="authorized" readonly="1" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="refund" readonly="1" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="method_payment" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                                <field name="use_cfdi" attrs="{'readonly':[('status','!=', 'draft')]}"/>
                            </group>
                            <field name="medical_expense_line_ids" widget="one2many_list" attrs="{'readonly':[('status','!=', 'draft')]}">
                                <tree editable="bottom" string="Employee Medical Expenses Line">
                                    <field name="product_sat_code_id"/>
                                    <field name="description"/>
                                    <field name="unit"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="total"/>
                                    <field name="authorized" invisible="1"/>
                                    <field name="refund" invisible="1"/>
                                </tree>    
                            </field>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div> 
                </form>
            </field>
        </record>    

        <record model="ir.ui.view" id="employee_medical_exp_tree_view">
            <field name="name">hr.employee.medical.expense.tree</field>
            <field name="model">hr.employee.medical.expense</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Employee Medical Expenses">
                    <field name="employee_id"/>
                    <field name="name" select="1"/>
                    <field name="status"/>
                    <field name='date_capture'/>
                    <field name="date_cfdi"/>
                    <field name="supplier"/>
                    <field name="rfc_supplier"/>
                    <field name="total"/>
                    <field name='uuid'/>
                    <field name="supplier_folio"/>
                    <field name="authorized"/>
                    <field name="refund"/>
                    <field name="method_payment"/>
                    <field name="use_cfdi"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>