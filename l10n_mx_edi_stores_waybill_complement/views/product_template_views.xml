<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">iproduct.template.form.waybill.stores.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product_structure_gebesa.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='product_classification']/group/group/field[@name='group_id']" position="after">
                <field name="products_services_id"/>
            </xpath>
        </field>
    </record>
</odoo>
