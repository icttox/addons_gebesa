<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ir_rule_edores_type" model="ir.rule">
            <field name="name">Income Statement Categories</field>
            <field name="model_id" ref="model_account_account_edores_type"/>
            <field name="groups" eval="[(4,ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field eval="False" name="global"/>
            <field name="domain_force">[('company_id','=',user.company_id.id)]</field>           
        </record>

        <record model='ir.ui.view' id='account_account_edores_type_tree'>
            <field name='name'>account.account.edores.type.tree</field>
            <field name='model'>account.account.edores.type</field>
            <field name='arch' type='xml'>
                <tree string='Income Statement Categories'>
                    <field name='name'/>
                    <field name='active'/>
                    <field name='sequence'/>
                    <field name='parent_id'/>
                </tree>
            </field>
        </record>

        <record model='ir.ui.view' id='account_account_edores_type_form'>
            <field name='name'>account.account.edores.type.form</field>
            <field name='model'>account.account.edores.type</field>
            <field name='arch' type='xml'>
                <form string='Income Statement Categories'>
                    <header>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" />
                            <h1>
                                <field name='name'/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name='parent_id' domain="[('parent_id', '=', False),
                                    ('id', '!=', id)]"/>
                                <field name='cumulative'/>
                                <field name='active'/>                                
                            </group>
                            <group>
                                <field name='company_id'/>
                                <field name='sequence'/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>  
                </form>
            </field>
        </record>

        <record id='account_account_edores_type_action' model='ir.actions.act_window'>
            <field name='name'>Income Statement Categories</field>
            <field name='res_model'>account.account.edores.type</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>tree,form</field>
        </record>

        <menuitem id="account_account_edores_type_menu" name="Income Statement Categories" parent="account.account_management_menu" action="account_account_edores_type_action" sequence="50"/>

    </data>
</odoo>