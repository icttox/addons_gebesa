<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_account_form'>
        	<field name='name'>account_parent_view_form</field>
        	<field name='model'>account.account</field>
        	<field name='inherit_id' ref='account.view_account_form'/>
        	<field name='arch' type='xml'>
        		<xpath expr="//group/group/field[@name='deprecated']" position="after">
        			<field name='edores_type_id' domain="[('parent_id', '!=', False)]"/>
        		</xpath>       		
        	</field>
        </record>

        <record id="action_account_financial_report_line_tree" model="ir.actions.act_window">
            <field name="name">Financial Reports Lines</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.financial.html.report.line</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <!--field name="context">{'account_reports.usr_created': True}</field-->
            <field name="view_id" ref="account_reports.view_account_financial_report_line_tree"/>
        </record>

        <menuitem id="menu_account_financial_reports_line_tree" name="Financial Reports Lines" parent="account.account_management_menu" action="account_financial_report_mx.action_account_financial_report_line_tree" groups="system_administrator.group_system_administrator_gebesa"/>
    </data>
</odoo>