<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="invoice_supplier_form" model="ir.ui.view">
        <field name="name">account.invoice.supplier.form.convert</field>
        <field name="model">account.invoice</field>
        <field name="priority">200</field>
        <field name="inherit_id" ref="account.invoice_supplier_form"/>
        <field name="arch" type="xml">
        	<xpath expr="//header" position="inside">
                <button name="%(action_account_invoice_in_to_out)d" type='action' string='Copy to a Customer Invoice' groups="account.group_account_invoice" attrs="{'invisible': ['|',('type', 'in', ['in_refund','out_refund', 'out_invoice']),('state','not in',('open','in_payment','paid'))]}"/>
            </xpath>
        </field>
    </record>
</odoo>
