<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="consultar_pedimento_vucem">
            <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:con="http://www.ventanillaunica.gob.mx/pedimentos/ws/oxml/consultarpedimentocompleto" xmlns:com="http://www.ventanillaunica.gob.mx/pedimentos/ws/oxml/comunes">
                <soapenv:Header>
                    <wsse:Security soapenv:mustUnderstand="1" xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd">
                        <wsse:UsernameToken>
                            <wsse:Username><t t-esc="user_name"/></wsse:Username>
                            <wsse:Password Type="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordText"><t t-esc="user_pass"/></wsse:Password>
                        </wsse:UsernameToken>
                    </wsse:Security>
                </soapenv:Header>
                <soapenv:Body>
                    <con:consultarPedimentoCompletoPeticion>
                        <con:peticion>
                            <com:aduana><t t-esc="clave_aduana"/></com:aduana>
                            <com:patente><t t-esc="patente"/></com:patente>
                            <com:pedimento><t t-esc="num_pedimento"/></com:pedimento>
                        </con:peticion>
                    </con:consultarPedimentoCompletoPeticion>
                    </soapenv:Body>
            </soapenv:Envelope>
        </template>

        <template id="consultar_partida_vucem">
            <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:con="http://www.ventanillaunica.gob.mx/pedimentos/ws/oxml/consultarpartida" xmlns:com="http://www.ventanillaunica.gob.mx/pedimentos/ws/oxml/comunes">
                <soapenv:Header>
                    <wsse:Security soapenv:mustUnderstand="1" xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd">
                        <wsse:UsernameToken>
                            <wsse:Username><t t-esc="user_name"/></wsse:Username>
                            <wsse:Password Type="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordText"><t t-esc="user_pass"/></wsse:Password>
                        </wsse:UsernameToken>
                    </wsse:Security>
                </soapenv:Header>
                <soapenv:Body>
                    <con:consultarPartidaPeticion>
                        <con:peticion>
                            <com:aduana><t t-esc="clave_aduana"/></com:aduana>
                            <com:patente><t t-esc="patente"/></com:patente>
                            <com:pedimento><t t-esc="num_pedimento"/></com:pedimento>
                            <con:numeroOperacion><t t-esc="numero_operacion"/></con:numeroOperacion>
                            <con:numeroPartida><t t-esc="numero_partida"/></con:numeroPartida>
                        </con:peticion>
                    </con:consultarPartidaPeticion>
                </soapenv:Body>
            </soapenv:Envelope>
        </template>

        <template id="consultar_edocument_vucem">
            <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:con="http://www.ventanillaunica.gob.mx/ConsultarEdocument/" xmlns:oxml="http://www.ventanillaunica.gob.mx/cove/ws/oxml/">
                <soapenv:Header>
                    <wsse:Security soapenv:mustUnderstand="1" xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd">
                        <wsse:UsernameToken>
                            <wsse:Username><t t-esc="user_name"/></wsse:Username>
                            <wsse:Password Type="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordText"><t t-esc="user_pass"/></wsse:Password>
                        </wsse:UsernameToken>
                    </wsse:Security>
                </soapenv:Header>
                <soapenv:Body>
                    <con:ConsultarEdocumentRequest>
                        <con:request>
                            <con:firmaElectronica>
                                <oxml:certificado><t t-esc="certificado"/></oxml:certificado>
                                <oxml:cadenaOriginal><t t-esc="cadena_original"/></oxml:cadenaOriginal>
                                <oxml:firma><t t-esc="firma"/></oxml:firma>
                            </con:firmaElectronica>
                            <con:criterioBusqueda>
                                <con:eDocument><t t-esc="edocument"/></con:eDocument>
                                <con:numeroAdenda></con:numeroAdenda>
                            </con:criterioBusqueda>
                        </con:request>
                    </con:ConsultarEdocumentRequest>
                </soapenv:Body>
            </soapenv:Envelope>
        </template>

        <template id="descargar_acuse_vucem">
            <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:oxml="http://www.ventanillaunica.gob.mx/consulta/acuses/oxml">
                <soapenv:Header>
                    <wsse:Security xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd">
                        <wsse:UsernameToken xmlns:wsu="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-utility-1.0.xsd">
                            <wsse:Username><t t-esc="user_name"/></wsse:Username>
                            <wsse:Password Type="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-username-token-profile-1.0#PasswordText"><t t-esc="user_pass"/></wsse:Password>
                        </wsse:UsernameToken>
                    </wsse:Security>
                </soapenv:Header>
                <soapenv:Body>
                    <oxml:consultaAcusesPeticion>
                        <idEdocument><t t-esc="complemento"/></idEdocument>
                    </oxml:consultaAcusesPeticion>
                </soapenv:Body>
            </soapenv:Envelope>
        </template>

        <template id="descargar_edocument_vucem">
            <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:tem="http://tempuri.org/">
                <soapenv:Header>
                    <tem:UserName><t t-esc="user_name"/></tem:UserName>
                    <tem:Password><t t-esc="user_pass"/></tem:Password>
                </soapenv:Header>
                <soapenv:Body>
                    <tem:DocumentoIn>
                        <tem:Edocument><t t-esc="complemento"/></tem:Edocument>
                    </tem:DocumentoIn>
                </soapenv:Body>
            </soapenv:Envelope>
        </template>
    </data>
</odoo>