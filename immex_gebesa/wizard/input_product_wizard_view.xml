<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='input_product_form'>
            <field name='name'>input.product.wz.form</field>
            <field name='model'>input.product.wz</field>
            <field name='arch' type='xml'>
                <form string='Entrada/Producto'>
                    <group>
                        <field name='fecha_inicio'/>
                        <field name='fecha_final' />
                    </group>
                    <footer>
                        <button string="Ejecutar" name="input_product_wz_m" type="object" default_focus="1" class="btn-primary"/>
                        or
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_report_input_product" model="ir.actions.act_window">
            <field name="name">Entrada Producto</field>
            <field name="res_model">input.product.wz</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="input_product_form"/>
            <field name="context">{}</field>
            <field name="target">new</field>
        </record>
    

         <!--menuitem id="entrada_producto_menu" name="Entrada Productos" parent="wizard_menu" action="action_report_input_product"/-->
    </data>
</odoo>
