<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="view_l10_mx_pedimento_tasas_Action">
            <field name="name">Pedimento tasas</field>
            <field name="res_model">l10n.mx.immex.pedimento.tasas</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('clave_documento', 'in', ['IN', 'V1', 'AF', 'RT'])]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Pedimento Casos
                </p>
            </field>
        </record>


         <menuitem id="pedimento_tasas_menu" name="Pedimento Tasas" parent="pedimento_menu" action="view_l10_mx_pedimento_tasas_Action"/>

        <record model="ir.ui.view" id="view_l10_mx_Action_pedimento_tasas_form">
            <field name="name">pedimento.tasas.form</field>
            <field name="model">l10n.mx.immex.pedimento.tasas</field>
            <field name="arch" type="xml">
                <form string="Tasas Form" create ="false" edit="false" delete ="false">
                    <sheet>
                        <group col="6" colspan="2">
                            <field name='patente'/>
                            <field name='num_pedimento'/>
                            <field name='clave_aduana'/>
                            <field name='pedimento_num'/>
                            <field name='clave_contribucion'/>
                            <field name='tasa'/>
                            <field name='tipo_tasa'/>
                            <field name='tipo_pedimento'/>
                            <field name='fecha_pago_real'/>
                            <field name='clave_documento'/>
                            <field name='pedimento_id'/>
                            <field name='resumen_id'/>
                        </group>
                    </sheet>
                </form> 
            </field>
        </record>
        <record model="ir.ui.view" id="view_l10_mx_Action_pedimento_tasas_view_tree">
            <field name="name">Pedimento.tasas.tree</field>
            <field name="model">l10n.mx.immex.pedimento.tasas</field>
            <field name="arch" type="xml">
                <tree string="Tasas Tree" create ="false" edit="false" delete ="false">
                            <field name='patente'/>
                            <field name='num_pedimento'/>
                            <field name='clave_aduana'/>
                            <field name='pedimento_num'/>
                            <field name='clave_contribucion'/>
                            <field name='tasa'/>
                            <field name='tipo_tasa'/>
                            <field name='tipo_pedimento'/>
                            <field name='fecha_pago_real'/>
                            <field name='clave_documento'/>
                            <field name='resumen_id'/>
                </tree>
            </field>
        </record>
    </data>
</odoo>
