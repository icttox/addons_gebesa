<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data>
        <record id="view_partner_immex_form" model="ir.ui.view">
            <field name="name">view.partner.immex.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/group/field[@name='lang']" position="after">
                    <field name="omitir_rt"/>
                    <field name="custom_broker"/>
                    <field name="transporter"/>
                </xpath>
            </field>
        </record>
        <record id="res_partner_search_view" model="ir.ui.view">
            <field name="name">res.partner.search</field>
            <field name="model">res.partner</field>
            <field name="mode">primary</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
            <separator/>
            <filter string="Temporal Custom Broker" name="temporal_partners_broker" domain="[('custom_broker', '=', True)]"/>
            </xpath>
            </field>
        </record>
        <record id="broker_action" model="ir.actions.act_window">
            <field name="name">Custom Broker</field>
            <field name="res_model">res.partner</field>
            <field name="view_type">form</field>
            <field name="search_view_id" ref="res_partner_search_view"/>
            <field name="view_mode">tree,form</field>
            <field name="context">{"search_default_temporal_partners_broker": 1}</field>
        </record>
        <record id="res_partner_search_filter_view" model="ir.ui.view">
            <field name="name">res.partner.search.filter</field>
            <field name="model">res.partner</field>
            <field name="mode">primary</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
            <separator/>
            <filter string="Temporal Transporter" name="temporal_transporter" domain="[('transporter', '=', True)]"/>
            </xpath>
            </field>
        </record>
        <record id="transporter_action" model="ir.actions.act_window">
            <field name="name">Transporter</field>
            <field name="res_model">res.partner</field>
            <field name="view_type">form</field>
            <field name="search_view_id" ref="res_partner_search_filter_view"/>
            <field name="view_mode">tree,form</field>
            <field name="context">{"search_default_temporal_transporter": 1}</field>
        </record>
        <menuitem id="menu_custom_broker" action="broker_action" name="Agentes Aduanales" parent="immex_gebesa.menu_l10n_mx_cat" sequence="90"/>
        <menuitem id="menu_transporter" action="transporter_action" name="Trasportista" parent="immex_gebesa.menu_l10n_mx_cat" sequence="100"/>
    </data>
</openerp>