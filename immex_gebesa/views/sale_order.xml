<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="pediment_code_view_order_form" model="ir.ui.view">
            <field name="name">pediment.entry.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/notebook/page/group/group/field[@name='team_id']" position="after">
                    <field name="pediment_number"/>
                    <field name="patente_aduanal"/>
                    <field name="entry_date"/>
                    <field name="clave_aduanal"/>
                    <field name="clave_pedimento" readonly="1"/>
                    <field name="double_export_invoice"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>