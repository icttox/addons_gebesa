<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="view_l10_mx_pedimento_rectificaciones_Action">
            <field name="name">Pedimento rectificaciones</field>
            <field name="res_model">l10n.mx.immex.pedimento.rectificaciones</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('clave_documento', 'in', ['IN', 'V1', 'AF', 'RT'])]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Pedimento Rectificaciones
                </p>
            </field>
        </record>


         <menuitem id="pedimento_rectificaciones_menu" name="Pedimento Rectificaciones" parent="pedimento_menu" action="view_l10_mx_pedimento_rectificaciones_Action"/>

        <record model="ir.ui.view" id="view_l10_mx_Action_pedimento_rectificaciones_form">
            <field name="name">pedimento.rectificaciones.form</field>
            <field name="model">l10n.mx.immex.pedimento.rectificaciones</field>
            <field name="arch" type="xml">
                <form string="rectificaciones Form" create ="false" edit="false" delete ="false">
                    <sheet>
                        <group col="6" colspan="2">
                            <field name='patente'/>
                            <field name='num_pedimento'/>
                            <field name='clave_aduana'/>
                            <field name='pedimento_num'/>
                            <field name='clave_documento'/>
                            <field name='fecha_pago'/>
                            <field name='num_pedimento_anterior'/>
                            <field name='patente_aduanal_anterior'/>
                            <field name='clave_aduanal_anterior'/>
                            <field name='clave_documento_anterior'/>
                            <field name='fecha_operacion_anterior'/>
                            <field name='num_pedimento_original'/>
                            <field name='patente_aduanal_original'/>
                            <field name='clave_aduanal_original'/>
                            <field name='fecha_pago_real'/>
                            <field name='pedimento_id'/>
                            <field name='resumen_id'/>
                        </group>
                    </sheet>
                </form> 
            </field>
        </record>
        <record model="ir.ui.view" id="view_l10_mx_Action_pedimento_rectificaciones_view_tree">
            <field name="name">Pedimento.rectificaciones.tree</field>
            <field name="model">l10n.mx.immex.pedimento.rectificaciones</field>
            <field name="arch" type="xml">
                <tree string="rectificaciones Tree" create ="false" edit="false" delete ="false">
                            <field name='patente'/>
                            <field name='num_pedimento'/>
                            <field name='clave_aduana'/>
                            <field name='pedimento_num'/>
                            <field name='clave_documento'/>
                            <field name='fecha_pago'/>
                            <field name='num_pedimento_anterior'/>
                            <field name='patente_aduanal_anterior'/>
                            <field name='clave_aduanal_anterior'/>
                            <field name='clave_documento_anterior'/>
                            <field name='fecha_operacion_anterior'/>
                            <field name='num_pedimento_original'/>
                            <field name='patente_aduanal_original'/>
                            <field name='clave_aduanal_original'/>
                            <field name='fecha_pago_real'/>           
                            <field name='resumen_id'/>
                </tree>
            </field>
        </record>
    </data>
</odoo>
