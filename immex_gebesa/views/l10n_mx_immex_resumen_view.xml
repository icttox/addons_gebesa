<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="view_l10_mx_immex_resumen_Action">
            <field name="name">Immex resumen</field>
            <field name="res_model">l10n.mx.immex.resumen</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Immex Resumen
                </p>
            </field>
        </record>

        <menuitem id="configuration_menu" name="Configuracion" parent="immex_menu" sequence="50"/>

         <menuitem id="immex_resumen_menu" name="Immex Resumen" parent="configuration_menu" action="view_l10_mx_immex_resumen_Action"/>

        <record model="ir.ui.view" id="view_l10_mx_Action_immex_resumen_form">
            <field name="name">immex.partida.resumen.form</field>
            <field name="model">l10n.mx.immex.resumen</field>
            <field name="arch" type="xml">
                <form string="Immex resumen Form" create ="false" edit="false" delete ="false">
                    <sheet>
                        <group col="6" colspan="2">
                            <field name='folio'/>
                            <field name='rfc'/>
                            <field name='fechaini'/>
                            <field name='fechafin'/>
                            <field name='fechaexe'/>
                        </group>
                        <notebook>
                            <page string="Pedimento">
                                <div>
                                    <field name="pedimento_ids">
                                        <tree editable="bottom"> 
                                            <field name='pedimento_num'/>
                                            <field name='fecha_pedimento'/>
                                            <field name='tipo_operacion'/>
                                            <field name='clave_documento'/>
                                            <field name='fecha_pago_real'/>
                                            <field name='regime_changed'/>
                                        </tree>
                                    </field>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div> 
                </form> 
            </field>
        </record>
        <record model="ir.ui.view" id="view_l10_mx_Action_immex_resumen_view_tree">
            <field name="name">immex.resumen.tree</field>
            <field name="model">l10n.mx.immex.resumen</field>
            <field name="arch" type="xml">
                <tree string="immex resumen Tree" create ="false" edit="false" delete ="false">
                            <field name='folio'/>
                            <field name='rfc'/>
                            <field name='fechaini'/>
                            <field name='fechafin'/>
                            <field name='fechaexe'/>
                </tree>
            </field>
        </record>
    </data>
</odoo>
