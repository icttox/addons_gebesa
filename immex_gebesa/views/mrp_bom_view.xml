<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="immex_mrp_bom_search_view" model="ir.ui.view">
            <field name="name">immex.mrp.bom.search</field>
            <field name="model">mrp.bom</field>
            <field name="mode">primary</field>
            <field name="inherit_id" ref="mrp.view_mrp_bom_filter"/>
            <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
            <separator/>
            <filter string="Temporal Import Bill of Materials" name="bom_a24" domain="[('salida_a24', '=', True)]"/>
            </xpath>
            </field>
        </record>
        <record id="materials_action" model="ir.actions.act_window">
            <field name="name">Bill of Materials</field>
            <field name="res_model">mrp.bom</field>
            <field name="view_type">form</field>
            <field name="search_view_id" ref="immex_mrp_bom_search_view"/>
            <field name="view_mode">tree,form</field>
            <field name="context">{"search_default_bom_a24": 1}</field>
        </record>
        <menuitem id="menu_bill_materials" action="materials_action" name="Listas de Materiales" parent="immex_gebesa.menu_l10n_mx_cat" sequence="90"/>
    </data>
</odoo>
