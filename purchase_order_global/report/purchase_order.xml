<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="assets_specific" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/purchase_order_global/static/src/css/travel_instructions.css"/>
            </xpath>
        </template>

        <report
            id="order_global"
            model="res.partner"
            string="Imprimir Pedido GLOBAL"
            report_type="qweb-pdf"
            name="purchase_order_global.report_order_global"
            file="purchase_order_global.report_order_global"
        />

        <template id="report_order_global_document">
            <div class="header">
                <div id="cabezera">
                </div>
                <div width="100%">
                    <div class="col-xs-4" id="logo">
                        <img class="logo_porte" t-if="doc.create_uid.partner_id.company_id.logo" t-att-src="'data:image/png;base64,%s' % doc.create_uid.partner_id.company_id.logo"/>
                    </div>
                    <div style="text-align:center;" id="titulo">
                        PEDIDO GLOBAL
                    </div>
                </div>
                <div id="departamento">
                    DEPARTAMENTO DE COMPRAS
                </div>
                <div id="departamento">

                </div>
                <div style="text-align:center;" id="titulo">
                        Fecha:&#160;<span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                </div>
            </div>
            <div class="page">
                <br/>
                <div class="col-xs-12" id="cobranza">
                    PROVEEDORES
                </div>
                <br/>
                <div class="col-xs-12" id="tablaa"> 
                <!--SECCION TABLA -->
                    <table width="100%" class="mrp_shipment_table_detail" style="top:15pt">
                        <tr>
                            <td id="titulo_tabla" width="19%">Proveedor</td>
                            <td id="titulo_tabla" width="9%">Código</td>
                            <td id="titulo_tabla" width="18%">Order Line</td>
                            <td id="titulo_tabla" width="9%">Cantidad</td>
                            <td id="titulo_tabla" width="9%">Recibido</td>
                            <td id="titulo_tabla" width="9%">Pendiente</td>
                            <td id="titulo_tabla" width="10%">Fecha PO</td>
                            <td id="titulo_tabla" width="7%">PO</td>
                        </tr>
                        <t t-foreach="res" t-as="trav3">
                            <tr>
                                <td>
                                    <t><span t-esc="trav3[0]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[1]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[2]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[3]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[4]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[5]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[6]"/></t>
                                </td>
                                <td>
                                    <t><span t-esc="trav3[7]"/></t>
                                </td>
                            </tr>
                        </t>
                    </table>
                </div>
                <br/>
                <br/>
            </div>
            <div class="footer">
                <div id="linea" class="col-xs-12">
                </div>
                <div class="col-xs-6">
                    www.gebesa.com
                </div>
                <div class="col-xs-6" align="right">
                    Página 1 de 1
                </div>
            </div>
        </template>
        <template id="report_order_global">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="purchase_order_global.report_order_global_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>