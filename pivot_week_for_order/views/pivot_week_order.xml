<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
        Work Order Report
        -->
        <record id="sale_order_pivot" model="ir.ui.view">
            <field name="name">sale.order.pivot</field>
            <field name="model">sale.order</field>
            <field name='inherit_id' ref="sale.view_sale_order_pivot"/>
            <field name="arch" type="xml">
                <xpath expr="/pivot/field[@name='date_order']" position="replace">
                    <field name="analytic_account_id" type="row"/>
                    <field name='date_order' type="col" interval="week"/>
                </xpath>
                <xpath expr="/pivot/field[@name='amount_total']" position="replace">
                    <field name='net_sale_rate_mex' type="measure"/>
                </xpath>
            </field>
        </record>
