<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="l10n_mx_edi_taxpayer_type_form">
            <field name="name">l10n_mx_edi.taxpayer.type.form</field>
            <field name="model">l10n_mx_edi.taxpayer.type</field>
            <field name="arch" type="xml">
                <form string="Taxpayer Type">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>    

        <record model="ir.ui.view" id="l10n_mx_edi_taxpayer_type_tree">
            <field name="name">l10n_mx_edi.taxpayer.type.tree</field>
            <field name="model">l10n_mx_edi.taxpayer.type</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Taxpayer Types" editable="bottom">
                    <field name="code"/>
                    <field name="name"/>
                </tree>
            </field>
        </record>
        <record model="ir.actions.act_window" id="l10n_mx_edi_taxpayer_type_action">
                <field name="name">Taxpayer Types</field>
                <field name="res_model">l10n_mx_edi.taxpayer.type</field>
                <field name="view_type">form</field>
                <field name="view_mode">tree,form</field>
                <field name="help" type="html">
                    <p class="o_view_nocontent_smiling_face">Create the first retention types</p>
                </field>
        </record>

        <menuitem id="l10n_mx_edi_taxpayer_type_menu" name="Taxpayer Types" parent="l10n_mx_edi_retentions_conf" action="l10n_mx_edi_taxpayer_type_action"/>
    </data>
</odoo>