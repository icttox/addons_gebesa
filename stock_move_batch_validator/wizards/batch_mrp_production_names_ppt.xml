<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="batch_mrp_production_ppt_view" model="ir.ui.view">
        <field name="name">batch.mrp.production.ppt.view</field>
        <field name="model">batch.mrp.production.ppt</field>
        <field name="arch" type="xml">
            <form string="MOs">
                <label for="mo_names" string="Enter the names of the mrp productions you want to procure, produce and transfer."/>
                <!--group col="4"-->
                <field name="mo_names"/>
                <!--/group-->
                <footer>
                    <button class="oe_highlight" default_focus="1" name="action_ppt_all" string="Transfer" type="object"/>
                    
                    <button class="oe_link" special="cancel" string="Cancel"/></footer>
            </form>
        </field>
    </record>

    <record id="action_batch_mrp_production_ppt" model="ir.actions.act_window">
        <field name="name">Batch mrp production by names</field>
        <field name="res_model">batch.mrp.production.ppt</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="batch_mrp_production_ppt_view"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem action="action_batch_mrp_production_ppt" id="menu_batch_mrp_production_ppt" name="batch mrp production by names" parent="inventory_special_process" groups="stock_move_batch_validator.group_mrp_production_all_processes"/>
</odoo>