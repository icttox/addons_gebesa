<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="batch_picking_names_view" model="ir.ui.view">
        <field name="name">Picking for create account entry</field>
        <field name="model">batch.picking.account</field>
        <field name="arch" type="xml">
            <form string="Pickings">
                <label for="sp_names" string="Enter the names of the picking for create account entry."/>
                <!--group col="4"-->
                <field name="sp_names"/>
                <!--/group-->
                <footer>
                    <button class="oe_highlight" default_focus="1" name="action_create_entry" string="Create" type="object"/>
                    
                    <button class="oe_link" special="cancel" string="Cancel"/></footer>
            </form>
        </field>
    </record>
    <record id="action_batch_picking_names" model="ir.actions.act_window">
        <field name="name">Picking for create account entry</field>
        <field name="res_model">batch.picking.account</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="batch_picking_names_view"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem action="action_batch_picking_names" id="menu_batch_picking_names" name="Picking for create account entry" parent="stock_move_batch_validator.inventory_special_process"/>
</odoo>