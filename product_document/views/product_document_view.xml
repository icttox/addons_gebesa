<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="product_document_form">
            <field name="name">product.document.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Product Document">
                        <field name="product_document_ids">
                            <tree editable="bottom"> 
                                <field name="description"/>
                                <field name="product_type"/>
                                <field name="link" widget="url"/>
                                <field name="revision"/>
                                <field name="change_log"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record model='ir.ui.view' id='product_normal_form_view'>
            <field name='name'>product.product.form.tmpl.inherit.view</field>
            <field name='model'>product.product</field>
            <field name='inherit_id' ref="product.product_normal_form_view"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='product_tmpl_id']" position="attributes">
                    <attribute name="invisible">False</attribute>
                </xpath>

                <button name="263" position="replace">
                    <button type="object"
                        name="action_view_product_documents"
                        class="oe_stat_button"
                        icon="fa-dropbox"
                        string="Document links"
                        groups="base.group_user">
                    </button>
                </button>
            </field>
        </record>
    </data>
</odoo>