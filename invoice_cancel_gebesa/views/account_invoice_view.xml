<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='account_invoice_refacture_view_form'>
            <field name='name'>account_invoice_refacture_view_form</field>
            <field name='model'>account.invoice</field>
            <field name='inherit_id' ref='account.invoice_form'/>
            <field name='arch' type='xml'>
                <xpath expr="//page/group/group/field[@name='name']" position="after">
                    <field name="invoice_refacture_id" domain="[('type', '=', 'out_invoice'), ('partner_id','=', partner_id)]" attrs="{'readonly':[('state','!=', 'open')]}"/>
                    <field name="reason_cancellation" attrs="{'readonly':[('state','!=', 'open')], 'required': [('invoice_refacture_id', '!=', False)]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>