<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="account_voucher_unreconcile_form" model="ir.ui.view">
            <field name="name">account.voucher.unreconcile.form</field>
            <field name="model">account.voucher.unreconcile</field>
            <field name="arch" type="xml">
                <form string="Unreconcile payment">
                    <group>
                        <group colspan="4">
                            <field name="payment_id" readonly="True"/>
                            <!--field name="voucher_id" readonly="True"/-->
                        </group>
                    </group>
                    <footer>
                        <button icon="gtk-ok" name="voucher_unreconcile_payment" string="Unreconcile" type="object"/>
                        Or
                        <button icon="gtk-cancel" special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_account_voucher_unreconcile" model="ir.actions.act_window">
            <field name="name">Unreconcile Voucher Payment</field>
            <field name="res_model">account.voucher.unreconcile</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>