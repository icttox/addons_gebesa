<odoo>
    <data>
        <record id="hr_payslip_form" model="ir.ui.view">
            <field name="name">hr.payslip.form</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header/button[@name='refund_sheet']" position="after">
                    <button name="import_payslips_from_microsip" string="Importar nominas de microsip" type="object" groups="payroll_import.import_payslips_from_microsip_button"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>