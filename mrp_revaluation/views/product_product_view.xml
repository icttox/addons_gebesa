<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="product_variant_easy_view_inherit2" model="ir.ui.view">
            <field name="name">product.variant.easy.view.inherit2</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock_account.product_variant_easy_edit_view_inherit"/>
            <field name="arch" type="xml">
                <data>
                    <field name="standard_price" position="attributes">
                        <attribute name="readonly">True</attribute>
                    </field>
                    <xpath expr="//field[@name='cost_method']" position="after">
                        <field name="bom_count" invisible="1"/>
                    </xpath>
                    <xpath expr="//div/div[@name='update_cost_price']/button" position="attributes">
                        <attribute name="attrs">{'invisible':['|','|',('valuation','!=', 'real_time'), ('cost_method', 'not in', ['standard', 'average']), ('bom_count', '!=', 0)]}</attribute>
                    </xpath>
                </data>
            </field>
        </record>

        <record id="product_normal_form_view_inherit2" model="ir.ui.view">
            <field name="name">product.product.form.inherit.stock_account2</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock_account.product_normal_form_view_inherit"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='standard_price']" position="before">
                        <field name="bom_count" invisible="1"/>
                    </xpath>
                    <xpath expr="//div[@name='update_cost_price']/button" position="attributes">
                        <attribute name="attrs">{'invisible':['|','|',('valuation','!=', 'real_time'), ('cost_method', 'not in', ['standard', 'average']), ('bom_count', '!=', 0)]}</attribute>
                    </xpath>
                </data>
            </field>
        </record>
    </data>
</odoo>