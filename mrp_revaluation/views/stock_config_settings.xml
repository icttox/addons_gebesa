<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='perc_revaluation_res_config_settings_view_form'>
        	<field name='name'>perc.revaluation.res.config.settings.view.form</field>
        	<field name='model'>res.config.settings</field>
        	<field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        	<field name='arch' type='xml'>
                <xpath expr="//div[@data-key='stock']/div[3]/div[3]" position="after">
                    <div class="col-xs-12 col-md-6 o_setting_box" id="sale_config_online_confirmation">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <label for="perc_revaluation"/>
                                <div class="mt16">
                                    <field name="perc_revaluation"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
        	</field>
        </record>
    </data>
</odoo>