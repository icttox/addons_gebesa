<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_sale_backorder_pivot" model="ir.ui.view">
            <field name="name">view.sale.backorder.pivot</field>
            <field name="model">sale.order.backorder</field>
            <field name="arch" type="xml">
                <pivot string="Sales Orders Backorder Test" disable_linking="True">
                    <field name="order_id" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="action_sale_backorder_all" model="ir.actions.act_window">
            <field name="name">Sales Orders Backorder Test</field>
            <field name="res_model">sale.order.backorder</field>
            <field name="view_type">form</field>
            <field name="view_mode">pivot</field>
            <field name="view_id"></field>  <!-- force empty -->
            <field name="help">Test.</field>
        </record>

        <menuitem name="Sales Orders Backorder Test" action="action_sale_backorder_all" id="menu_sale_backorder_all" parent="base.menu_sale_report"/>

    </data>
</odoo>