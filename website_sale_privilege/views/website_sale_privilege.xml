<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='website_publish_button_form'>
            <field name='name'>website.publish.button.form</field>
            <field name='model'>product.template</field>
            <field name='inherit_id' ref='product.product_template_form_view'/>
            <field name='arch' type='xml'>
                <xpath expr="//div/button[@name='website_publish_button']" position="replace">
                    <button class="oe_stat_button" name="website_publish_button"
                        type="object" icon="fa-globe" groups="global_privilege_button.group_manager_product">
                        <field name="website_published" widget="website_button"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>