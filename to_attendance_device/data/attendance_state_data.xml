			<field name="name">Break-Out</field>
			<field name="code" eval="2" />
			<field name="activity_id" ref="attendance_activity_normal" />
			<field name="type">breakout</field>
		</record>
		<record id="attendance_device_state_code_3" model="attendance.state">
			<field name="name">Break-In</field>
			<field name="code" eval="3" />
			<field name="activity_id" ref="attendance_activity_normal" />
			<field name="type">breakin</field>
		</record> -->
		
		<!-- Overtime Attendance -->
		<record id="attendance_device_state_code_4" model="attendance.state">
			<field name="name">Check-in</field>
			<field name="code" eval="4" />
			<field name="activity_id" ref="attendance_activity_overtime" />
			<field name="type">checkin</field>
		</record>
		<record id="attendance_device_state_code_5" model="attendance.state">
			<field name="name">Check-out</field>
			<field name="code" eval="5" />
			<field name="activity_id" ref="attendance_activity_overtime" />
			<field name="type">checkout</field>
		</record>

		<record id="attendance_device_state_code_6" model="attendance.state">
			<field name="name">Break</field>
			<field name="code" eval="6" />
			<field name="activity_id" ref="attendance_activity_normal" />
			<field name="type">break</field>
			<field name="start_time">11.9166666666667</field>
			<field name="end_time">15.2333333333333</field>
		</record>
		<record id="attendance_device_state_code_7" model="attendance.state">
			<field name="name">Night</field>
			<field name="code" eval="7" />
			<field name="activity_id" ref="attendance_activity_normal" />
			<field name="type">night</field>
			<field name="start_time">22.5</field>
			<field name="end_time">4.23333333333333</field>
		</record>

		<record id="attendance_device_state_code_255" model="attendance.state">
			<field name="name">No type</field>
			<field name="code" eval="255" />
			<field name="activity_id" ref="attendance_activity_normal" />
			<field name="type">notype</field>
		</record>
	</data>
