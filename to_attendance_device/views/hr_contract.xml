<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="hr_contract_overtime_view_form">
            <field name="name">contract.overtime.form</field>
            <field name="model">hr.contract</field>
            <field name="inherit_id" ref="hr_contract.hr_contract_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[@name='information']/group/group/field[@name='advantages']" position="after">
                    <separator string='Horas Extras'/>
                    <field name="max_overtime"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>