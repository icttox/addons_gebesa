<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='mrp_bost_res_config_settings_view_form'>
            <field name='name'>mrp.bost.res.config.settings.view.form</field>
            <field name='model'>res.config.settings</field>
            <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//div[@data-key='mrp']" position="inside">
                    <h2>Boost manufacturing</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-lg-6 col-12 o_setting_box" id="mrp_bost_steps" title="Make production orders without supply movements (1 step) or with supply movements (2 steps)">
                            <div class="o_setting_right_pane">
                                <label for="manufacturing_steps"/>
                                <div class="text-muted">
                                    Ordenes de fabricaciones sin movimientos de abastecimientos  (1 paso) o con movimientos de abastecimiento (2 pasos)
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="manufacturing_steps" widget="radio" class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
        	</field>
        </record>
    </data>
</odoo>