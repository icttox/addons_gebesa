<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="waybill_complementv30" inherit_id="l10n_mx_edi_extended.cfdiv40">
        <xpath expr="//*[name()='cfdi:Comprobante']" position="attributes" t-if="record.l10n_mx_edi_origin and complement_waybill_version == '3.0'">
            <attribute name="xmlns__cartaporte31">http://www.sat.gob.mx/CartaPorte31</attribute>
        </xpath>
        <xpath expr="*" position="inside">
            <t t-if="record.l10n_mx_edi_waybill_complement and complement_waybill_version == '3.0' and not record.l10n_mx_edi_skip_waybill">
                <cfdi:Complemento
                    xmlns:cfdi="http://www.sat.gob.mx/cfd/4">
                    <!--t t-set="distancias" t-value="record._l10n_mx_edi_waybill_distance()"/-->
                    <cartaporte31:CartaPorte
                        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                        xsi:schemaLocation="http://www.sat.gob.mx/CartaPorte31 http://www.sat.gob.mx/sitio_internet/cfd/CartaPorte/CartaPorte31.xsd"
                        xmlns:cartaporte31="http://www.sat.gob.mx/CartaPorte31"
                        Version="3.1"
                        t-att-TranspInternac="transp_internac"
                        t-att-IdCCP="id_ccp"
                        t-att-EntradaSalidaMerc="entrada_salida_merc"
                        t-att-ViaEntradaSalida="via_entrada_salida"
                        t-att-PaisOrigenDestino="pais_origen_destino"
                        t-att-TotalDistRec="distancias['total']">
                        <cartaporte31:Ubicaciones>
                            <t t-set="id_orig" t-value="False"/>
                            <t t-if="cant_trans">
                                <t t-set="id_orig" t-value="'OR000001'"/>
                            </t>
                            <cartaporte31:Ubicacion TipoUbicacion="Origen" t-att-IDUbicacion="id_orig" t-att-RFCRemitenteDestinatario="record.travel_ids[0].departure_address_id.vat" t-att-NombreRemitenteDestinatario="record.travel_ids[0].departure_address_id.name" t-att-FechaHoraSalidaLlegada="record.travel_ids[0].date_start_real.strftime('%Y-%m-%dT%H:%M:%S')">
                                <cartaporte31:Domicilio 
                                    t-att-Estado="record.travel_ids[0].departure_address_id.state_id.code" 
                                    t-att-Pais="record.travel_ids[0].departure_address_id.country_id.l10n_mx_edi_code" 
                                    t-att-CodigoPostal="record.travel_ids[0].departure_address_id.zip"/>
                            </cartaporte31:Ubicacion>
                            <t t-set="num_delivery" t-value="0"/>
                            <t t-foreach="record.travel_ids" t-as="travel">
                                <t t-foreach="travel.delivery_ids" t-as="delyvery">
                                    <t t-set="id_dest" t-value="False"/>
                                    <t t-if="cant_trans">
                                        <t t-set="id_dest" t-value="'DE' + str(delyvery.sequence).zfill(6)"/>
                                    </t>
                                    <cartaporte31:Ubicacion TipoUbicacion="Destino" t-att-DistanciaRecorrida="distancias[str(num_delivery)]" t-att-IDUbicacion="id_dest" t-att-RFCRemitenteDestinatario="delyvery.partner_id.vat if delyvery.partner_id.vat else delyvery.partner_id.parent_id.vat" t-att-FechaHoraSalidaLlegada="delyvery.date_time_delivery.strftime('%Y-%m-%dT%H:%M:%S')">
                                        <cartaporte31:Domicilio 
                                            t-att-Estado="delyvery.partner_id.state_id.code" 
                                            t-att-Pais="delyvery.partner_id.country_id.l10n_mx_edi_code" 
                                            t-att-CodigoPostal="delyvery.partner_id.zip"/>
                                    </cartaporte31:Ubicacion>
                                    <t t-set="num_delivery" t-value="num_delivery + 1"/>
                                </t>
                            </t>
                        </cartaporte31:Ubicaciones>
                        <t t-set="weight_total" t-value="record._get_transportable_weights('weight', False)"/>
                        <!-- Calcular peso bruto -->
                        <t t-set="gross_weight" t-value="record._get_transportable_weights('gross_weight', False)"/>
                        <t t-set="qty_total" t-value="len(record.mapped('travel_ids').mapped('transportable_line_ids').mapped('transportable_id'))"/>
                        <cartaporte31:Mercancias 
                            UnidadPeso="KGM"
                            t-att-PesoBrutoTotal="'%.3f' % gross_weight"
                            t-att-PesoNetoTotal="'%.3f' % weight_total" 
                            t-att-NumTotalMercancias="qty_total"
                            t-att-LogisticaInversaRecoleccionDevolucion="'Sí' if record.travel_ids[0].l10n_mx_edi_reverse_logistics else False">
                            <t t-foreach="record.mapped('travel_ids').mapped('transportable_line_ids').mapped('transportable_id')" t-as="transportable">
                                <t t-set="weight" t-value="record._get_transportable_weights('gross_weight', transportable.id)"/>
                                <t t-set="qty" t-value="sum(record.mapped('travel_ids').mapped('transportable_line_ids').filtered(lambda x: x.transportable_id.id == transportable.id).mapped('quantity'))"/>
                                <cartaporte31:Mercancia 
                                    t-att-BienesTransp="transportable.products_services_id.code" 
                                    t-att-Descripcion="transportable.name"
                                    t-att-Cantidad="qty" 
                                    t-att-ClaveUnidad="transportable.uom_id.l10n_mx_edi_code_sat_id.code" 
                                    t-att-MaterialPeligroso="False if transportable.threatening == 'none' else 'Sí' if transportable.dangerous else 'No'" 
                                    t-att-Embalaje="transportable.packing_type_id.code"
                                    t-att-DescripEmbalaje="transportable.packing_type_id.name"
                                    t-att-CveMaterialPeligroso="transportable.dangerous_material_id.code"
                                    t-att-PesoEnKg="'%.3f' % weight"
                                    t-att-FraccionArancelaria="transportable.l10n_mx_edi_tariff_fraction_id.code if transp_internac else False">
                                    <!-- Pedimentos -->
                                    <t t-foreach="record.mapped('travel_ids').mapped('transportable_line_ids').filtered(lambda x: x.transportable_id.id == transportable.id).mapped('pedimento_ids')" t-as="pedimento">
                                        <cartaporte31:DocumentacionAduanera
                                            t-att-TipoDocumento="pedimento.document_type"
                                            t-att-NumPedimento="pedimento.name"
                                            t-att-IdentDocAduanero="pedimento.folio"
                                            t-att-RFCImpo="pedimento.importer_rfc"/>
                                    </t>
                                    <!-- ValorMercancia=""-->
                                    <t t-if="cant_trans">
                                        <t t-foreach="record.mapped('travel_ids').mapped('transportable_line_ids').filtered(lambda x: x.transportable_id.id == transportable.id)" t-as="cant_tran">
                                            <t t-set="id_dest" t-value="'DE' + str(cant_tran.delivery_id.sequence).zfill(6)"/>
                                            <cartaporte31:CantidadTransporta 
                                                t-att-Cantidad="cant_tran.quantity" 
                                                IDOrigen="OR000001" 
                                                t-att-IDDestino="id_dest"/>
                                        </t>
                                    </t>
                                    <!--t t-set="net_weight" t-value="record._get_transportable_weights('net_weight', transportable.id)"/-->
                                    <!--t t-set="tara_weight" t-value="record._get_transportable_weights('tara_weight', transportable.id)"/-->
                                    <!--cartaporte31:DetalleMercancia 
                                        t-att-UnidadPeso="transportable.unit_weight_id.code"
                                        t-att-PesoBruto="weight"
                                        t-att-PesoNeto="net_weight"
                                        t-att-PesoTara="tara_weight"/-->
                                </cartaporte31:Mercancia>
                            </t>
                            <cartaporte31:Autotransporte 
                                t-att-PermSCT="record.company_id.stc_type_permit.code"
                                t-att-NumPermisoSCT="record.company_id.sct_reg">
                                <cartaporte31:IdentificacionVehicular 
                                    t-att-ConfigVehicular="record.travel_ids[0].conf_vehicle_id.code"
                                    t-att-PesoBrutoVehicular="record.travel_ids[0].conf_vehicle_id.gvwr"
                                    t-att-PlacaVM="record.travel_ids[0].unit_id.license_plate"
                                    t-att-AnioModeloVM="record.travel_ids[0].unit_id.year_model"/>
                                <cartaporte31:Seguros 
                                t-att-AseguraRespCivil="record.travel_ids[0].insurance_supplier_id.name"
                                t-att-PolizaRespCivil="record.travel_ids[0].insurance_policy"
                                t-att-AseguraMedAmbiente="record.travel_ids[0].environmental_insurance_supplier_id.name"
                                t-att-PolizaMedAmbiente="record.travel_ids[0].environmental_insurance_policy"/>
                                <t t-if="record.travel_ids[0].unit_id.trailer">
                                    <cartaporte31:Remolques>
                                        <cartaporte31:Remolque 
                                            t-att-SubTipoRem="record.travel_ids[0].trailer1_id.sub_type_rem.code"
                                            t-att-Placa="record.travel_ids[0].trailer1_id.license_plate"/>
                                        <t t-if="record.travel_ids[0].trailer2_id">
                                            <cartaporte31:Remolque 
                                            t-att-SubTipoRem="record.travel_ids[0].trailer2_id.sub_type_rem.code"
                                            t-att-Placa="record.travel_ids[0].trailer2_id.license_plate"/>
                                        </t>
                                    </cartaporte31:Remolques>
                                </t>
                            </cartaporte31:Autotransporte>
                        </cartaporte31:Mercancias>
                        <cartaporte31:FiguraTransporte>
                            <cartaporte31:TiposFigura 
                                TipoFigura="01" 
                                t-att-RFCFigura="record.travel_ids[0].employee_id.rfc"
                                t-att-NumLicencia="record.travel_ids[0].employee_id.driver_license"
                                t-att-NombreFigura="record.travel_ids[0].employee_id.name">
                                <!--cartaporte31:Domicilio 
                                    t-att-Calle="record.travel_ids[0].employee_id.address_home_id.street_name"
                                    t-att-Localidad="record.travel_ids[0].employee_id.address_home_id.l10n_mx_edi_locality_id.code" 
                                    t-att-Municipio="record.travel_ids[0].employee_id.address_home_id.city_id.l10n_mx_edi_code"
                                    t-att-Estado="record.travel_ids[0].employee_id.address_home_id.state_id.code"
                                    t-att-Pais="record.travel_ids[0].employee_id.address_home_id.country_id.l10n_mx_edi_code"
                                    t-att-CodigoPostal="record.travel_ids[0].employee_id.address_home_id.zip" /-->
                            </cartaporte31:TiposFigura>
                            <t t-if="record.travel_ids[0].employee_two_id">
                                <cartaporte31:TiposFigura 
                                    TipoFigura="01"
                                    t-att-RFCFigura="record.travel_ids[0].employee_two_id.rfc"
                                    t-att-NumLicencia="record.travel_ids[0].employee_two_id.driver_license"
                                    t-att-NombreFigura="record.travel_ids[0].employee_two_id.name">
                                    <!--cartaporte31:Domicilio 
                                        t-att-Calle="record.travel_ids[0].employee_two_id.address_home_id.street_name"
                                        t-att-Localidad="record.travel_ids[0].employee_two_id.address_home_id.l10n_mx_edi_locality_id.code" 
                                        t-att-Municipio="record.travel_ids[0].employee_two_id.address_home_id.city_id.l10n_mx_edi_code"
                                        t-att-Estado="record.travel_ids[0].employee_two_id.address_home_id.state_id.code"
                                        t-att-Pais="record.travel_ids[0].employee_two_id.address_home_id.country_id.l10n_mx_edi_code"
                                        t-att-CodigoPostal="record.travel_ids[0].employee_two_id.address_home_id.zip" /-->
                               </cartaporte31:TiposFigura>
                            </t>
                        </cartaporte31:FiguraTransporte>
                     </cartaporte31:CartaPorte>
                </cfdi:Complemento>
            </t>
        </xpath>
    </template>
</odoo>