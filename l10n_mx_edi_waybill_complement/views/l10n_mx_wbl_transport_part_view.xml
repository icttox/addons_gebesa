<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_transport_part_form_view">
            <field name="name">l10n.mx.wbl.transport.part.form</field>
            <field name="model">l10n.mx.wbl.transport.part</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Transport Part">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_transport_part_tree_view">
            <field name="name">l10n.mx.wbl.transport.part.tree</field>
            <field name="model">l10n.mx.wbl.transport.part</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Transport Part">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_transport_part_action">
            <field name="name">Waybill Transport Part</field>
            <field name="res_model">l10n.mx.wbl.transport.part</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill transport part
                </p>
            </field>
        </record>

        <menuitem action="wbl_transport_part_action" id="menu_wbl_transport_part" name="Transport Part" parent="menu_wbl_complement" sequence="50"/>
    </data>
</odoo>