<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_load_type_form_view">
            <field name="name">l10n.mx.wbl.load.type.form</field>
            <field name="model">l10n.mx.wbl.load.type</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Load Type">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_load_type_tree_view">
            <field name="name">l10n.mx.wbl.load.type.tree</field>
            <field name="model">l10n.mx.wbl.load.type</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Load Type">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_load_type_action">
            <field name="name">Waybill Load Type</field>
            <field name="res_model">l10n.mx.wbl.load.type</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill load type
                </p>
            </field>
        </record>

        <menuitem action="wbl_load_type_action" id="menu_wbl_load_type" name="Load Type" parent="menu_wbl_complement" sequence="130"/>
    </data>
</odoo>
    