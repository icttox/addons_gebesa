<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_stcc_products_services_form_view">
            <field name="name">l10n.mx.wbl.stcc.products.services.form</field>
            <field name="model">l10n.mx.wbl.stcc.products.services</field>
            <field name="arch" type="xml">
                <form string="Form Waybill STCC Products Services">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_stcc_products_services_tree_view">
            <field name="name">l10n.mx.wbl.stcc.products.services.tree</field>
            <field name="model">l10n.mx.wbl.stcc.products.services</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill STCC Products Services">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_stcc_products_services_action">
            <field name="name">Waybill STCC Products Services</field>
            <field name="res_model">l10n.mx.wbl.stcc.products.services</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill stcc products services
                </p>
            </field>
        </record>

        <menuitem action="wbl_stcc_products_services_action" id="menu_wbl_stcc_products_services" name="STCC Products Services" parent="menu_wbl_complement" sequence="160"/>
    </data>
</odoo>
    