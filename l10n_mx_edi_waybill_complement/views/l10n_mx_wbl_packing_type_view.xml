<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_packing_type_form_view">
            <field name="name">l10n.mx.wbl.packing.type.form</field>
            <field name="model">l10n.mx.wbl.packing.type</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Packing Type">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_packing_type_tree_view">
            <field name="name">l10n.mx.wbl.packing.type.tree</field>
            <field name="model">l10n.mx.wbl.packing.type</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Packing Type">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_packing_type_action">
            <field name="name">Waybill Packing Type</field>
            <field name="res_model">l10n.mx.wbl.packing.type</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill packing type
                </p>
            </field>
        </record>

        <menuitem action="wbl_packing_type_action" id="menu_wbl_packing_type" name="Packing Type" parent="menu_wbl_complement" sequence="60"/>
    </data>
</odoo>
    