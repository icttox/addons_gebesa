<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_maritime_conf_form_view">
            <field name="name">l10n.mx.wbl.maritime.conf.form</field>
            <field name="model">l10n.mx.wbl.maritime.conf</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Maritime Configuration">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_maritime_conf_tree_view">
            <field name="name">l10n.mx.wbl.maritime.conf.tree</field>
            <field name="model">l10n.mx.wbl.maritime.conf</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Maritime Configuration">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_maritime_conf_action">
            <field name="name">Waybill Maritime Configuration</field>
            <field name="res_model">l10n.mx.wbl.maritime.conf</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill maritime configuration
                </p>
            </field>
        </record>

        <menuitem action="wbl_maritime_conf_action" id="menu_wbl_maritime_conf" name="Maritime Configuration" parent="menu_wbl_complement" sequence="120"/>
    </data>
</odoo>
    