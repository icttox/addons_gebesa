<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_figure_transport_form_view">
            <field name="name">l10n.mx.wbl.figure.transport.form</field>
            <field name="model">l10n.mx.wbl.figure.transport</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Figure Transport">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_figure_transport_tree_view">
            <field name="name">l10n.mx.wbl.figure.transport.tree</field>
            <field name="model">l10n.mx.wbl.figure.transport</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Figure Transport">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_figure_transport_action">
            <field name="name">Waybill Figure Transport</field>
            <field name="res_model">l10n.mx.wbl.figure.transport</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill figure transport
                </p>
            </field>
        </record>

        <menuitem action="wbl_figure_transport_action" id="menu_wbl_figure_transport" name="Figure Transport" parent="menu_wbl_complement" sequence="50"/>
    </data>
</odoo>