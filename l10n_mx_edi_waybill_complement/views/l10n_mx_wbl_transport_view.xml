<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_transport_form_view">
            <field name="name">l10n.mx.wbl.transport.form</field>
            <field name="model">l10n.mx.wbl.transport</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Transport">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_transport_tree_view">
            <field name="name">l10n.mx.wbl.transport.tree</field>
            <field name="model">l10n.mx.wbl.transport</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Transport">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_transport_action">
              <field name="name">Waybill Transport</field>
              <field name="res_model">l10n.mx.wbl.transport</field>
              <field name="view_type">form</field>
              <field name="view_mode">tree,form</field>
              <field name="help" type="html">
                  <p class="o_view_nocontent_smiling_face">Create the waybill transport
                  </p>
              </field>
          </record>
        <menuitem id="menu_wbl_complement" name="Waybill Complement" parent="tms.menu_tms" sequence="100"/>
        <menuitem action="wbl_transport_action" id="menu_wbl_transport" name="Transport" parent="menu_wbl_complement" sequence="10"/>
    </data>
</odoo>
    