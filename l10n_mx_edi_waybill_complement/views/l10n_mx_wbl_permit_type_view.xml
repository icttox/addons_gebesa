<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_permit_type_form_view">
            <field name="name">l10n.mx.wbl.permit.type.form</field>
            <field name="model">l10n.mx.wbl.permit.type</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Permit Type">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="transport_id"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_permit_type_tree_view">
            <field name="name">l10n.mx.wbl.permit.type.tree</field>
            <field name="model">l10n.mx.wbl.permit.type</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Permit Type">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="transport_id"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_permit_type_action">
            <field name="name">Waybill Permit Type</field>
            <field name="res_model">l10n.mx.wbl.permit.type</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill permit type
                </p>
            </field>
        </record>

        <menuitem action="wbl_permit_type_action" id="menu_wbl_permit_type" name="Permit Type" parent="menu_wbl_complement" sequence="70"/>
    </data>
</odoo>
    