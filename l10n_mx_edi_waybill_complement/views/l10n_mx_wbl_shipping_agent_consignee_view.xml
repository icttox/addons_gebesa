<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.ui.view" id="wbl_shipping_agent_consignee_form_view">
            <field name="name">l10n.mx.wbl.shipping.agent.consignee.form</field>
            <field name="model">l10n.mx.wbl.shipping.agent.consignee</field>
            <field name="arch" type="xml">
                <form string="Form Waybill Shipping Agent Consignee">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="wbl_shipping_agent_consignee_tree_view">
            <field name="name">l10n.mx.wbl.shipping.agent.consignee.tree</field>
            <field name="model">l10n.mx.wbl.shipping.agent.consignee</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Tree Waybill Shipping Agent Consignee">
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="wbl_shipping_agent_consignee_action">
            <field name="name">Waybill Shipping Agent Consignee</field>
            <field name="res_model">l10n.mx.wbl.shipping.agent.consignee</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the waybill shipping agent consignee
                </p>
            </field>
        </record>

        <menuitem action="wbl_shipping_agent_consignee_action" id="menu_wbl_shipping_agent_consignee" name="Shipping Agent Consignee" parent="menu_wbl_complement" sequence="150"/>
    </data>
</odoo>
    