<?xml version="1.0" encoding="utf-8"?>

<odoo>
  <data>
    <record id="product_replacement_import_view_form" model="ir.ui.view">
      <field name="name">product.replacement.import.view.form</field>
      <field name="model">product.replacement.import</field>
      <field name="arch" type="xml">
        <form string="Product Replacement Import">
          <group>
            <field name="data" filename="filename"/>
            <field name="filename" invisible="1"/>
          </group>
          <footer>
            <button name="import_product_replacement" string="Importar" type="object" class="btn-primary"/>
            <button string="Cancel" class="btn-default" special="cancel" />
          </footer>
        </form>
      </field>
    </record>

    <record id="product_replacement_import_action" model="ir.actions.act_window">
      <field name="name">Product Replacement Import</field>
      <field name="res_model">product.replacement.import</field>
      <field name="view_type">form</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="product_replacement_import_view_form"/>
      <field name="target">new</field>
      <field name="groups_id" eval="[(4,ref('system_administrator.group_system_administrator_gebesa'))]"/>
    </record>

  </data>
</odoo>

