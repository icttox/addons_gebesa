<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record model='ir.ui.view' id='view_order_form'>
            <field name='name'>view_order_product_family_form</field>
            <field name='model'>sale.order</field>
            <field name='inherit_id' ref='sale.view_order_form'/>
            <field name='arch' type='xml'>
                <xpath expr="//sheet/notebook/page[last()]" position="after">
                    <page string="Product Family">
                        <field name="sale_order_product_family_id" string="Product Family">
                            <tree string="Product Family">                                  
                                <field name="family_id"/>
                                <field name="margin"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
                <xpath expr="//page[@name='other_information']/group/group/field[@name='expected_date']" position="before">
                    <field name="project_tracking"/>
                </xpath>
            </field>
        </record>
	</data>
</odoo>