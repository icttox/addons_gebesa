<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="account_invoice_reconcile_view">
            <field name="name">account.invoice.reconcile.view</field>
            <field name="model">account.invoice</field>
            <field name="inherit_id" ref="account.invoice_supplier_form"/>
            <field name="arch" type="xml"> 
                <xpath expr="//notebook" position="inside">
                    <page string="Conciliaciones de anticipos">
                        <field name="reconcile_advance_ids" readonly="1"/>
                    </page>
                </xpath>                                 
            </field>
        </record>
    </data>
</odoo>