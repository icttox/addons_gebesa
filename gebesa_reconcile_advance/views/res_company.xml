<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_res_company_tax_form" model="ir.ui.view">
            <field name="name">res.company.tax.form</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page/group/group/field[@name='currency_id']" position="after">
                        <field name='advance_tax_id'/>
                        <field name='advance_tax_cust_id'/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>