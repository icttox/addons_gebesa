<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <data noupdate="1">
        <record model="res.groups" id="group_gra_user">
            <field name="name">Advance Reconcile User</field>
        </record>
        <record model="res.groups" id="group_gra_manager">
            <field name="name">Advance Reconcile Manager</field>
        </record>
        <record id="group_cancel_advance_reconcile" model="res.groups">
            <field name="name">Cancel Advance Reconcile</field>
        </record>

        <record id="ir_rule_same_company" model="ir.rule">
            <field name="name">See Reconciliation of My Own Company</field>
            <field name="model_id" ref="model_gebesa_reconcile_advance"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field eval="False" name="global"/>
            <field name="domain_force">[('company_id','=',user.company_id.id)]</field>
            <field name="groups" eval="[(4,ref('gebesa_reconcile_advance.group_gra_manager')),(4,ref('gebesa_reconcile_advance.group_gra_user'))]"/>
        </record>
    </data>
</odoo>