<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="assets_specific" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/website_maintenance_hr/static/src/css/website_equipments.css"/>
            </xpath>
        </template>

        <template id="assets_frontend" inherit_id="website.assets_frontend">
            <xpath expr="script[last()]" position="after">
                <script type="text/javascript" src="/website_maintenance_hr/static/src/js/website_maintenance.js"></script>
            </xpath>
        </template>

        <template id="Maintenance">
            <t t-call="web.basic_layout">
                <div class="container">
                    <t t-call-assets="web.assets_frontend" t-js="false"/>
                    <t t-call-assets="web.assets_frontend" t-css="false"/>
                    <title>Maintenance</title>
                    <form t-attf-action="/submit" method="post" data-success_page="/maintenance_request-thanks" enctype="multipart/form-data" style="font-size: 25pt">
                        <div class="form-group form-field o_website_form_required_custom col-md-offset-2 col-sm-offset-3">
                            <br/>
                            <p style="font-size: 30pt">
                                <b>Maintenance Request</b>
                            </p>
                            <!--label class="col-md-3 col-sm-4 control-label" for="subject">Subject</label>
                            <div class="col-lg-7 col-md-8">
                                <input type="text" class="form-control o_website_form_input" name="subject"/>
                            </div-->
                        </div>

                        <div class="form-group form-field o_website_form_required_custom">
                            <input type="text" class="form-control o_website_form_input team" name="team" style="visibility: hidden; display: none;"/>
                            <label class="col-md-3 col-sm-4 control-label" for="from">Team</label>
                             <div class="col-lg-9 col-md-10">
                                <select class="form-control form-control-lg o_website_form_input" id="team_id" name="teams" required="">
                                    <option value="">Select Team</option>
                                    <t t-foreach="team_selection" t-as="team">
                                        <option t-att-value="team['id']">
                                            <t t-esc="team['name']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <label class="col-md-3 col-sm-4 control-label date_to" for="to">Ubicacion</label>
                            <div class="col-lg-9 col-md-10">
                                <select class="form-control form-control-lg o_website_form_input" id="ubication" name="ubication" required="">
                                    <option value="">Seleccionar ubicacion</option>
                                    <t t-foreach="ubication_selection" t-as="ubication">
                                        <option t-att-value="ubication['id']">
                                            <t t-esc="ubication['name']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <label class="col-md-3 col-sm-4 control-label date_to" for="to">Equipment</label>
                            <div class="col-lg-9 col-md-10">
                                <select class="form-control form-control-lg o_website_form_input" id="equipment" name="equipment" required="">
                                    <option value="">Select Equipment</option>
                                    <t t-foreach="equipment_selection" t-as="equipment">
                                        <option t-att-value="equipment['id']">
                                            <t t-esc="equipment['name']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <label class="col-md-3 col-sm-4 control-label date_to" for="to">Priority</label>
                            <div class="col-lg-9 col-md-10">
                                <select class="form-control form-control-lg o_website_form_input" id="priority_id" name="stars" required="">
                                    <option value="">Select Priority</option>
                                    <option value="0">Very Low</option>
                                    <option value="1">Low</option>
                                    <option value="2">Normal</option>
                                    <option value="3">High</option>
                                </select>
                            </div>

                            <label class="col-md-3 col-sm-4 control-label date_to" for="provision">Picture</label>
                            <div class="col-lg-9 col-md-10">
                                <input type="file" name="warning_evidence" class="form-control form-control-lg o_website_form_input"/>
                            </div>

                        </div>

                        <div class="form-group form-field o_website_form_required_custom">
                            <label class="col-md-3 col-sm-4 control-label" for="description">Details</label>
                            <div class="col-md-9 col-sm-10">
                                <textarea class="form-control form-control-lg" rows="4" name="details"/>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="row"  style="height: 5rem;">
                                <div class="col-md-offset-1 col-sm-offset-1 col-sm-5 col-md-5">
                                    <button type="submit" class="btn btn-primary btn-lg w-100 h-100 o_website_form_send">Submit</button>
                                    <span id="o_website_form_result">
                                    </span>
                                </div>
                                <div class="col-md-offset-1 col-sm-offset-1 col-sm-5 col-md-5">
                                    <a href="/production_floor">
                                        <button type="button" class="btn btn-danger btn-lg w-100 h-100 o_website_form_send">Cancel</button>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <br/>
                    </form>
                </div>
            </t>
        </template>

