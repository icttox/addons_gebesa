        <template id="equipment_details" name="Equipment">
        <t t-call="web.basic_layout">
            <body style="background-color: rgb(195, 203, 207)">
                <div class="jumbotron m-0 h2" style="background-color: rgb(17, 122, 185)">
                    <div class="container">
                        <h1 class="display-4 text-white"><span t-field="equipment.name"/></h1>
                        <p class="lead text-white"><span t-field="equipment.consecutive_id"/></p>
                    </div>
                </div>
                <div class="fondo-titulo">
                    <h1>Informacion</h1>
                </div>
                <div class="w-100 pt-1 pb-1">
                    <div style="display: flex;">
                        <t t-if="equipment.image_render">
                            <img t-att-src="image_data_uri(equipment.image_render)" alt="Imagen no guardada" style="max-width: 555px; border: 6px solid rgb(222, 221, 238)"/>
                        </t>
                        <t t-if="equipment.image_plano">
                            <img t-att-src="image_data_uri(equipment.image_plano)" alt="Imagen no guardada" style="max-width: 555px; border: 6px solid rgb(222, 221, 238)"/>
                        </t>
                    </div>
                    <br></br>
                    <div class="col-md-12 pl-1">
                        <h3 style="color:#FF0000">Ubicacion Fisica: <span t-field="equipment.location_physical"/></h3>
                        <h3 style="color:#FF0000">Centro de producción: <span t-field="equipment.workcenter_id"/></h3>
                        <h3>Marca: <span t-field="equipment.mark"/></h3>
                        <h3>Modelo: <span t-field="equipment.model"/></h3>
                        <h3>Nº de serie: <span t-field="equipment.serial_no"/></h3>
                        <h3>Capacidad: <span t-field="equipment.capacity"/></h3>
                        <h3>Dimensiones: <span t-field="equipment.dimensions"/></h3>
                        <h3>Fecha efectiva: <span t-field="equipment.effective_date"/></h3>
                        <h3>Fecha de Compra: <span t-field="equipment.warranty_date"/></h3>
                        <h3>Last IP: <span t-field="equipment.last_ip"/></h3>
                        <h3>Número Interno: <span t-field="equipment.int_number"/></h3>
                        <h3>Dispositivo de Seguridad: <span t-field="equipment.security_device"/></h3>
                        <h3>Nota: <span t-field="equipment.note"/></h3>
                    </div>
                </div>
                <br></br>
                <div class="fondo-titulo">
                    <h1>Mantenimiento</h1>
                </div>
                 <div class="w-100 pt-1 pb-1">
                    <div class="col-md-3">
                        <t t-if="equipment.image">
                            <img t-att-src="image_data_uri(equipment.image)" alt="Imagen no guardada" style="max-width: 555px; border: 6px solid rgb(222, 221, 238)"/>
                        </t>
                    </div>
                    <br></br>
                    <div class="col-md-10 pl-1">
                        <t t-if="equipment.maintenance_ids">
                            <tr t-foreach='equipment.maintenance_ids' t-as='line'>
                                <h3>Responsable de mantenimiento: <span t-field="line.user_id.name"/></h3>
                                <h3>Tipo de mantenimiento: <span t-field="line.maintenance_type"/></h3>
                                <h3>Duración: <span t-field="line.duration"/></h3>
                                <h3>Costo Aproximado: <span t-field="line.stopped_cost"/></h3>
                                <h3>Fecha de solicitud: <span t-field="line.request_date"/></h3>
                                <h3>Fecha cierre: <span t-field="line.close_date"/></h3>
                            </tr>
                        </t>
                        <h3>Siguiente mantenimiento preventivo:<span t-field="equipment.next_action_date"/></h3>
                    </div>                       
                </div>
            </body>
        </t>
        </template>

        <record id="thanks" model="website.page">
            <field name="name">Thanks</field>
            <field name="type">qweb</field>
            <field name="url">/maintenance_request-thanks</field>
            <field name="website_published">True</field>
            <field name="arch" type="xml">
                <t name="Thanks" t-name="maintenance_request.thanks">
                    <t t-call="web.basic_layout">
                        <div id="wrap">
                            <t t-call-assets="web.assets_frontend" t-js="false"/>
                            <div class="oe_structure"/>
                            <div class="container">
                                <br/><br/><br/>
                                <h1>Thank You</h1>
                                <div class="row">
                                    <div class="col-lg-8">
                                        <div class="alert alert-success" role="status" style="font-size: 25pt">
                                            Your maintenance request has been submitted successfully.
                                        </div>
                                    </div>
                                </div>
                                <div class="row mt5">
                                    <div class="col-lg-8" style="height: 3rem;">
                                        <a href="/maintenance_request">
                                            <button type="button" class="btn btn-success btn-lg w-100 h-100 o_website_form_send">Return</button>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </field>
        </record>

        <record id="nouser" model="website.page">
            <field name="name">No User</field>
            <field name="type">qweb</field>
            <field name="url">/maintenance_request-nouser</field>
            <field name="website_published">True</field>
            <field name="arch" type="xml">
                <t name="No User Found" t-name="maintenance_request.nouser">
                    <t t-call="web.basic_layout">
                        <div id="wrap">
                            <t t-call-assets="web.assets_frontend" t-js="false"/>
                            <div class="oe_structure"/>
                            <div class="container">
                                <br/><br/><br/>
                                <h1>We're Sorry.!</h1>
                                <div class="row">
                                    <div class="col-lg-8">
                                        <div class="alert alert-warning" role="status" style="font-size: 25pt">
                                            You cannot send maintenance request to us since you are not a registered employee.
                                        </div>
                                    </div>
                                </div>
                                <div class="row mt5">
                                    <div class="col-lg-8" style="height: 3rem;">
                                        <a href="/production_floor">
                                            <button type="button" class="btn btn-danger btn-lg w-100 h-100 o_website_form_send">Return</button>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </field>
        </record>

    </data>
</odoo>
