<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="res_physical_location_view_website_published_form" model="ir.ui.view">
            <field name="name">res.physical.location.view.website.published.form</field>
            <field name="model">res.physical.location</field>
            <field name="inherit_id" ref="informatica_gebesa.view_ubicacion_fisica_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group" position="before">
                    <div class="oe_button_box" name="button_box" position="inside">
                        <button class="oe_stat_button" name="website_publish_button"
                            type="object" icon="fa-globe">
                            <field name="website_published" widget="website_button"/>
                        </button>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>