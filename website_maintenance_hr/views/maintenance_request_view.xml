<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="hr_equipment_request_view_image_form" model="ir.ui.view">
            <field name="name">equipment.request.image.form</field>
            <field name="model">maintenance.request</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@class='oe_title']" position="before">
                    <field name="image" web_widget_image_webcam.flash_fallback_mode="1" widget="image" class="oe_avatar"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>