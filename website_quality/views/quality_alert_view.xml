<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="quality_alert_view_gebesa_form" model="ir.ui.view">
            <field name="name">quality.alert.view.gebesa.form</field>
            <field name="model">quality.alert</field>
            <field name="inherit_id" ref="quality_control.quality_alert_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@class='oe_title']" position="before">
                    <field name="image" web_widget_image_webcam.flash_fallback_mode="1" widget="image" class="oe_avatar"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>