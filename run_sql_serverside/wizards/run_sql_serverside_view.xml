<?xml version="1.0" encoding="utf-8"?>

<odoo>
  <data>
    <record id="sql_executer_view_form" model="ir.ui.view">
      <field name="name">sql.executer.form</field>
      <field name="model">sql.executer</field>
      <field name="arch" type="xml">
        <form string="Run Sql Serverside">
          <group>
            <field name="data" filename="filename"/>
            <field name="filename" invisible="1"/>
            <field name="query"/>
          </group>
          <footer>
            <button name="execute_query" string="Importar" type="object" class="btn-primary"/>
            <button string="Cancel" class="btn-default" special="cancel" />
          </footer>
        </form>
      </field>
    </record>

    <record id="run_sql_serverside_action" model="ir.actions.act_window">
      <field name="name">Run Sql Serverside</field>
      <field name="res_model">sql.executer</field>
      <field name="view_type">form</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="sql_executer_view_form"/>
      <field name="target">new</field>
      <field name="groups_id" eval="[(4,ref('system_administrator.group_system_administrator_gebesa'))]"/>
    </record>

    <menuitem id="sql_execute_menu" name="Sql Execute" parent="sale.sale_order_menu" action="run_sql_serverside_action"/>

  </data>
</odoo>

