<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="product_price_list_partner_form_view" model="ir.ui.view">
            <field name="name">product.price.list.partner.form.view</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="product.view_partner_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group/field[@name='property_product_pricelist']" position="after">
                    <field name="sellers_ids" widget="many2many_tags"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>