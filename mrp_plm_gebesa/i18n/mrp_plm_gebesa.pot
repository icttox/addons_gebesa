#. module: mrp_plm_gebesa
#: model:mail.template,body_html:mrp_plm_gebesa.email_template_task_notification
msgid "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"    <p>A new task was assigned to you: </p>\n"
"    \n"
"    <p style=\"border-left: 1px solid #8e0000; margin-left: 30px;\">\n"
"       &nbsp;&nbsp;<strong>REFERENCES</strong><br/>\n"
"       &nbsp;&nbsp;Name: <strong>${object.name}</strong><br/>\n"
"       &nbsp;&nbsp;Project: <strong>${object.project_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Product: <strong>${object.product_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Customer: <strong>${object.partner_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Assigned to: <strong>${object.user_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Deadline: <strong>${object.date_deadline}</strong><br/>\n"
"       &nbsp;&nbsp;Sale Order: <strong>${object.order_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Warehouse: <strong>${object.warehouse_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Muestra: <strong>${object.muestra}</strong><br/>\n"
"       &nbsp;&nbsp;Clave: <strong>${object.clave}</strong><br/>\n"
"       &nbsp;&nbsp;Costo: <strong>${object.costo}</strong><br/>\n"
"       &nbsp;&nbsp;Sembrado: <strong>${object.planted}</strong><br/>\n"
"       &nbsp;&nbsp;Render: <strong>${object.render}</strong><br/>\n"
"    </p>  \n"
"\n"
"    <p>You can check more details <a href=\"http://erp.portalgebesa.com/web?debug=#id=${object.id}&view_type=form&model=project.task&action=203&active_id=219&menu_id=164\">here</a></p>\n"
"    \n"
"    <div style=\"width: 375px; margin: 0px; padding: 0px; background-color: #8E0000; border-top-left-radius: 5px 5px; border-top-right-radius: 5px 5px; background-repeat: repeat no-repeat;\">\n"
"        <h3 style=\"margin: 0px; padding: 2px 14px; font-size: 12px; color: #DDD;\">\n"
"            <strong style=\"text-transform:uppercase;\">${object.company_id.name}</strong></h3>\n"
"    </div>\n"
"    <div style=\"width: 347px; margin: 0px; padding: 5px 14px; line-height: 16px; background-color: #F2F2F2;\">\n"
"        <span style=\"color: #222; margin-bottom: 5px; display: block; \">\n"
"            ${object.company_id.partner_id.sudo().with_context(show_address=True, html_format=True).name_get()[0][1] | safe}\n"
"        </span>\n"
"        % if object.company_id.phone:\n"
"            <div style=\"margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding-top: 0px; padding-right: 0px; padding-bottom: 0px; padding-left: 0px; \">\n"
"                Phone:&nbsp; ${object.company_id.phone}\n"
"            </div>\n"
"        % endif\n"
"        % if object.company_id.website:\n"
"            <div>\n"
"                Web :&nbsp;<a href=\"${object.company_id.website}\">${object.company_id.website}</a>\n"
"            </div>\n"
"        %endif\n"
"        <p></p>\n"
"    </div>\n"
"</div>\n"
"            "
msgstr ""

