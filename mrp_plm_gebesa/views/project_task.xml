        <record model='ir.ui.view' id='project_task_kanban_geb_view'>
            <field name='name'>project.task.kanban.geb.view</field>
            <field name='model'>project.task</field>
            <field name="inherit_id" ref="project.view_task_kanban"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='name']" position="after">
                   <br/><strong><field name="product_id"/></strong><br/>
                </xpath>
                <xpath expr="//field[@name='project_id']" position="after">
                    <br/><field name="partner_id"/>
                    <br/><field name="order_id"/><br/>
                </xpath>
            </field>
        </record>
        <record model="ir.ui.view" id="view_project_task_tree">
            <field name="name">view.project.task.tree</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_tree2" />
            <field name="arch" type="xml">
                <xpath expr="//tree/field[@name='project_id']" position="after">
                    <field name="partner_id"/>
                    <field name="order_id"/>
                </xpath>
            </field>
        </record>
