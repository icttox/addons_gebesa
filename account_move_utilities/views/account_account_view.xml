<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_account_account_form'>
        	<field name='name'>account_account_view_form</field>
        	<field name='model'>account.account</field>
        	<field name='inherit_id' ref='account.view_account_form'/>
        	<field name='arch' type='xml'>
        		<xpath expr="//group/group/field[@name='tag_ids']" position="after">
        			<field name='required_partner'/>
        		</xpath>       		
        	</field>
        </record>

		<record id="view_account_line_tree" model="ir.ui.view">
            <field name="name">account_move_line_view_tree</field>
            <field name="model">account.move.line</field>
            <field name="mode">extension</field>
            <field name="inherit_id" ref="account.view_move_line_tree"/>
            <field name="arch" type="xml">
                <field name="amount_currency" position="after">
                    <field name="amount_residual" readonly="True" sum="Total" groups="base.group_no_one"/> 
					<field name="amount_residual_currency" readonly="True" sum="Total" groups="base.group_no_one"/>
                	<field name="reconciled" readonly="True" sum="Total" groups="base.group_no_one"/>
				</field>
                <field name="date_maturity" position="replace"/>
            </field>
        </record>

		<record model="ir.ui.view" id="account_partial_reconcile_tree_view">
            <field name="name">account.partial.reconcile.tree</field>
            <field name="model">account.partial.reconcile</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
				<tree string="Account Partial Reconcile" create="false">
					<field name='max_date'/>
					<field name='debit_move_id'/>
					<field name='credit_move_id'/>
					<field name='amount'/>
					<field name='company_currency_id'/>
					<field name='amount_currency'/> 
					<field name='currency_id'/> 
					<field name='full_reconcile_id'/> 
				</tree>
            </field>
        </record>

		<record model="ir.actions.act_window" id="account_move_reconcile_action">
            <field name="name">Account Partial Reconcile</field>
			<field name="type">ir.actions.act_window</field>
            <field name="res_model">account.partial.reconcile</field>
			<field name="view_type">form</field>
			<field name="view_mode">tree</field>
            <field name="view_id" ref="account_partial_reconcile_tree_view"/>
			<field name="target">current</field>
        </record>

		<menuitem id="account_partial_menu" name="Account Partial Reconcile" parent="account.menu_finance_entries" action="account_move_reconcile_action"/>


    </data>
</odoo>
