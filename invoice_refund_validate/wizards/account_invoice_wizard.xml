<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='account_invoice_wizard_form'>
            <field name='name'>account.invoice.wizard.form</field>
            <field name='model'>account.invoice.wizard</field>
            <field name='arch' type='xml'>
                <form string='Invoice Approve'>
                    <p class="oe_grey">
                        *Approve this refunds?
                    </p>
                    <footer>
                        <button string="Approve" name="button_invoice_gebesa_wizard" type="object" default_focus="1" class="btn-primary"/>
                        or
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <act_window id="action_account_invoice_wizard"
            multi="True"
            key2="client_action_multi" name="Approve"
            res_model="account.invoice.wizard" src_model="account.invoice"
            view_mode="form" target="new" view_type="form"
            groups="invoice_refund_validate.group_invoice_button_gebesa"/>
    </data>
</odoo>