<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_res_partner_dealer_form">
            <field name="name">view.res.partner.dealer.form</field>
            <field name="model">res.partner.dealer</field>
            <field name="arch" type="xml">
                <form string="Partner Dealer">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button" options="{&quot;terminology&quot;: &quot;archive&quot;}"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label class="oe_edit_only" for="name" string="Dealer Name"/>
                            <h1><field name="name" placeholder="Dealer Name"/></h1>
                        </div>
                        <group>
                            <field name='partner_id'/>
                            <field name='dealer_type'/>
                        </group>
                    </sheet>
                </form> 
            </field>
        </record>

        <record model="ir.ui.view" id="view_res_partner_dealer_tree">
            <field name="name">view.res.partner.dealer.tree</field>
            <field name="model">res.partner.dealer</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Partner Dealer">
                    <field name='name'/>
                    <field name='dealer_type'/>
                    <field name='partner_id'/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_res_partner_dealer">
            <field name="name">Partner Dealer</field>
            <field name="res_model">res.partner.dealer</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Create Partner Dealer
                </p>
            </field>
        </record>

        <menuitem id="res_partner_dealer_menu" name="Partner Dealer" parent="sale.product_menu_catalog" action="action_res_partner_dealer"/>
    </data>
</odoo>