<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='stock_warehouse_company_form'>
            <field name='name'>stock.warehouse.company.form</field>
            <field name='model'>stock.warehouse</field>
            <field name='inherit_id' ref="stock.view_warehouse"/>
            <field name='arch' type='xml'>
                <xpath expr="//form/sheet/group/group/field[@name='company_id']" position="attributes">
                    <attribute name="readonly">False</attribute>
                </xpath>
                <xpath expr="//form/sheet/notebook/page/group/group/field[@name='wh_output_stock_loc_id']" position="after">
                    <field name="lot_stock_id"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
