<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="report_actions_layout">
            <div class="header" style="font-size: 10pt;">
                        <div class="row">
                            <div class="col-9" style="text-align:center;">
                                <span t-field="doc.company_id.name" style="font-size:15pt"/>
                                <br/>
                                <strong>R.F.C. </strong>
                                <span t-field="doc.warehouse_id.partner_id.vat"/>
                            </div>
                            <div class="col-3" style="text-align:center;">
                                <strong>ORDEN DE COMPRA</strong>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-9" style="text-align:center;">
                                <span t-field="doc.warehouse_id.partner_id.street_name"/>
                                <span t-field="doc.warehouse_id.partner_id.street_number"/>
                                <span t-field="doc.warehouse_id.partner_id.l10n_mx_edi_colony"/>
                                <br/>
                                <span t-field="doc.warehouse_id.partner_id.l10n_mx_edi_locality_id"/>
                                <span t-field="doc.warehouse_id.partner_id.state_id"/>
                                <span t-field="doc.warehouse_id.partner_id.zip"/>                               
                            </div>
                            <div class="col-3" style="text-align:center; color: #B72000">
                                <strong>FOLIO</strong>
                                <span t-esc="doc.name"/>
                            </div>
                        </div>
            </div>
            <div class="article o_report_layout_standard">
                <t t-raw="0" />
            </div>
            <div class="footer o_standard_footer" style="font-size: 10pt;">
                <div class="text-right mt-4">
                    <div t-if="report_type == 'pdf'" class="text-muted">
                        <span class="page"/> / <span class="topage"/>
                    </div>
                </div>
            </div>
        </template>

        <report
            id="purchase_order_report"
            model="purchase.order"
            string="Report purchase"
            report_type="qweb-pdf"
            name="purchase_order_gebesa.report_purchase_order"
            file="purchase_order_gebesa.report_purchase_order"
        />
        <template id="report_purchase_order">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                <t t-call="purchase_order_gebesa.report_actions_layout">
                    <div class="page" style="font-size:8pt">
                            <table class="table table-striped table-sm" width="100%" style="text-align:center;">
                                <tr>
                                    <td rowspan="2" style="background-color: #ffffff;color: #000000; width: 50%; text-align:left;"><strong>Provedor</strong>
                                        <span t-esc="doc.partner_id.name"/></td>
                                    <th style="background-color: #BDBBBA;color: #000000;">Fecha</th>
                                    <th style="background-color: #BDBBBA;color: #000000;">Entrega</th>
                                    <th style="background-color: #BDBBBA;color: #000000;">Condiciones</th>
                                </tr>
                                    <tr>
                                        <td><span t-esc="doc.date_order.date()"/></td>
                                        <td> </td>
                                        <td><strong>CREDITO</strong></td>
                                    </tr>
                            </table>
                            <br/>
                            <table class="table table-striped table-sm" width="100%" style="text-align:center;">
                                <tr style="background-color: #BDBBBA;color: #000000;">
                                    <th>CANT</th>
                                    <th>UNIDAD</th>
                                    <th>DESCRIPCION</th>
                                    <th>NOMBRE PRODUCTO</th>
                                    <th>CLAVE PRODUCTO</th>
                                    <th>PRECIO UNIT</th>
                                    <th>DESCUENTO</th>
                                    <th>IMPORTE NETO</th>
                                </tr>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-field="line.product_qty"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_uom"/>
                                        </td>
                                        <td>
                                            <span t-field="line.name"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_id.seller_ids.filtered(lambda seller: seller.name == doc.partner_id and seller.product_id == line.product_id)[0].product_name"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_id.seller_ids.filtered(lambda seller: seller.name == doc.partner_id and seller.product_id == line.product_id)[0].product_code"/>
                                        </td>
                                        <td>
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td>
                                            <span t-field="line.invoice_lines.discount"/>
                                        </td>
                                        <td>
                                            <span string=""/>
                                        </td>
                                    </tr>
                                </t>
                                    <tr>
                                        <td  colspan="6">
                                        </td>
                                        <td align="right">Subtotal: </td>
                                        <td align="right">
                                            <t>$<span t-esc="'{:,.2f}'.format(doc.amount_untaxed)"/></t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="6">
                                        </td>
                                        <td align="right">Total: </td>
                                        <td align="right">
                                            <t><strong>$<span t-esc="'{:,.2f}'.format(doc.amount_total)"/></strong></t>
                                        </td>
                                    </tr>
                            </table>
                            <br/>

                            <table class="table table-striped" width="100%" style="text-align:center; padding-top: 0.3em; padding-bottom: 0.3em;">
                                <tr style="background-color: #BDBBBA;color: #000000;">
                                    <th>DIRECCION</th>
                                    <th>CARGAR A</th>
                                    <th>N° REQ</th>
                                    <th>FIRMA</th>
                                </tr>
                                    <tr>
                                        <td width="50%">
                                            <span t-field="doc.warehouse_id.partner_id.street_name"/>
                                            <span t-field="doc.warehouse_id.partner_id.street_number"/>
                                            <span t-field="doc.warehouse_id.partner_id.l10n_mx_edi_colony"/>
                                            <span t-field="doc.warehouse_id.partner_id.city_id"/>
                                            <span t-field="doc.warehouse_id.partner_id.city"/>
                                            <span t-field="doc.warehouse_id.partner_id.state_id"/>
                                            <span t-field="doc.warehouse_id.partner_id.zip"/>
                                        </td>
                                        <td>
                                            <span t-field="doc.warehouse_id.name"/>
                                        </td>
                                        <td>
                                            <span string=""/>
                                        </td>
                                        <td>
                                            <span string=""/>
                                        </td>
                                    </tr>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>