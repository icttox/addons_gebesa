<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_sale_report_js" model="ir.actions.client">
            <field name="name">Generic Sale Report</field>
            <field name="tag">sale_report_js_generic</field>
            <field name="context" eval="{'url': '/account_reports/output_format/generic_sale_js_report/1', 'model': 'sale.generic.js.report'}" />
        </record>
        <menuitem id="menu_action_sale_report_js" name="Generic Sale Report" action="action_sale_report_js" parent="base.menu_sale_report"/>

        <template id="account_reports_backend" inherit_id="web.assets_backend" active="True">
            <xpath expr="." position="inside">
                <script type="text/javascript" src="/report_sale_order_js/static/src/js/sale_report_js_backend.js"></script>
            </xpath>
        </template>

    <template id="report_sale_js_body">
        <div t-att-data-report-name="str(report.get_name())" t-att-data-context="str(context.id)" t-att-class="' '.join(['container', 'o_account_reports_page', 'o_account_reports_widgets', mode != 'print' and 'o_account_reports_no_print' or ''])">
            <h2 t-esc="report.get_title()"/>
            <h4 class='text-muted' t-esc="context.create_uid.company_id.name"/>
            <div t-if="mode != 'print' and context.summary == ''" class="o_account_reports_summary">
                <div class="addSummary" role="alert">
                    <span><input type='text' class="o_form_input o_form_field" name='summary' placeholder='Click to add an introductory explanation' /></span>
                </div>
            </div>
            <div t-if="mode != 'print' and context.summary != ''" class="o_account_reports_summary mt32">
                <i class="fa fa-fw fa-pencil o_account_reports_edit_summary_pencil"></i>
                <div class="o_account_reports_saved_summary" role="alert">
                    <span><t t-raw="context.summary" /></span>
                </div>
            </div>
            <div t-if="mode == 'print' and context.summary != ''" class="o_account_reports_summary" role="alert">
                <span><t t-raw="context.summary" /></span>
            </div>
            <div t-att-class="mode != 'print' and 'table-responsive' or ''">
                <table width='100%' t-att-class="' '.join(['o_account_reports_table', report.get_report_type() == 'date_range_extended' and 'table-striped' or ''])">
                    <thead>
                        <tr>
                            <th></th>
                            <t t-set="column" t-value="0" />
                            <t t-foreach="context.get_columns_names()" t-as="column_name">
                                <t t-set="column" t-value="column + 1" />
                                <th t-att-class="context.get_columns_types()[column - 1] == 'number' and 'text-right' or context.get_columns_types()[column - 1] == 'text' and  'text-left' or 'text-center'" t-raw="column_name" t-att-width="context.get_columns_types()[column - 1] == 'number' and '1%' or ''" style='padding-left: 15px;'/>
                            </t>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="lines" t-as="a">
                            <t t-call="account_reports.report_financial_line" />
                        </t>
                    </tbody>
                </table>
            </div>
            <t t-foreach="context.footnotes" t-as="footnote">
                <p class="footnote" t-att-id="'footnote' + str(footnote.number)">
                    <span class='text'><t t-raw="str(footnote.number) + '. ' + footnote.text"/></span>
                    <span class='o_account_reports_footnote_icons'><i class="fa fa-fw fa-pencil-square"></i><i class="fa fa-fw fa-trash-o"></i></span>
                </p>
            </t>
        </div>
    </template>

        <template id="report_sale_js">
            <div class='o_account_reports_body'>
                <t t-call='report_sale_order_js.report_sale_js_body' />
            </div>
        </template>
    </data>
</odoo>