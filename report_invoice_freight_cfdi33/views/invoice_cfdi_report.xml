<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="electronic_invoice_report_document" inherit_id="l10n_mx_base.electronic_invoice_report_document">
            <xpath expr="//div[@class='page']/div[@class='row no-gutters']" position="before">
              <div style="margin: 0 auto; background: gray; text-align: center; color: #ffffff;">
                <h6 t-if="o.travel_ids">CFDI CON COMPLEMENTO CARTA PORTE</h6>
              </div>
            </xpath>
            <xpath expr="//div[@class='page']/div[@id='concepts']" position="before">
                
                <t t-if="o.travel_ids">
                    <div class="row">
                        <div class="col-4">
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                    <strong><span>Ruta: </span></strong>
                                </div>
                            </div>
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                    <span t-esc="o.travel_ids[0].route_id.name"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                    <strong><span>Camión: </span></strong>
                                </div>
                            </div>
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                    <span t-esc="o.travel_ids[0].unit_id.name"/> - <span t-esc="o.travel_ids[0].unit_id.conf_vehicle.code"/> - <span t-esc="o.travel_ids[0].unit_id.license_plate"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                    <strong><span>Remolque: </span></strong>
                                </div>
                            </div>
                            <div class="row" style="font-size:9px">
                                <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                    <span><span t-esc="o.travel_ids[0].trailer1_id.name"/> - <span t-esc="o.travel_ids[0].trailer1_id.sub_type_rem.code"/> - <span t-esc="o.travel_ids[0].trailer1_id.license_plate"/> | <span t-esc="o.travel_ids[0].trailer2_id.name"/> - <span t-esc="o.travel_ids[0].trailer2_id.sub_type_rem.code"/> -  <span t-esc="o.travel_ids[0].trailer2_id.license_plate"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12" id="payment_method">
                        <div class="row" style="font-size:9px">
                            <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Remitente / Origen </span></strong>
                            </div>
                            <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Destinatario / Destino </span></strong>
                            </div>
                        </div>
                        <div class="row" style="font-size:9px">
                            <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span>Cliente: </span><span t-esc="o.travel_ids[0].departure_address_id.name"/> <br/>
                                <span>RFC: </span><span t-esc="o.travel_ids[0].departure_address_id.vat"/> <br/>
                                <span>Domicilio: </span><span t-esc="o.travel_ids[0].departure_address_id.street"/> <br/>
                                <span>&#160;&#160;&#160;&#160;</span><span t-esc="o.travel_ids[0].departure_address_id.city"/> <span t-esc="o.travel_ids[0].departure_address_id.state_id.name"/> <span t-esc="o.travel_ids[0].departure_address_id.country_id.name"/><span> CP: </span><span t-esc="o.travel_ids[0].departure_address_id.zip"/>
                            </div>
                            <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span></span><span t-esc="o.travel_ids[0].arrival_address_id.name"/> <br/>
                                <span>RFC Destinatario: </span><span t-esc="o.travel_ids[0].arrival_address_id.vat"/> <br/>
                                <span>Domicilio: </span><span t-esc="o.travel_ids[0].arrival_address_id.street"/> <br/>
                                <span>&#160;&#160;&#160;&#160;</span><span t-esc="o.travel_ids[0].arrival_address_id.city"/> <span t-esc="o.travel_ids[0].arrival_address_id.state_id.name"/> <span t-esc="o.travel_ids[0].arrival_address_id.country_id.name"/><span> CP: </span><span t-esc="o.travel_ids[0].arrival_address_id.zip"/>
                            </div>
                        </div>
                        <div class="row" style="font-size:9px">
                            <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Detalle de la Carga:&#160;&#160;&#160;&#160;&#160;&#160;&#160;Que el Remitente dice que contiene</span></strong>
                            </div>
                        </div>
                        <div class="row no-gutters" style="font-size:9px">
                            <div class="col-12">
                                <table class="table">
                                    <tr>
                                        <th width="12%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Clave producto<br/>servicio</span></strong></th>
                                        <th width="15%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Carga</span></strong></th>
                                        <th width="15%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Descripcion</span></strong></th>
                                        <th width="10%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Unidad de<br/>medida</span></strong></th>
                                        <th width="9%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Cantidad</span></strong></th>
                                        <th width="13%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Peso Unitario</span></strong></th>
                                        <th width="11%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Peso</span></strong></th>
                                        <th width="15%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;"><strong><span>Notas</span></strong></th>
                                    </tr>
                                    <t t-foreach="o.travel_ids[0].transportable_line_ids" t-as="transportable_line">
                                        <tr>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="transportable_line.transportable_id.products_services_id.code"/> 
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="transportable_line.transportable_id.name"/>
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="transportable_line.name"/>
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="transportable_line.transportable_uom_id.name"/>
                                            </td>
                                            <td class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="'%.3f'% transportable_line.quantity"/>
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="'%.3f'% transportable_line.gross_weight"/>
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="'%.3f'% (transportable_line.gross_weight  * transportable_line.quantity)"/>
                                            </td>
                                            <td style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="transportable_line.notes"/>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                        </div>
                        <div class="row" style="font-size:9px">
                            <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Datos Adicionales:</span></strong>
                            </div>
                        </div>
                        <div class="row" style="font-size:9px">
                            <div class="col-4" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <strong><span>Proveedor de Seguros</span></strong>
                            </div>
                            <div class="col-2" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <strong><span>Poliza de Seguro</span></strong>
                            </div>
                            <div class="col-3" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <strong><span>Modelo</span></strong>
                            </div>
                            <div class="col-1" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <strong><span>Año</span></strong>
                            </div>
                            <div class="col-2" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <strong><span>Distancia Recorrida</span></strong>
                            </div>
                        </div>
                        <div class="row" style="font-size:9px">
                            <div class="col-4" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="o.travel_ids[0].insurance_supplier_id.name"/> 
                            </div>
                            <div class="col-2" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="o.travel_ids[0].insurance_policy"/> 
                            </div>
                            <div class="col-3" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="o.travel_ids[0].unit_id.model_id.name"/>
                            </div>
                            <div class="col-1" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="o.travel_ids[0].unit_id.year_model"/>
                            </div>
                            <div class="col-2" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <t t-if="all(deliv.distance_previous_point > 0 for deliv in o.mapped( 'travel_ids').mapped('delivery_ids'))">
                                    <t t-set="distancias" t-value="o._l10n_mx_edi_waybill_manual_distance()"/>
                                </t>
                                <t t-if="not all(deliv.distance_previous_point > 0 for deliv in o.mapped( 'travel_ids').mapped('delivery_ids'))">
                                    <t t-set="distancias" t-value="o._l10n_mx_edi_waybill_distance()"/>
                                </t>
                                <span t-esc="distancias['total']"/> km
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-4">
                                <div class="row" style="font-size:9px">
                                    <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                        <strong><span>Entregas:</span></strong>
                                    </div>
                                </div>
                                <div class="row" style="font-size:9px">
                                    <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <strong><span>Entrega</span></strong>
                                    </div>
                                    <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <strong><span>Fecha de entrega</span></strong>
                                    </div>
                                </div>
                                <t t-foreach="o.travel_ids[0].delivery_ids" t-as="delivery">
                                    <div class="row" style="font-size:9px">
                                        <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                            <span t-esc="delivery.partner_id.name"/> 
                                        </div>
                                        <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                            <span t-esc="delivery.date_time_delivery"/> 
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="col-5">
                                <div class="row" style="font-size:9px">
                                    <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                        <strong><span>Operador</span></strong>
                                    </div>
                                </div>
                                <div class="row" style="font-size:9px">
                                    <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <span t-esc="o.travel_ids[0].employee_id.name"/>
                                    </div>
                                </div>
                                <div class="row" style="font-size:9px">
                                    <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <strong><span>Tipo de permiso</span></strong>
                                    </div>
                                    <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <strong><span>Número de permiso</span></strong>
                                    </div>
                                </div>
                                <!-- <t t-foreach="o.travel_ids[0].company_id" t-as="company"> -->
                                    <div class="row" style="font-size:9px">
                                        <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                            <span t-esc="o.company_id.stc_type_permit.name"/> 
                                        </div>
                                        <div class="col-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                            <span t-esc="o.company_id.sct_reg"/> 
                                        </div>
                                    </div>
                                <!-- </t> -->
                            </div>
                            <div class="col-3">
                                <div class="row" style="font-size:9px">
                                    <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                        <strong><span>Observaciones</span></strong>
                                    </div>
                                </div>
                                <div class="row" style="font-size:9px">
                                    <div class="col-12" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <span t-raw="o.travel_ids[0].notes"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </xpath>
        </template>
    </data>
</odoo>