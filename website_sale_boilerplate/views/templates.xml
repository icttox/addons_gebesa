        <template id="checkout" inherit_id="website_sale.checkout">
            <xpath expr="//t/div/div/div/div/t/div/div/div/div/form[@action='/shop/address']/a" position="replace">
                <br/>
            </xpath>
        </template>

        <!-- poner Orden de compra -->
        <template id="extra_info_gebesa" inherit_id="website_sale.extra_info" name="Checkout Extra Info Orden Compra">
            <xpath expr="//t/div/div/div/div/div/div/form[@class='s_website_form container-fluid']" position="replace">
                <form action="/website_form/" method="post" class="s_website_form container-fluid" enctype="multipart/form-data" data-force_action="shop.sale.order" data-model_name="sale.order" data-success_page="/shop/payment">
                    <div class="form-group row form-field o_website_form_custom">
                        <div class="col-lg-3 col-md-4 text-md-right">
                            <label class="col-form-label" for="client_order_ref"><span class='text-danger'>* </span>Your Reference</label>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <input type="text" class="form-control o_website_form_input" name="client_order_ref" required="True" placeholder="Field required"/>
                        </div>
                    </div>
                    <div class="form-group row form-field o_website_form_custom">
                        <div class="col-lg-3 col-md-4 text-md-right">
                            <label class="col-form-label" for="hubspot_id"><span class='text-danger'>* </span>ID de Hubspot</label>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <input type="text" class="form-control o_website_form_input" name="hubspot_id" required="True" placeholder="Field required"/>
                        </div>
                    </div>
                    <div class="form-group row form-field o_website_form_custom">
                        <div class="col-lg-3 col-md-4 text-md-right">
                            <label class="col-form-label" for="Give us your feedback">Give us your feedback</label>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <textarea class="form-control o_website_form_input" rows="8" name="Give us your feedback" />
                        </div>
                    </div>
                    <div class="form-group row form-field o_website_form_custom">
                        <div class="col-lg-3 col-md-4 text-md-right">
                            <label class="col-form-label" for="a_document">A document to provide</label>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <input type="file" class="form-control o_website_form_input" name="a_document" />
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-lg-3 col-md-4">
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <a role="button" href="/shop/checkout" class="btn btn-secondary mb32 float-left"><span class="fa fa-chevron-left" /> Previous</a>
                            <a role="button" class="btn btn-primary float-right mb32 o_website_form_send" href="/shop/confirm_order">Next <span class="fa fa-chevron-right" /></a>
                        </div>
                    </div>
                </form>

            </xpath>
        </template>

        <template id="invisible_delivery_orders" inherit_id="sale_stock.sale_order_portal_content_inherit_sale_stock" name="Delivery Orders invisible">
            <xpath expr="//t[@t-if='sale_order.picking_ids']" position="replace"> 
            </xpath>
        </template>

        <template id="invisible_task_project" inherit_id="project.portal_my_home" name="Task/Project invisible">
            <xpath expr="//t[@t-if='project_count']" position="replace"> 
            </xpath>
            <xpath expr="//t[@t-if='task_count']" position="replace"> 
            </xpath>
        </template>

        <template id="404_producto">
            <t t-call="website.layout">
                <div id="wrap">
                    <t t-raw="0"/>
                    <div class="oe_structure oe_empty">
                        <div class="container">
                            <h1 class="mt32">This Combination of color is temporary unavailable!</h1>
                            <p>
                                Please contact your executive.
                            </p>
                            <ul>
                                <li><a href="/shop">Return the Shop</a></li>
                                <!--<li><a href="/page/website.contactus/">Contact Us</a></li>-->
                            </ul>
                        </div>
                    </div>

                    <t t-if="request.debug">
                        <t t-call="website.http_error_debug"/>
                    </t>
                </div>
            </t>
        </template>

        <template id="new_message_for_variants" inherit_id="website_sale.product">

            <xpath expr="//div[hasclass('js_product')]/p" position="replace">
                <p t-if="len(product.product_variant_ids) &gt; 1" class="css_not_available_msg bg-danger" style="padding: 15px;">
                    <t t-if="product.env['ir.config_parameter'].sudo().get_param('stock.website_variants_visibility_message')"  t-raw="product.env['ir.config_parameter'].sudo().get_param('stock.website_variants_visibility_message')"/>
                    <t t-else="">This variant cannot be purchased from the website. Please contact us for further information.</t>
                </p>
            </xpath>

        </template>
    </data>
</odoo>