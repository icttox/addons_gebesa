<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>        
        <template id="report_delivery_document_inherit" inherit_id="stock.report_delivery_document">       
            <xpath expr="//t/t/div/table[2]" position="replace">
                <table class="table table-condensed mt48" t-if="o.state!='done'">
	                <thead>
	                    <tr>
	                        <th><strong>Producto</strong></th>
	                        <th><strong>Estado</strong></th>
	                        <th><strong>Ubicación</strong></th>
	                        <th class="text-right"><strong>Cantidad</strong></th>
	                    </tr>
	                </thead>
	                <tbody>
		            	<t t-set="lines" t-value="o.move_lines.filtered(lambda x: x.product_uom_qty)"/>
		            	<tr t-foreach="lines" t-as="move">
		                    <td>
		                        <span t-field="move.product_id"/>
		                        <p t-if="o.picking_type_code == 'outgoing'">
		                            <span t-field="move.product_id.sudo().description_pickingout"/>
		                        </p>
		                        <p t-if="o.picking_type_code == 'incoming'">
		                            <span t-field="move.product_id.sudo().description_pickingin"/>
		                        </p>
		                    </td>
		                    <td><span t-field="move.state"/></td>
		                    <td><span t-field="move.location_id"/></td>
		                    <td>
		                        <span t-field="move.product_uom_qty"/>
		                        <span t-field="move.product_uom"/>
		                    </td>
		                </tr>
		            </tbody>
		        </table>
            </xpath>
            <xpath expr="//t/t/div/table[3]" position="replace">
                <table class="table table-condensed mt48" t-if="o.move_line_ids and o.state=='done'">
                	<t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')" groups="stock.group_production_lot"/>
	                <thead>
	                    <tr>
	                        <th><strong>Producto</strong></th>
	                        <th name="lot_serial" t-if="has_serial_number">
                                Lot/Número de Serie
                            </th>
	                        <th><strong>Estado</strong></th>
	                        <th><strong>Ubicación</strong></th>
	                        <th class="text-right"><strong>Cantidad</strong></th>
	                    </tr>
	                </thead>
	                <tbody>
		            	<t t-set="lines" t-value="o.move_lines.filtered(lambda x: x.product_uom_qty)"/>
		            	<tr t-foreach="lines" t-as="move">
		                    <td>
		                        <span t-field="move.product_id"/>
		                        <p t-if="o.picking_type_code == 'outgoing'">
		                            <span t-field="move.product_id.sudo().description_pickingout"/>
		                        </p>
		                        <p t-if="o.picking_type_code == 'incoming'">
		                            <span t-field="move.product_id.sudo().description_pickingin"/>
		                        </p>
		                    </td>
		                    <t t-if="has_serial_number">
                               <td>
                                    <table width="100%">
                                        <tr>
                                            <td>
                                                 <span t-field="move_line.lot_id"/>
                                                 <t t-if="not move_line.lot_id">
                                                     <span t-field="move_line.lot_name"/>
                                                 </t>
                                             </td>
                                             <td name="lot_qty">
                                                 <t t-if="move_line.product_qty"> 
                                                    <span t-field="move_line.product_qty"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </t>
		                    <td><span t-field="move.state"/></td>
		                    <td><span t-field="move.location_id"/></td>
		                    <td>
		                        <span t-field="move.product_uom_qty"/>
		                        <span t-field="move.product_uom"/>
		                    </td>
		                </tr>
		            </tbody>
		        </table>
            </xpath>
        </template>
    </data>
</odoo>