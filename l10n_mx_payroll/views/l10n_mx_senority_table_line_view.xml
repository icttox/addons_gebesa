<odoo>
  <data>
    <record model="ir.ui.view" id="l10n_mx_senority_table_line_tree">
      <field name="name">l10n.mx.senority.table.line</field>
      <field name="model">l10n.mx.senority.table.line</field>
      <field name="arch" type="xml">
        <tree>
          <field name="years"/>
          <field name="vacation_days"/>
          <field name="vacation_porcentage"/>
          <field name="xmass_bonus_days"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="l10n_mx_senority_table_line_form">
      <field name="name">l10n.mx.senority.table.line.form</field>
      <field name="model">l10n.mx.senority.table.line</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="years"/>
              <field name="vacation_days"/>
              <field name="vacation_porcentage"/>
              <field name="xmass_bonus_days"/>
            </group>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
  </data>
</odoo>