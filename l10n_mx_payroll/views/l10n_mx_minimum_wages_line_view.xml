<odoo>
  <data>
    <record model="ir.ui.view" id="l10n_mx_minimum_wages_line_tree">
      <field name="name">l10n.mx.minimum.wages.line.tree</field>
      <field name="model">l10n.mx.minimum.wages.line</field>
      <field name="arch" type="xml">
        <tree>
          <field name="validity"/>
          <field name="amount"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="l10n_mx_minimum_wages_line_form">
      <field name="name">l10n.mx.minimum.wages.line.form</field>
      <field name="model">l10n.mx.minimum.wages.line</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="validity"/>
              <field name="amount"/>
            </group>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
  </data>
</odoo>