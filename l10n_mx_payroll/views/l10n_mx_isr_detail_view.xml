<odoo>
  <data>
    <record model="ir.ui.view" id="l10n_mx_isr_detail_tree">
      <field name="name">l10n.mx.isr.detail.tree</field>
      <field name="model">l10n.mx.isr.detail</field>
      <field name="arch" type="xml">
        <tree>
          <field name="decimal_lower_limit"/>
          <field name="fixed_fee"/>
          <field name="surplus_percentage"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="l10n_mx_isr_detail_form">
      <field name="name">l10n.mx.isr.detail.form</field>
      <field name="model">l10n.mx.isr.detail</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="decimal_lower_limit"/>
              <field name="fixed_fee"/>
              <field name="surplus_percentage"/>
            </group>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
  </data>
</odoo>
