<odoo>
  <data>
    <record model="ir.ui.view" id="l10n_mx_subemp_tree">
      <field name="name">l10n.mx.subemp.tree</field>
      <field name="model">l10n.mx.subemp</field>
      <field name="arch" type="xml">
        <tree>
          <field name="year"/>
          <field name="active"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="l10n_mx_subemp_form">
      <field name="name">l10n.mx.subemp.form</field>
      <field name="model">l10n.mx.subemp</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="year" required="1"/>
              <field name="active"/>
            </group>
            <notebook>
              <page string="Lines">
                <field name="subemp_ids"/>
              </page>
            </notebook>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
    
    <record model="ir.actions.act_window" id="l10n_mx_subemp_action">
      <field name="name">l10n mx subemp</field>
      <field name="res_model">l10n.mx.subemp</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="l10n_mx_subemp_menu_action" name="Subemp monthly" parent="hr_payroll.menu_hr_payroll_configuration"
              action="l10n_mx_payroll.l10n_mx_subemp_action"/>
  </data>
</odoo>
