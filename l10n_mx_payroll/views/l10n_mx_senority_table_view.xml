<odoo>
  <data>
    <record model="ir.ui.view" id="l10n_mx_senority_table_tree">
      <field name="name">l10n.mx.senority.table.tree</field>
      <field name="model">l10n.mx.senority.table</field>
      <field name="arch" type="xml">
        <tree>
          <field name="year"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="l10n_mx_senority_table_form">
      <field name="name">l10n.mx.senority.table.form</field>
      <field name="model">l10n.mx.senority.table</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="year" required="1"/>
            </group>
            <notebook>
              <page string="Lines">
                <field name="senority_line_ids"/>
              </page>
            </notebook>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
    
    <record model="ir.actions.act_window" id="l10n_mx_senority_table_action">
      <field name="name">l10n mx senority</field>
      <field name="res_model">l10n.mx.senority.table</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="l10n_mx_senority_table_menu_action" name="Senority table" parent="hr_payroll.menu_hr_payroll_configuration"
              action="l10n_mx_payroll.l10n_mx_senority_table_action"/>
  </data>
</odoo>