<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="assets_frontend" inherit_id="website_sale.assets_frontend" name="Shop">
            <xpath expr="." position="inside">
                <link rel='stylesheet' href='/website_sale_attribute_img/static/src/css/website_sale_image.css'/>
            </xpath>
        </template>

        <template id="variants_img" inherit_id="sale.variants">
            <xpath expr="//ul/t/li/strong" position="replace">
                <strong t-if="variant_id.name_web" t-field="variant_id.name_web"/>
                <strong t-if="not variant_id.name_web" t-field="variant_id.attribute_id.name"/>
            </xpath>
            <xpath expr="//t/ul[@class='list-inline']/li/label" position="replace">
                <label t-attf-class="css_attribute_color #{'active' if not inc else ''}">
                    <input type="radio" class="js_variant_change"
                      t-att-checked="'checked' if not inc else ''"
                      t-att-name="'attribute-%s-%s' % (product.id, variant_id.attribute_id.id)"
                      t-att-value="value_id.id"
                      t-att-title="value_id.name"/>
                    <img t-att-src="value_id.product_attribute_value_id.isometric_small and ('data:image/png;base64,' + to_text(value_id.product_attribute_value_id.isometric_small)) or '/web/static/src/img/placeholder.png'" style="max-height: 42px;"/>
                    <!--t t-if="value_id.isometric_small">
                        <img t-att-src="'data:image/png;base64,%s' % value_id.isometric_small" style="max-height: 42px;"/>
                    </t>
                    <t t-if="not value_id.isometric_small">
                    	<img t-att-src="/web/static/src/img/placeholder.png"/>
                    </t-->
                </label>
            </xpath>
        </template>
    </data>
</odoo>
