<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='l10n_mx_supplier_taxes_statement_form'>
            <field name='name'>l10n.mx.supplier.taxes.statement.form</field>
            <field name='model'>l10n.mx.supplier.taxes.statement</field>
            <field name='arch' type='xml'>
                <form string='Download taxes data'>
                    <group>
                        <field name='date_from'/>
                        <field name='date_to'/>
                        <field name='tax_id'/>
                        <field name='company_id' invisible="1"/>
                    </group>
                    <footer>
                        <button string="Download" name="do_the_job" type="object" default_focus="1" class="btn-primary"/>
                        or
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_l10n_mx_supplier_taxes_statement" model="ir.actions.act_window">
            <field name="name">Download taxes data</field>
            <field name="res_model">l10n.mx.supplier.taxes.statement</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="l10n_mx_supplier_taxes_statement_form"/>
            <field name="context">{}</field>
            <field name="target">new</field>
        </record>
    
        <menuitem id="menu_l10n_mx_supplier_taxes_statement" name="Download taxes data" action="action_l10n_mx_supplier_taxes_statement" parent="account.menu_finance_entries" sequence="200"/>
    </data>
</odoo>
