<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_res_company_form_inh_payslip_l10n_mx">
        <field name="name">view.res.company.form.inh.payslip.l10n_mx</field>
        <field name="inherit_id" ref="l10n_mx_base.view_res_company_form_l10n_mx_base"/>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='mexico']" position="inside">
                <group>
                    <group string="Payslip">
                        <field name="company_registry"/>
                        <field name="l10n_mx_edi_curp"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
