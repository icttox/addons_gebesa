<?xml version="1.0" ?>
<odoo noupdate="1">

    <record id="payroll_mx_manager" model="res.users" context="{'no_reset_password': True}">
        <field name="name">Manager Electronic Payroll MX</field>
        <field name="login">payroll_mx_manager</field>
        <field name="password">1234</field>
        <field name="email">payroll_mx_manager@yourcompany.com</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
        <field name="tz">America/Mexico_City</field>
        <field name="groups_id" eval="[(6,0,[ref('base.group_user'),
            ref('base.group_partner_manager'),
            ref('l10n_mx_base.group_l10n_mx_base_manager'),
            ref('hr_payroll.group_hr_payroll_manager'),
            ref('base.group_erp_manager'),
            ref('account.group_account_invoice')])]"/>
    </record>

    <record id="payroll_mx_user" model="res.users" context="{'no_reset_password': True}">
        <field name="name">User Electronic Payroll MX</field>
        <field name="login">payroll_mx_user</field>
        <field name="password">1234</field>
        <field name="email">facturae_mx_user@yourcompany.com</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
        <field name="tz">America/Mexico_City</field>
        <field name="groups_id" eval="[(6,0,[ref('base.group_partner_manager'),
            ref('l10n_mx_base.group_l10n_mx_base_user'),
            ref('hr_payroll.group_hr_payroll_user'),
            ref('base.group_erp_manager')])]"/>
    </record>

</odoo>
