<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="assets_specific" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="mrp_shipment/static/src/css/mrp_shipment.css"/>
            </xpath>
        </template>

        <template id="report_shipment_layout">
            <t t-if="not o" t-set="o" t-value="doc"/>
            <t t-if="not company">
                <!-- Multicompany -->
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id"/>
                </t>
                <t t-elif="o and 'company_id' in o">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company"/>
                </t>
            </t>
            <div class="header" style="font-size: 10pt;">
                <div class="row">
                    <div class="col-3 border">
                        <img t-if="company_logo" t-att-src="image_data_uri(company_logo)" class="ml-3" style="z-index: 50; max-width: 180px; max-height: 120px;margin-top: -30px"/>
                    </div>
                    <div class="col-9">
                        <div class="row">
                            <div class="col-9 border">
                                <strong>Titulo del Documento</strong>
                                <br/>Lista de Embarques
                            </div>
                            <div class="col-3 border">
                                <strong>Revision: 0</strong>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-9">
                                <div class="row">
                                    <div class="col-6 border">
                                        <strong>Codigo del documento</strong><br/>F-LOG-01
                                    </div>
                                    <div class="col-6 border">
                                        <strong>Deriva de: P-LOG-01</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3 border">
                                <strong>Fecha de Revision</strong><br/>27/07/2021
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="article o_report_layout_standard">
                <t t-raw="0" />
            </div>
            <div class="footer o_standard_footer" style="font-size: 10pt;">
                <div class="text-right mt-4">
                    <div t-if="report_type == 'pdf'" class="text-muted">
                        <span class="page"/> / <span class="topage"/>
                    </div>
                </div>
            </div>
        </template>

        <report
            id="shipment_report"
            model="mrp.shipment"
            string="Lista de embarques"
            report_type="qweb-pdf"
            name="mrp_shipment.report_shipment"
            file="mrp_shipment.report_shipment"
        />

        <record id="mrp_shipment.shipment_report" model="ir.actions.report">
            <field name="paperformat_id" ref="flete_gebesa.paperformat_informe_gastos" />
        </record>

        <template id="report_shipment_document">
            <t t-call="mrp_shipment.report_shipment_layout">
                <div class="page" style="font-size: 10pt;">
                    <t t-foreach="shipment[doc.id]" t-as="partner">
                        <div class="row">
                            <div class="col-12 mt-2" style="border: 1px solid black">
                                <t t-set="total_m" t-value="0"/>
                                <t t-set="total_fle" t-value="0"/>
                                <t t-set="total_imp" t-value="0"/>
                                <t t-set="m" t-value="0"/>
                                <t t-set="n" t-value="1"/>
                                <table class="mrp_shipment_table">
                                    <tr>
                                        <td width="10%">Folio:</td>
                                        <th width="1%">&#160;</th>
                                        <td width="15%"><span t-esc="doc.folio"/></td>
                                        <th width="1%">&#160;</th>
                                        <td width="10%">Desc:</td>
                                        <th width="1%">&#160;</th>
                                        <td><span t-esc="doc.reference"/></td>
                                        <th width="1%">&#160;</th>
                                        <td width="10%">Fecha:</td>
                                        <th width="1%">&#160;</th>
                                        <td width="15%"><span t-esc="doc.date"/></td>
                                    </tr>
                                    <t t-foreach="shipment1[doc.id]" t-as="family">
                                        <t t-set="m" t-value="0"/>
                                        <t t-foreach="shipment1[doc.id][family]" t-as="line">
                                            <!--<t t-foreach="shipment1[doc.id][family][partner2]" t-as="city">
                                                <t t-foreach="shipment1[doc.id][family][partner2][city]" t-as="line">-->
                                                    <t t-set="m" t-value="m+(line.product_id.volume*line.quantity_shipped)"/>
                                                    <t t-set="total_fle" t-value="total_fle+((line.order_line_id.freight_amount/line.order_line_id.product_uom_qty)*line.quantity_shipped)"/>
                                                    <t t-set="total_imp" t-value="total_imp+((line.order_line_id.net_sale/line.order_line_id.product_uom_qty)*line.quantity_shipped)"/>
                                                <!--</t>
                                            </t>-->
                                        </t>
                                        <td>MTS&#160;<span t-esc="family"/></td>
                                        <th>&#160;</th>
                                        <td><span t-esc="m"/></td>
                                        <t t-if="n!=3">
                                            <th>&#160;</th>
                                        </t>
                                        <t t-set="total_m" t-value="total_m+m"/>
                                        <t t-set="n" t-value="n+1"/>
                                        <t t-if="n==4">
                                            <tr></tr>
                                            <t t-set="n" t-value="1"/>
                                        </t>
                                    </t>
                                    <tr>
                                        <td>Mts Tot:</td>
                                        <th>&#160;</th>
                                        <td><span t-esc="total_m"/></td>
                                        <th>&#160;</th>
                                        <td>Tot Fle:</td>
                                        <th>&#160;</th>
                                        <td>$&#160;<span t-esc="total_fle"/></td>
                                        <th>&#160;</th>
                                        <td>Tot Impor:</td>
                                        <th>&#160;</th>
                                        <td>$&#160;<span t-esc="total_imp"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                Estatus:&#160;&#160;<span t-esc="doc.state"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12" style="margin-top: 15px;">
                                <div style="text-align:center;font-size:20pt">
                                    ///&#160;<span t-esc="partner"/>&#160;\\\
                                </div>
                                <t t-foreach="shipment[doc.id][partner]" t-as="so">
                                    <div style="text-align:center;margin-top:10px">
                                        <div style="text-align:center;font-size:14pt">
                                            <span t-esc="so"/>
                                        </div>
                                        <!--<span t-esc="so"/>
                                        <br />-->
                                        <t t-foreach="shipment[doc.id][partner][so]" t-as="city">
                                            <div aling="center" style="text-align:center;margin-top:5px">
                                                <div style="text-align:center;font-size:8pt">
                                                    <span t-esc="city"/>
                                                </div>
                                                <br/>
                                                <!--<span t-esc="city"/>-->
                                                <t t-set="familia" t-value="''"/>
                                                <t t-set="mts" t-value="0"/>
                                                <t t-set="peso" t-value="0"/>
                                                <t t-set="flete" t-value="0"/>
                                                <t t-set="importe" t-value="0"/>
                                                <t t-foreach="shipment[doc.id][partner][so][city]" t-as="line">
                                                    <t t-set="line" t-value="line.with_context({'lang':'es_MX'})"/>
                                                    <t t-if="line.product_id.family_id.name not in familia">
                                                        <t t-set="familia" t-value="familia+line.product_id.family_id.name+','"/>
                                                    </t>
                                                    <t t-set="mts" t-value="mts+(line.product_id.volume*line.quantity_shipped)"/>
                                                    <t t-set="peso" t-value="peso+(line.product_id.weight*line.quantity_shipped)"/>
                                                    <t t-set="flete" t-value="flete+((line.order_line_id.freight_amount/line.order_line_id.product_uom_qty)*line.quantity_shipped)"/>
                                                    <t t-set="importe" t-value="importe+((line.order_line_id.net_sale/line.order_line_id.product_uom_qty)*line.quantity_shipped)"/>
                                                </t>
                                                <table width="100%">
                                                    <tr>
                                                        <td width="8%">Familia:</td>
                                                        <td width="12%"><span t-esc="familia"/></td>
                                                        <td width="8%">Mts:</td>
                                                        <td width="12%"><span t-esc="mts"/></td>
                                                        <td width="8%">Peso:</td>
                                                        <td width="12%"><span t-esc="peso"/></td>
                                                        <td width="8%">Flete:</td>
                                                        <td width="12%">$&#160;<span t-esc="flete"/></td>
                                                        <td width="8%">Importe:</td>
                                                        <td width="10%">$&#160;<span t-esc="importe"/></td>
                                                    </tr>
                                                </table>
                                                <br />
                                                <table  id="table_detail" width="100%" class="mrp_shipment_table_detail">
                                                    <tr>
                                                        <td width="21%">Producto(En)</td>
                                                        <td width="14%">Clave</td>
                                                        <td width="15%">Tag Line</td>
                                                        <td width="25%">Articulo</td>
                                                        <td width="9%">Pedido</td>
                                                        <td width="8%">Embarca</td>
                                                        <td width="8%">Cantidad</td>
                                                    </tr>
                                                    <t t-foreach="sorted(shipment[doc.id][partner][so][city], key=lambda kv: kv.product_id.with_context({'lang':'en_US'}).name)" t-as="line">
                                                        <t t-set="line" t-value="line.with_context({'lang':'es_MX'})"/>
                                                        <t t-if="line.product_id.id not in kit.keys()">
                                                            <tr t-att-style="'background: #FF3535;' if line.sale_order_id.priority == 'replenishment' else 'background: #F1F812' if line.sale_order_id.priority == 'sample' else ''">
                                                                <td align="center" style="font-size: 9pt;font-family: CCode39;vertical-align:middle;">
                                                                    <!--<img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', line.product_id.barcode, 600, 100)" style="width:95%;height:50px;padding-top:5px;margin-bottom:4px"/>-->
                                                                    <!--span t-esc="line.sale_order_id.client_order_ref"/-->
                                                                    <t t-set="product_en" t-value="line.product_id.with_context({'lang':'en_US'})"/>
                                                                    <t t-if="product_en.individual_name">
                                                                        <span t-esc="product_en.individual_name"/>
                                                                    </t>
                                                                    <t t-if="not product_en.individual_name">
                                                                        <span t-esc="product_en.product_tmpl_id.name"/>
                                                                    </t>
                                                                </td>
                                                                <td><span t-esc="line.product_id.default_code"/></td>
                                                                <td><span t-esc="line.order_line_id.line_tag_number"/></td>
                                                                <td>
                                                                    <t t-if="line.product_id.individual_name">
                                                                        <span t-esc="line.product_id.individual_name"/>
                                                                    </t>
                                                                    <t t-if="not line.product_id.individual_name">
                                                                        <span t-esc="line.product_id.product_tmpl_id.name"/>
                                                                    </t>
                                                                </td>
                                                                <td><span t-esc="line.sale_order_id.name"/></td>
                                                                <td><span t-esc="line.product_id.family_id.name"/></td>
                                                                <td><span t-esc="line.quantity_shipped"/></td>
                                                            </tr>
                                                        </t>
                                                        <t t-if="line.product_id.id in kit.keys()">
                                                            <tr t-att-style="'background: #FF6868;' if line.sale_order_id.priority == 'replenishment' else 'background: #E0E700;' if line.sale_order_id.priority == 'sample' else 'background: lightgray;'">
                                                                <td align="center" style="font-size: 9pt;font-family: CCode39;">
                                                                    <!--<img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', line.product_id.barcode, 600, 100)" style="width:99%;height:50px;padding-top:5px;margin-bottom:4px"/>-->
                                                                    <!--span t-esc="line.sale_order_id.client_order_ref"/-->
                                                                    <t t-set="product_en" t-value="line.product_id.with_context({'lang':'en_US'})"/>
                                                                    <t t-if="product_en.individual_name">
                                                                        <span t-esc="product_en.individual_name"/>
                                                                    </t>
                                                                    <t t-if="not product_en.individual_name">
                                                                        <span t-esc="product_en.product_tmpl_id.name"/>
                                                                    </t>
                                                                </td>
                                                                <td><span t-esc="line.product_id.default_code"/></td>
                                                                <td><span t-esc="line.order_line_id.line_tag_number"/></td>
                                                                <td>
                                                                    <t t-if="line.product_id.individual_name">
                                                                        <span t-esc="line.product_id.individual_name"/>
                                                                    </t>
                                                                    <t t-if="not line.product_id.individual_name">
                                                                        <span t-esc="line.product_id.product_tmpl_id.name"/>
                                                                    </t>
                                                                </td>
                                                                <td><span t-esc="line.sale_order_id.name"/></td>
                                                                <td><span t-esc="line.product_id.family_id.name"/></td>
                                                                <td><span t-esc="line.quantity_shipped"/></td>
                                                            </tr>
                                                            <t t-foreach="kit[line.product_id.id]" t-as="bom_line">
                                                                <!--t t-set="bom_line" t-value="bom_line.with_context({'lang':'es_MX'})"/-->
                                                                <t t-set="bom_line_qty" t-value="line.quantity_shipped * bom_line[3]"/>
                                                                <tr t-att-style="'background: #FD8D8D;' if line.sale_order_id.manufacture == 'replenishment' else 'background: #FAFF5B;' if line.sale_order_id.priority == 'sample' else 'background: #F2F2F2;'">
                                                                    <td align="center" style="font-size: 9pt;font-family: CCode39;">
                                                                        <!--<img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', bom_line.product_id.barcode, 600, 100)" style="width:99%;height:50px;padding-top:5px;margin-bottom:4px"/>-->
                                                                        <span t-esc="bom_line[5]"/>
                                                                    </td>
                                                                    <td><span t-esc="bom_line[1]"/></td>
                                                                    <td><span t-esc="line.order_line_id.line_tag_number"/></td>
                                                                    <td>
                                                                        <span t-esc="bom_line[2]"/>
                                                                        <!--t t-if="bom_line.product_id.individual_name">
                                                                            <span t-esc="bom_line.product_id.individual_name"/>
                                                                        </t>
                                                                        <t t-if="not bom_line.product_id.individual_name">
                                                                            <span t-esc="bom_line.product_id.product_tmpl_id.name"/>
                                                                        </t-->
                                                                    </td>
                                                                    <td><span t-esc="line.sale_order_id.name"/></td>
                                                                    <td><span t-esc="bom_line[4]"/></td>
                                                                    <td><span t-esc="bom_line_qty"/></td>
                                                                </tr>
                                                            </t>
                                                        </t>
                                                    </t>
                                                </table>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div style="page-break-after: always;">&#160;</div>
                    </t>
                </div>
            </t>
        </template>

        <template id="report_shipment">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="mrp_shipment.report_shipment_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>