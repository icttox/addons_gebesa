<?xml version="1.0" encoding="UTF-8"?>
<!--Nodo requerido-->
<odoo>
    <data>
        <record model='ir.ui.view' id='pivot_backorder_tree'>
        	<field name='name'>pivot.backorder.tree</field>
        	<field name='model'>sale.order</field>
        	<field name='arch' type='xml'>
        		<tree string='Sale'>   
                    <field name='name' string='Pedido de Venta'/>
        			<field name='date_order' string='Fecha de Pedido' interval="week"/>
                    <field name='analytic_account_id' string='Cuenta Analítica'/>
                    <field name="o_amount_pending_rate_mex"/>
                    <field name='o_total_net_sale' string='Vta Neta Total'/>
                    <field name='state'/>                               
        		</tree>
        	</field>
            <!--Cierre de Registro-->
        </record>

        <record id="pivot_backorder_pivot" model="ir.ui.view">
            <field name="name">pivot.backorder.pivot</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <pivot string="Sale Orders">
                    <field name="warehouse_id" type="row"/>
                    <field name="analytic_account_id" type="row"/>
                    <!--field name='date_order' type="col" interval="week"/-->
                    <field name='week_number' type="col"/>
                    <field name="o_amount_pending_rate_mex" type="measure"/> 
                </pivot>
            </field>
        </record>

        <record model="ir.ui.view" id="pivot_backorder_graph">
            <field name="name">pivot.backorder.graph</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <graph string="Sales Orders">
                    <field name="partner_id"/>
                    <field name="amount_total" type="measure"/>
                </graph>
            </field>
        </record>

        <record id='action_pivot_backorder' model='ir.actions.act_window'>
            <field name='name'>Pivot Backorder</field>
            <field name='res_model'>sale.order</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>pivot,tree</field>
            <field name="view_id" ref="pivot_backorder_pivot"/>
            <field name="domain">[('geb_invoice_status', 'in', ['no_invoice','partial_invoice']),('state', 'in', ['done', 'sale'])]</field>
        </record>
        <menuitem id="pivot_backorderl_menu" parent="sale.menu_sale_report" name="Pivot Backorder" action="action_pivot_backorder"/>
    </data>
</odoo>