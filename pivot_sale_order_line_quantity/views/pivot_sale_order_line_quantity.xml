<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_line_quantity_pivot" model="ir.ui.view">
            <field name="name">sale.order.line.quantity.pivot</field>
            <field name="model">sale.order.line.quantity</field>
            <field name="arch" type="xml">
                <pivot string="Sale Orders Quantity">
                    <field name="code" type="row" string="Product"/>
                    <field name='week' type="col" interval="week"/>
                    <field name="quantity" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="sale_order_line_quantity_tree" model="ir.ui.view">
            <field name="name">sale.order.line.quantity.tree</field>
            <field name="model">sale.order.line.quantity</field>
            <field name="arch" type="xml">
                <tree string="Sale Orders Quantity">
                    <field name="order"/>
                    <field name="fecha_order"/>
                    <field name="code"/>
                    <field name='week' interval="week"/>
                    <field name="quantity"/>
                </tree>
            </field>
        </record>

        <record id='action_quantity_order_line' model='ir.actions.act_window'>
            <field name='name'>Sales For Quantity</field>
            <field name='res_model'>sale.order.line.quantity</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>pivot,tree</field>
            <field name="view_id" ref="sale_order_line_quantity_pivot"/>
        </record>
        <menuitem id="menu_quantity_order_line" parent="sale.menu_sale_report" name="Sales For Quantity" action="action_quantity_order_line"/>
    </data>
</odoo>
