<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_incidents_form" model="ir.ui.view">
            <field name="name">sale.order.incidents.form</field>
            <field name="model">sale.order.incidents</field>
            <field name="arch" type="xml">
                <form string="Incidents">
                    <group>
                        <group colspan="6">
                            <field name="date_incident"/>
                            <field name="sale_order_id"/>
                            <field name="order_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="amount"/>
                            <field name="warehouse_id"/>
                            <field name="departament_id" domain="[('show_incidents','=',True)]"/>
                            <field name="replacement_id" domain="[('workcenter_ids','=', False)]"/>
                            <field name="description"/>
                            <field name="product_uom_qty" invisible="1"/>
                            <field name="net_sale" invisible="1"/>
                            <field name="net_sale_mx" readonly="1"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Create incidents" name="send_incidence" type="object"/>
                        Or
                        <button string="Cancel" special="cancel" type="object"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_sale_order_incidents" model="ir.actions.act_window">
            <field name="name">Incidents</field>
            <field name="res_model">sale.order.incidents</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>