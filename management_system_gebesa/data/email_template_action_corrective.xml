<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="email_corrective_actions_notification" model="mail.template">
            <field name="name">Corrective actions notification</field>
            <field name="email_from">${(object.sudo().create_uid.email and '%s &lt;%s&gt;' % (object.sudo().create_uid.name, object.sudo().create_uid.email) or '')|safe}</field>
            <field name="subject">New Corrective Action (Folio ${object.folio or 'n/a'}), Motivo: ${object.motive or 'n/a'}</field>
            <field name="email_to">${object.responsible_id.work_email}</field>
            <field name="model_id" ref="management_system_gebesa.model_quality_corrective_action"/>
            <field name="auto_delete" eval="True"/>
            <field name="att_default" eval="True"/>
            <field name="body_html"><![CDATA[
<div style="font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
    <p>Corrective action notification</p>
    <p>Hello good morning</p>
    <p>Verify corrective action data is correct</p>
    <p>Attach evidence and close the corrective action</p>
    <p>You have a good day</p>
    <p>Regards</p>

    <p style="border-left: 1px solid #8e0000; margin-left: 30px;">
       &nbsp;&nbsp;<strong>CORRECTIVE ACTION DATA</strong><br/>
       &nbsp;&nbsp;Data: <strong>${object.date}</strong><br/>
       &nbsp;&nbsp;Folio: <strong>${object.folio}</strong><br/>
       &nbsp;&nbsp;Motive: <strong>${object.motive}</strong><br/>
       &nbsp;&nbsp;Departament: <strong>${object.departament_id.name}</strong><br/>
       &nbsp;&nbsp;Company: <strong>${object.company_id.name}</strong><br/>
       &nbsp;&nbsp;Responsible: <strong>${object.responsible_id.name}</strong><br/>
    </p>
    <p>Corrective action<a href="http://erp.portalgebesa.com/web?debug=true#id=${object.id}&model=quality.corrective.action&view_type=form&menu_id=1753"> Link</a></p> 
</div>]]></field>
        </record>
    </data>
</odoo>