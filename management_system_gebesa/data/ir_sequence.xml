<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="corrective_action_sequence" model="ir.sequence">
            <field name="name">Management system</field>
            <field name="code">quality.corrective.action</field>
            <field name="prefix">%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>            
            <field name="company_id" eval="False"/>
            <field name="padding">4</field>
        </record>

        <record id="corrective_action_sequences" model="ir.sequence">
            <field name="name">Management system change</field>
            <field name="code">quality.change.management</field>
            <field name="prefix">%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>            
            <field name="company_id" eval="False"/>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
