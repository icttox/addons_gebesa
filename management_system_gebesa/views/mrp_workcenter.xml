<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="mrp_workcenter_daily_inspection_form" model="ir.ui.view">
            <field name="name">mrp.workcenter.daily.inspection.form</field>
            <field name="model">mrp.workcenter</field>
            <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Reports">
                        <group>
                            <field name="daily_inspection_header"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>