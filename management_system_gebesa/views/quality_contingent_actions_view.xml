<odoo>
  <data>
    <record model="ir.ui.view" id="quality_contingent_actions_tree">
      <field name="name">quality.contingent.actions.tree</field>
      <field name="model">quality.contingent.actions</field>
      <field name="arch" type="xml">
        <tree>
          <field name="description"/>
          <field name="responsible_id"/>
          <field name="date_commitment"/>
          <field name="date_close"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="quality_contingent_actions_form">
      <field name="name">quality.contingent.actions.form</field>
      <field name="model">quality.contingent.actions</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="description"/>
              <field name="responsible_id"/>
              <field name="company_id" readonly="True"/>
              <field name="date_commitment"/>
              <field name="date_close"/>
            </group>
          </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
            </div> 
        </form>
      </field>
    </record>
    
    <record model="ir.actions.act_window" id="quality_contingent_actions_action">
      <field name="name">Contingent actions</field>
      <field name="res_model">quality.contingent.actions</field>
      <field name="view_mode">tree,form</field>
    </record>
    
  </data>
</odoo>