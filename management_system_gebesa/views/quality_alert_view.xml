<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="quality_alert_view_gebesa_form" model="ir.ui.view">
            <field name="name">quality.alert.view.gebesa.form</field>
            <field name="model">quality.alert</field>
            <field name="inherit_id" ref="quality_control.quality_alert_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='title']" position="after">
                    <field name="date"/>
                    <field name="sale_id"/>
                </xpath>
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="oven"/>
                </xpath>
                <xpath expr="//field[@name='tag_ids']" position="replace">
                    <field name="color"/>
                    <field name="qty_reviewed"/>
                </xpath>
                <xpath expr="//group/group/field[@name='priority']" position="after">
                    <separator string='Rejected'/>
                    <field name="qty_rejected"/>
                    <field name="flaw_id" widget="selection" domain="[('workcenter_ids', 'in', workcenter_id)]"/>
                    <field name="provision"/>
                </xpath>
            </field>
        </record>

        <record id="quality_alert_view_gebesa_tree" model="ir.ui.view">
            <field name="name">quality.alert.view.gebesa.tree</field>
            <field name="model">quality.alert</field>
            <field name="inherit_id" ref="quality_control.quality_alert_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='check_id']" position="after">
                    <field name="date"/>
                    <field name="sale_id"/>
                    <field name="product_id"/>
                    <field name="qty_reviewed"/>
                    <field name="qty_rejected"/>
                    <field name="flaw_id"/>
                    <field name="oven"/>
                    <field name="workcenter_id"/>
                    <field name="color"/>
                    <field name="provision"/>
                </xpath>
            </field>
        </record>

        <record id="quality_alert_view_gebesa_kanban" model="ir.ui.view">
            <field name="name">quality.alert.view.gebesa.kanban</field>
            <field name="model">quality.alert</field>
            <field name="inherit_id" ref="quality_control.quality_alert_view_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='priority']" position="after">
                    <field name="date"/>
                    <field name="sale_id"/>
                    <field name="flaw_id"/>
                </xpath>
                <xpath expr="//kanban/templates/t/div/div[2]" position="after">
                    <div>
                        <field name="date"/>
                        <field name="sale_id"/>
                        (<field name="flaw_id"/>)
                    </div>
                </xpath>
            </field>
        </record>

        <record id="quality_alert_view_gebesa_search" model="ir.ui.view">
            <field name="name">quality.alert.view.gebesa.search</field>
            <field name="model">quality.alert</field>
            <field name="inherit_id" ref="quality_control.quality_alert_view_search"/>
            <field name="arch" type="xml">
                <field name="tag_ids" position="after">
                    <field name="sale_id"/>
                </field>
            </field>
        </record>
    </data>
</odoo>