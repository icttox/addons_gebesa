#. module: management_system_gebesa
#: model:mail.template,body_html:management_system_gebesa.email_corrective_actions_notification
msgid ""
"\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"    <p>Corrective action notification</p>\n"
"    <p>Hello good morning</p>\n"
"    <p>Verify corrective action data is correct</p>\n"
"    <p>Attach evidence and close the corrective action</p>\n"
"    <p>You have a good day</p>\n"
"    <p>Regards</p>\n"
"\n"
"    <p style=\"border-left: 1px solid #8e0000; margin-left: 30px;\">\n"
"       &nbsp;&nbsp;<strong>CORRECTIVE ACTION DATA</strong><br/>\n"
"       &nbsp;&nbsp;Data: <strong>${object.date}</strong><br/>\n"
"       &nbsp;&nbsp;Folio: <strong>${object.folio}</strong><br/>\n"
"       &nbsp;&nbsp;Motive: <strong>${object.motive}</strong><br/>\n"
"       &nbsp;&nbsp;Departament: <strong>${object.departament_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Company: <strong>${object.company_id.name}</strong><br/>\n"
"       &nbsp;&nbsp;Responsible: <strong>${object.responsible_id.name}</strong><br/>\n"
"    </p>\n"
"    <p>Corrective action<a href=\"http://erp.portalgebesa.com/web?debug=true#id=${object.id}&model=quality.corrective.action&view_type=form&menu_id=1753\"> Link</a></p> \n"
"</div>"
msgstr ""
"\n"
"<div style=\"font-size:13px;font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"    <p style=\"margin:0px 0 1rem 0;font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;\">Notificación de acción correctiva<br><br>Hola buenos dias<br><br>Verifique que los datos de la acción correctiva sean correctos<br><br>Adjuntar evidencias y cerrar la acción correctiva<br><br>Saludos</p>\n"
"\n"
"    <p style=\"margin:0px 0 1rem 0;font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;border-left: 1px solid #8e0000; margin-left: 30px;\">\n"
"       &nbsp;&nbsp;<strong style=\"font-weight:bolder;\">CORRECTIVE ACTION DATA</strong><br>\n"
"       &nbsp;&nbsp;Data: <strong style=\"font-weight:bolder;\">${object.date}</strong><br>\n"
"       &nbsp;&nbsp;Folio: <strong style=\"font-weight:bolder;\">${object.folio}</strong><br>\n"
"       &nbsp;&nbsp;Motive: <strong style=\"font-weight:bolder;\">${object.motive}</strong><br>\n"
"       &nbsp;&nbsp;Departament: <strong style=\"font-weight:bolder;\">${object.departament_id.name}</strong><br>\n"
"       &nbsp;&nbsp;Company: <strong style=\"font-weight:bolder;\">${object.company_id.name}</strong><br>\n"
"       &nbsp;&nbsp;Responsible: <strong style=\"font-weight:bolder;\">${object.responsible_id.name}</strong><br>\n"
"    </p>\n"
"    <p style=\"margin:0px 0 1rem 0;font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;\">Corrective action<a href=\"http://erp.portalgebesa.com/web?debug=true#id=${object.id}&amp;model=quality.corrective.action&amp;view_type=form&amp;menu_id=1753\" style=\"text-decoration:none;background-color:transparent;color:rgb(0, 135, 132);\"> Link</a></p> \n"
"</div>"

