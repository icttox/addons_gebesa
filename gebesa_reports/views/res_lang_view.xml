<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="res_lang_inherit_form" model="ir.ui.view">
            <field name="name">res_lang_inherit_form</field>
            <field name="model">res.lang</field>
            <field name="inherit_id" ref="base.res_lang_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tr_sequence']" position="after">
                    <field name="date_format_pentaho"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
