<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='purchase_order_business_partner_form'>
            <field name='name'>purchase.order.business.partner.form</field>
            <field name='model'>purchase.order</field>
            <field name='inherit_id' ref="purchase.purchase_order_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//sheet/group/group/field[@name='partner_id']" position="after">
                    <field name="businness_partner_ids" widget="many2many_tags" readonly="True" invisible="True"/>
                    <field name="has_businness_partner" invisible="True"/>
                    <field name="businness_partner_id" domain="[('id', 'in', businness_partner_ids)]" attrs="{'required': [('has_businness_partner', '=', True)]}"/>
                </xpath>
                <xpath expr="//sheet/notebook/page/field[@name='order_line']/tree/field[@name='price_subtotal']" position="after">
                    <button name="update_price_po_so" states="purchase,done" string="Update Price" type="object" icon="fa-edit" groups="multicompany_gebesa.update_price_po"/>
                </xpath>
                <xpath expr="//button[@name='button_unlock']" position="attributes">
                    <attribute name="groups">system_administrator.group_system_administrator_gebesa</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
