<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_partner_salesrep_form'>
            <field name='name'>view.partner.salesrep.form</field>
            <field name='model'>res.partner</field>
            <field name='inherit_id' ref="base.view_partner_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//sheet/group/group/field[@name='vat']" position="after">
                    <field name="salesrep_id" invisible="1"/>
                    <field name="salesrep_ids" widget="many2many_tags"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>