<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='sale_salesrep_tree'>
            <field name='name'>sale.salesrep.tree</field>
            <field name='model'>sale.salesrep</field>
            <field name='arch' type='xml'>
                <tree string='Sales REP'>
                    <field name='name'/>
                    <field name='team_id'/>
                    <field name='salesrep_type'/>
                </tree>
            </field>
        </record>

        <record model='ir.ui.view' id='sale_salesrep_form'>
            <field name='name'>sale.salesrep.form</field>
            <field name='model'>sale.salesrep</field>
            <field name='arch' type='xml'>
                <form string='Sales REP'>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name='name'/>
                            </h1>
                        </div>
                        <group>
                            <field name="team_id"/>
                            <field name="salesrep_type"/>
                        </group>
                        <notebook>
                            <page string="Commissions" name="commissions">
                                <field name="Commission_ids">
                                    <tree string="Commissions" editable="bottom">
                                        <field name='start_date'/>
                                        <field name='end_date'/>
                                        <field name='commission'/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Vendedores" name="vendedores">
                                <group>
                                    <field name="salesrep_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <record id='action_sale_salesrep' model='ir.actions.act_window'>
            <field name='name'>Sales REP</field>
            <field name='res_model'>sale.salesrep</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>tree,form</field>
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to start a Sales REP.
              </p>
            </field>
        </record>

        <menuitem id="menu_sale_salesrep"
            name="Sales REP"
            parent="sale.product_menu_catalog"
            action="action_sale_salesrep"/>
    </data>
</odoo>