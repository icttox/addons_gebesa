<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_multicompany_gebesa" model="ir.ui.view">
        <field name="name">res.config.settings.view.multicompany.gebesa.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div/div/div[@id='sales_settings_invoicing_policy']" position="after">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_right_pane">
                        <label for="warehouse_commission"/>
                        <div class="text-muted">
                            Commission percentage for warehouses 
                        </div>
                        <div class="content-group">
                            <div class="mt16">
                                <field name="warehouse_commission" class="o_light_label"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>