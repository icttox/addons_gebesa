<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="batch_product_codes_view" model="ir.ui.view">
        <field name="name">Match product cost with their BoM by Codes</field>
        <field name="model">batch.product.bom.codes</field>
        <field name="arch" type="xml">
            <form string="Products Codes">
                <separator string="Products for match cost"/>
                <label for="pp_codes" string="Enter the codes of the products you want to match their cost."/>
                    <field name="pp_codes"/>
                <footer>
                    <button class="oe_highlight" default_focus="1" name="action_match_cost_all" string="Match costs" type="object"/>
                    
                    <button class="oe_link" special="cancel" string="Cancel"/></footer>
            </form>
        </field>
    </record>
    <record id="action_batch_product_codes_view" model="ir.actions.act_window">
        <field name="name">Match product cost with their BoM by Codes</field>
        <field name="res_model">batch.product.bom.codes</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="batch_product_codes_view"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem action="action_batch_product_codes_view" id="menu_match_product_cost_bom_batch" name="Match product cost with their BoM by Codes" parent="stock_move_batch_validator.inventory_special_process"/>
</odoo>