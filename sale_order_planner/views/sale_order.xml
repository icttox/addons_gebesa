<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_order_form" model="ir.ui.view">
            <field name="name">view_order_import_planner_form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_done']" position="after">
                    <button icon="fa-file-text" name="%(action_sale_order_import_planner)d" string="Import Planner" type="action"/>
                </xpath>
                <xpath expr="/form/sheet/notebook/page/field[@name='order_line']/tree/field[@name='name']" position="after">
                    <field name="options" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="attributes">
                    <attribute name="attrs">{'invisible': [('state', 'in', ['draft', 'sent', 'sale', 'done', 'cancel'])]}</attribute>
                </xpath>
            </field>
        </record>

        <record id="action_split_sales_order_server" model="ir.actions.server">
            <field name="name">Split Sales Order</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">
                action = records.split_sales_order()
            </field>
        </record>
    </data>
</odoo>