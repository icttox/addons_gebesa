<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_import_planner_form" model="ir.ui.view">
            <field name="name">sale.order.import.planner.form</field>
            <field name="model">sale.order.import.planner</field>
            <field name="arch" type="xml">
                <form string="Import Planner File">
                    <field name="planner_xml" required="True"/>
                    <footer>
                    	<button icon="gtk-ok" name="import_planner" string="Import" type="object"/>
                    	Or
                        <button icon="gtk-cancel" special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_sale_order_import_planner" model="ir.actions.act_window">
            <field name="name">Attach Planner</field>
            <field name="res_model">sale.order.import.planner</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="sale_order_import_planner_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>