<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="kpi_payroll_family_wizard_form">
        <field name="name">kpi.payroll.family.wizard.form</field>
        <field name="model">kpi.payroll.family.wizard</field>
        <field name="arch" type="xml">
            <form string="Payroll Cost">
                <group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date" />
                        <field name="account_ids" widget="many2many_tags">
                          <tree>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="user_type_id"/>
                          </tree>
                        </field>
                    </group>
                    <group>
                        <field name="lines_ids">
                        	<tree>
                        		<field name="family_id"/>
	                            <field name="analytic_id"/>
	                            <field name="amount"/>
	                            <field name="invoced_percent"/>
	                            <field name="payroll_analityc_ids"/>
	                            <field name="payroll_amount"/>
                        	</tree>
                        </field>
                    </group>
                </group>
                <footer>
                    <button
                    name="action_get_data_from_db"
                    string="Submit"
                    type="object"
                    class="oe_highlight"
                />
                    or
                    <button special="cancel" string="Cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="kpi_payroll_family_wizard_action" model="ir.actions.act_window">
        <field name="name">Payroll Cost</field>
        <field name="res_model">kpi.payroll.family.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!--menuitem id="menu_kpi_payroll_family_wizard" name="Payroll Cost" action="kpi_payroll_family_wizard_action" parent="account.menu_finance_entries" sequence="200"/-->
</odoo>
