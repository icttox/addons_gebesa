<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="movements_generated_line_item"
            model="sale.order.line"
            string="movements generated by line item"
            report_type="qweb-pdf"
            name="order_line_cancel.report_movements_generated_line_item"
            file="order_line_cancel.report_movements_generated_line_item"
        />

        <template id="report_movements_generated_line_item_document">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2>
                        Pedido: <span t-esc="doc.order_id.name"/>,
                        Linea: <span t-esc="doc.id"/>,
                        Producto: <span t-esc="doc.product_id.default_code"/>
                        Cantidad: <span t-esc="doc.product_uom_qty"/>
                    </h2>
                    <br/>
                    <div style="font-size: 10pt;">
                        <table class="table table-condensed">
                            <tr>
                                <th>Movimiento</th>
                                <th>Estatus</th>
                                <th>Ubicaciones</th>
                                <th>Producto</th>
                                <th>Picking</th>
                                <th>Ord. Frab</th>
                            </tr>
                            <t t-foreach="move_generated[doc.id]" t-as="move">
                                <tr>
                                    <td><span t-esc="move[1]"/></td>
                                    <td><span t-esc="move[2]"/></td>
                                    <td><span t-esc="move[3]"/>&#32;&#45;&#62;&#32;<span t-esc="move[4]"/></td>
                                    <td><span t-esc="move[5]"/></td>
                                    <td>
                                        <span t-esc="move[6]"/>
                                        <t t-if="move[6]">
                                            &#40;<span t-esc="move[7]"/>&#41;
                                        </t>
                                    </td>
                                    <td>
                                        <span t-esc="move[8]"/>
                                        <t t-if="move[8]">
                                            &#40;<span t-esc="move[9]"/>&#41;
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <template id="report_movements_generated_line_item">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="order_line_cancel.report_movements_generated_line_item_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>