<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="employee_credential"
            model="hr.employee"
            string="Credencial"
            report_type="qweb-pdf"
            name="website_lunch_hr.report_employee_credential"
            file="website_lunch_hr.report_employee_credential"
        />
        <record id="website_lunch_hr.employee_credential" model="ir.actions.report">
            <field name="paperformat_id" ref="website_lunch_hr.paperformat_pvc_credential" />
        </record>

        <template id="report_employee_credential_document">
            <div class="page">
                <div class="row" style="page-break-after:always;">
                    <div class="col-8">
                        <br/>
                        <div class="row text-center">
                            <div class="col-12">
                                <img t-att-src="image_data_uri(doc.image)" style="border-top-right-radius: 50%; max-width: 110px; max-height: 110px;" t-if="doc.image"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 text-center h5">
                                <span t-field="doc.name" class="font-weight-bold"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-1"/>
                            <div class="col-9" style="border-bottom: 2px solid #05B5C3 !important;"/>
                        </div>
                        <div class="row" style="font-size: 65%">
                            <div class="col-12 mt-2">
                                <span t-field="doc.department_id" class="h6"/>
                            </div>
                        </div>
                        <div class="row" style="font-size: 65%">
                            <div class="col-12 mt-2">
                                <span t-esc="'Puesto: ' + doc.job_id.name"/>
                                <br/>
                                <span t-esc="'Fecha de ingreso: ' + doc.entry_date_vacation.strftime('%d/%m/%Y')"/>
                                <br/>
                                <span t-esc="'NSS: ' + doc.imss"/>
                                <br/>
                                <span t-esc="'RFC: ' + doc.rfc"/>
                            </div>
                        </div>
                        <!-- <div class="row">
                            <div class="col-12 mt-2 text-center">
                                <img t-att-src="image_data_uri(doc.company_id.logo)" class="mt-2" t-if="doc.company_id.logo" style="max-width: 110px; max-height: 40px;"/>
                            </div>
                        </div> -->
                    </div>
                    <div class="col-4 text-center" style="height: 418px;">
                        <div class="row">
                            <div class="col-12 text-center mt-5">
                                <img src="/website_lunch_hr/static/src/img/gebesa_sf.png" width="140%" style="margin-left:-20px;"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row" style="page-break-after:always;">
                    <div class="col-12">
                        <div class="row">
                            <div class="col-12 text-center" style="height: 288px">
                                <img src="/website_lunch_hr/static/src/img/gebesa_col.png" class="mt-5" width="45%"/>
                                <br/>
                                <span t-field="doc.name" class="font-weight-bold mt-4"/>
                                <br/>
                                <t t-set="password" t-value="doc.decrypt_password_as_string(doc.id) if doc.lunch_pass else ''"/>
                                <t t-set="barcode" t-value="doc.identification_id + '-' + password"/>
                                <!-- <br/>
                                <span t-esc="'*' + barcode + '*'" style="font-family: CCode39"/>
                                <br/>-->
                                <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=%s' % ('QR', barcode.upper(), 800, 800, 0)" class="mt-2" width="40%"/>
                                <br/>
                                <span t-field="doc.consecutive_id" class="mt-1"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 text-center" style="background-color: #05B5C3; height: 130px">
                                <!-- <div class="row">
                                  <div class="col-12 text-center">
                                    <img t-att-src="image_data_uri(doc.company_id.logo)" class="mt-4" t-if="doc.company_id.logo" style="max-width: 150px; max-height: 60px;"/>
                                  </div>
                                </div> -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </template>

        <template id="report_employee_credential">
            <t t-call="web.html_container">
                <t t-call="website_lunch_hr.report_ticket_layout_empty">
                    <t t-foreach="docs" t-as="doc">
                        <t t-call="website_lunch_hr.report_employee_credential_document"/>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
