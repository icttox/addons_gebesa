<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="report_employee_barcode_xlsx"
            model="hr.employee"
            string="Codigo de barras empleado (XLSX)"
            report_type="xlsx"
            name="website_lunch_hr.report_employee_barcode_xlsx"
            file="report_employee_barcode_xlsx"
            attachment_use="False"
            groups="website_lunch_hr.group_report_lunch"
        />
        <report
            id="action_employee_lunch_password"
            model="hr.employee"
            string="Credenciales para comedor"
            report_type="qweb-pdf"
            name="website_lunch_hr.report_employee_lunch_password"
            file="website_lunch_hr.report_employee_lunch_password"
            groups="website_lunch_hr.group_report_lunch"
        />
        <record id="website_lunch_hr.action_employee_lunch_password" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag_letter_vertical" />
        </record>

        <template id="report_employee_lunch_password">
            <t t-call="web.html_container">
                <t t-call="website_lunch_hr.report_ticket_layout_empty">
                    <div class="page">
                        <t t-set="contador" t-value="1"/>
                      <t t-foreach="docs.mapped('department_id')" t-as="dep">
                            <t t-set="contador" t-value="1"/>
                            <div class="row no-gutters">
                                <div class="col-12 text-center">
                                    <strong>
                                        <h2>
                                            <t t-esc="dep.name"/>
                                        </h2>
                                    </strong>
                                </div>
                            </div>
                            <br/>
                            <div class="row no-gutters">
                            <div class="col-1 border text-center"></div>
                                <div class="col-2 border text-center"><strong>No. Empleado</strong></div>
                                <div class="col-5 border text-center"><strong>Empleado</strong></div>
                                <div class="col-2 border text-center"><strong>Identificador</strong></div>
                                <div class="col-2 border text-center"><strong>Contraseña</strong></div>
                            </div>
                            <t t-foreach="docs.filtered(lambda emp: emp.department_id.id == dep.id)" t-as="doc">
                                <div class="row no-gutters">
                                    <div class="col-1 border text-center"><t t-esc="contador"/></div>
                                    <div class="col-2 border text-center"><t t-esc="doc.consecutive_id"/></div>
                                    <div class="col-5 border"><t t-esc="doc.name"/></div>
                                    <div class="col-2 border text-center"><t t-esc="doc.identification_id"/></div>
                                    <div class="col-2 border text-center"><t t-if="doc.lunch_pass" t-esc="doc.decrypt_password_as_string(doc.id)"/></div>
                                </div>
                                <t t-set="contador" t-value="contador+1"/>
                            </t>
                            <br/><br/>
                        </t>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
    