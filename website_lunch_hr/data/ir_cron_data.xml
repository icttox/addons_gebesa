<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_lunch_to_assign" model="ir.cron">
            <field name="name">Generate salary assignments from meals</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="model_id" ref="model_lunch_order_line"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:30:00')" />
            <field name="state">code</field>
            <field name="code">model.create_salary_assignment()</field>
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>
