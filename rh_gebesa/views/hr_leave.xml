<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="hr_leave_view_gebesa_form" model="ir.ui.view">
            <field name="name">hr.leave.view.gebesa.form</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/group/div/div/field[@name='request_unit_half']" position="after">
                    <label for="for_payroll" attrs="{'readonly': [('state', 'not in', ('draft', 'confirm'))]}"/>
                    <field name="for_payroll" attrs="{'readonly': [('state', 'not in', ('draft', 'confirm'))]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>