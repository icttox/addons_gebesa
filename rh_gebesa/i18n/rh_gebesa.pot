msgid "al referirse al presente documento como “EL CONTRATO”, y a los que suscriben como “LAS PARTES”.\n"
"                        <br/><br/>\n"
"                        <strong>SEGUNDA.-</strong> Este “CONTRATO” se celebra por tiempo indeterminado según lo establece el artículo 35 de “LA LEY”.\n"
"                        <br/><br/>\n"
"                        <strong>TERCERA.-</strong> La prestación de los servicios de “EL TRABAJADOR” consistirá de acuerdo a la definición de su puesto de"
msgstr ""

#. module: rh_gebesa
#: model_terms:ir.ui.view,arch_db:rh_gebesa.report_contrato_indeterminado_document
msgid "así como cualquier otra actividad conexa o complementaria, de conformidad con las instrucciones y lineamientos que reciba de la empresa y de conformidad con los reglamentos interiores, las políticas y procedimientos de la empresa.\n"
"                        <br/><br/>\n"
"                        4. VI.- El Trabajador"
msgstr ""

#. module: rh_gebesa
