<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_stock_return_picking_form'>
        	<field name='name'>stock_return_picking_invoice_state_form</field>
        	<field name='model'>stock.return.picking</field>
        	<field name='inherit_id' ref='stock.view_stock_return_picking_form'/>
        	<field name='arch' type='xml'>
        		<xpath expr="//group/field[@name='parent_location_id']" position="before">
        			<field name='invoice_state' required="True" readonly="False"/>
        		</xpath>
        	</field>
        </record>
    </data>
</odoo>