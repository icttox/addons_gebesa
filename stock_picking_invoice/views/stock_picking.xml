<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_picking_form'>
        	<field name='name'>view_invoice_picking_form</field>
        	<field name='model'>stock.picking</field>
        	<field name='inherit_id' ref="stock.view_picking_form"/>
        	<field name='arch' type='xml'>
                <xpath expr="//notebook/page[3]/group/group/field[@name='move_type']" position="before">
                    <field name='invoice_state' required="True"/>
                </xpath>
        		<xpath expr="//button[@name='do_unreserve']" position="after">
        			<button name="%(action_stock_invoice)d" attrs="{'invisible': ['|',('state', '&lt;&gt;', 'done'), ('invoice_state', '&lt;&gt;', '2binvoiced')]}" string="Create invoice"  type="action" class="oe_highlight" group="base.group_user"/>
        		</xpath>
        	</field>
        </record>
    </data>
</odoo>