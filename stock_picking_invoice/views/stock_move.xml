<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_move_form'>
        	<field name='name'>view_invoice_move_form</field>
        	<field name='model'>stock.move</field>
        	<field name='inherit_id' ref="stock.view_move_form"/>
        	<field name='arch' type='xml'>
                <xpath expr="//group/group/field[@name='procure_method']" position="after">
                    <field name='invoice_state' required="True"/>
                </xpath>
        	</field>
        </record>
    </data>
</odoo>