<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_family_tree" model="ir.ui.view">
            <field name="name">sale.order.family.tree</field>
            <field name="model">sale.order.family</field>
            <field name="arch" type="xml">
                <tree string="Sale Orders Quantity">
                    <field name='week' interval="week"/>
                    <field name="order_id"/>
                    <field name="date_validator"/>
                    <field name="family_id"/>
                    <field name="amount" sum="Imp X Sur" widget="monetary"/>
                </tree>
            </field>
        </record> 

        <record id="sale_order_family_pivot" model="ir.ui.view">
            <field name="name">sale.order.family.pivot</field>
            <field name="model">sale.order.family</field>
            <field name="arch" type="xml">
                <pivot string="Sale Orders Quantity">
                    <field name="warehouse_id" type="row"/>
                    <field name="family_id" type="row"/>
                    <field name='week' type="col"/>
                    <field name="amount" type="measure"/>
                </pivot>
            </field>
        </record>


        <record id='action_family' model='ir.actions.act_window'>
            <field name='name'>Pivot Backorder Por Familia</field>
            <field name='res_model'>sale.order.family</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>pivot</field>
            <field name="view_id" ref="sale_order_family_pivot"/>
        </record>
        <menuitem id="menu_quantity_family" parent="sale.menu_sale_report" name="Pivot Backorder Por Familia" action="action_family"/>
    </data>
</odoo>
