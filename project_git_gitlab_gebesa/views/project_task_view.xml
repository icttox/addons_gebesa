<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_project_task" model="ir.ui.view">
        <field name="name">project.task.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form/header/button[last()]" position="after">
                    <button name="call_gitlab_api_task"  string="Crear Issue" type="object" class="oe_highlight" attrs="{'invisible': [('issue', '!=', False)]}"/>
                </xpath>
                <xpath expr="//form/sheet/group/group/field[@name='date_deadline']" position="before">
                    <field name="issue" widget="url"/>
                </xpath>
            </data>
        </field>
    </record>
</odoo>