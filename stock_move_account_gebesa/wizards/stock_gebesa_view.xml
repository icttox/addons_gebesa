<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_bom_change_view" model="ir.ui.view">
        <field name="name">Generate account moves from BoM changes</field>
        <field name="model">account.move.bom.change</field>
        <field name="arch" type="xml">
            <form string="Generate Account Moves">
                <separator string="Dates"/>
                <label for="date_ini" string="Enter the date range."/>
                <!--group col="4"-->
                    <field name="date_ini"/>
                    <field name="date_end"/>
                <!--/group-->
                <footer>
                    <button class="oe_highlight" default_focus="1" name="generate_am_bomchange" string="Proceed" type="object"/>
                    
                    <button class="oe_link" special="cancel" string="Cancel"/></footer>
            </form>
        </field>
    </record>
    <record id="action_generate_am_bomchanges_view" model="ir.actions.act_window">
        <field name="name">Generate account moves from BoM changes</field>
        <field name="res_model">account.move.bom.change</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="account_move_bom_change_view"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem action="action_generate_am_bomchanges_view" id="menu_generate_am_bomchanges" name="Generate account moves from BoM changes" parent="stock_move_batch_validator.inventory_special_process"/>

    <record id="account_move_stock_move_view" model="ir.ui.view">
        <field name="name">Generate account moves from stock moves</field>
        <field name="model">account.move.stock.move</field>
        <field name="arch" type="xml">
            <form string="Generate Account Moves">
                <separator string="Dates"/>
                <label for="date_ini" string="Enter the date range."/>
                <!--group col="4"-->
                    <field name="date_ini"/>
                    <field name="date_end"/>
                <!--/group-->
                <footer>
                    <button class="oe_highlight" default_focus="1" name="generate_am_sm" string="Proceed" type="object"/>
                    
                    <button class="oe_link" special="cancel" string="Cancel"/></footer>
            </form>
        </field>
    </record>
    <record id="action_generate_am_sm_view" model="ir.actions.act_window">
        <field name="name">Generate account moves from stock moves</field>
        <field name="res_model">account.move.stock.move</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="account_move_stock_move_view"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>
    <menuitem action="action_generate_am_sm_view" id="menu_generate_am_sm" name="Generate account moves from stock moves" parent="stock_move_batch_validator.inventory_special_process"/>
</odoo>