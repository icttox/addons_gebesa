<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="logistic_unit_type_tree" model="ir.ui.view">
            <field name="name">logistic.unit.type.tree</field>
            <field name="model">logistic.unit.type</field> 
            <field name="arch" type="xml">
                <tree string="Logistic Unit Type">
                    <field name="name"/>
                    <field name="width"/>
                    <field name="empty_weight"/>
                    <field name="height"/>
                    <field name="lenght"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>

        <record id="logistic_unit_type_form" model="ir.ui.view">
            <field name="name">logistic.unit.type.form</field>
            <field name="model">logistic.unit.type</field>
            <field name="arch" type="xml">
                <form string="Logistic Unit Type" version="9.0">
                    <sheet>
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="width"/>
                                <field name="empty_weight"/>
                            </group>
                            <group>
                                <field name="height"/>
                                <field name="lenght"/>
                            </group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_logistic_unit_type_form" model="ir.actions.act_window">
            <field name="name">Logistic Unit Type</field>
            <field name="res_model">logistic.unit.type</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem action="action_logistic_unit_type_form" id="menu_logistic_unit_type_form" name="Logistic Unit Type" parent="menu_mrp_packing" sequence="10"/>
    </data>
</odoo>
