<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <menuitem id="menu_mrp_packing"
            name="Packing"
            parent="mrp_shipment.logistics_menu"
            sequence="3"/>

        <record id="product_packing_tree" model="ir.ui.view">
            <field name="name">product.packing.tree</field>
            <field name="model">product.packing.list</field> 
            <field name="arch" type="xml">
                <tree string="Product Packing List">
                    <field name="name"/>
                    <field name="product_tmpl_id"/>
                    <field name="type"/>
                    <field name="description"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record id="product_packing_form" model="ir.ui.view">
            <field name="name">product.packing.form</field>
            <field name="model">product.packing.list</field>
            <field name="arch" type="xml">
                <form string="Packing List" version="9.0">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                            </button>
                        </div>
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="product_tmpl_id" required="1"/>
                                <field name="qty"/>
                            </group>
                            <group>
                                <field name="type"/>
                                <field name="active" readonly="1"/>
                            </group>
                            <field name="description" required="1"/>
                        </group>
                        <notebook>
                            <page string="Packing List Lines">
                                <field name='packing_line_ids' widget="one2many_list">
                                    <tree string="Packing List Lines" editable="bottom" required="1">
                                        <field name='unit_type_id'/>
                                        <field name='quantity' required="1"/>
                                        <field name='description' required="1"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_product_packing_gebesa_form" model="ir.actions.act_window">
            <field name="name">Product Packing List</field>
            <field name="res_model">product.packing.list</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem action="action_product_packing_gebesa_form" id="menu_product_packing_gebesa_form" name="Product Packing List" parent="menu_mrp_packing" sequence="10"/>
    </data>
</odoo>
