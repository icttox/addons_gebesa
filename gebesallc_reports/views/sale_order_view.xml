<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="sale_order_spiff_form">
            <field name="name">sale.order.spiff.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_cancel']" position="after">
                    <button name="apply_spiff" string="Apply SPIFF" type="object" attrs="{'invisible': [('spiff_number', '!=', '')]}" groups="gebesallc_reports.group_update_spiff_number"/>
                    <button name="apply_spiff" string="Unapply SPIFF" type="object" attrs="{'invisible': [('spiff_number', '=', '')]}" groups="gebesallc_reports.group_update_spiff_number"/>
                </xpath>
                <xpath expr="//field[@name='validity_date']" position="after">
                    <field name="spiff_number" readonly="1"/>
                    <field name="spiff_percent" attrs="{'readonly': [('spiff_number', '=', '')]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
