<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_background_llc">
        <div class="header">
            <div class="o_background_header">
            <div class="float-right">
                <h3 class="mt0 text-right" t-field="company.report_header"/>
            </div>
            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" class="float-left" alt="Logo"/>
            <div class="float-left company_address">
                <div>
                    <strong t-field="company.partner_id.name"/>
                </div>
                <span t-field="company.partner_id"
                    t-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/>
            </div>
            <div class="clearfix mb8"/>
            </div>
        </div>
        <div class="article o_report_layout_background" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-call="web.address_layout"/>
            <t t-raw="0"/>
        </div>

        <div class="footer o_background_footer">
            <div class="text-center">
                <ul class="list-inline">
                    <li><span>For questions, please contact:</span></li>
                    <li t-if="company.phone" class="list-inline-item"><i class="fa fa-phone" role="img" aria-label="Phone" title="Phone"/> <span t-field="company.phone"/></li>
                    <li t-if="company.email" class="list-inline-item"><span t-field="company.email"/></li>
                    <li t-if="company.website" class="list-inline-item"><i class="fa fa-globe" role="img" aria-label="Website" title="Website"/> <span t-field="company.website"/></li>
                </ul>
                <div t-field="company.report_footer"/>
                <div t-if="report_type == 'pdf'" class="text-muted">
                    Page:
                    <span class="page"/>
                    of
                    <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <template id="report_invoice_document">
        <t t-set="o" t-value="o.with_context(lang=lang)" />
    <!--EN EL ID, EL PRIMERO ES EL NOMBRE DE MI MODULO Y POSTERIORMENTE EL DEL ID DE MI LAYOUT-->
            <t t-if="not o" t-set="o" t-value="doc"/>
            <t t-if="not company">
                <!-- Multicompany -->
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id"/>
                </t>
                <t t-elif="o and 'company_id' in o">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company"/>
                </t>
            </t>
            <t t-call="gebesallc_reports.external_layout_background_llc">
                <div class="row">
                                <div class="col-6">
                                    <strong>BILL TO</strong>
                                        <div t-field="o.partner_id"
                                            t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True, "phone_icons": True}'/>
                                            <div t-if="o.partner_id.vat" class="mt16"><t t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>: <span t-field="o.partner_id.vat"/></div>
                                </div>
                                <div class="col-6">
                                    <strong>SHIP TO</strong>
                                        <div t-field="o.partner_shipping_id"
                                            t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True, "phone_icons": True}'/>
                                </div>
                            </div>
                <div class="page">
                    <h2>
                        <span t-if="o.move_type == 'out_invoice' and o.state in ('open', 'in_payment', 'paid')">Invoice</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                        <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                        <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                        <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                        <span t-field="o.name"/>
                    </h2>

                    <div id="informations" class="row mt32 mb32">
                        <div class="col-auto mw-100 mb-2" t-if="o.name" name="description">
                            <strong>Description:</strong>
                            <p class="m-0" t-field="o.name"/>
                        </div>
                        <div class="col-auto mw-100 mb-2" t-if="o.invoice_date" name="invoice_date">
                            <strong>Invoice Date:</strong>
                            <p class="m-0" t-field="o.invoice_date"/>
                        </div>
                        <div class="col-auto mw-100 mb-2" t-if="o.date_due and o.move_type == 'out_invoice' and o.state in ('open', 'in_payment', 'paid')" name="due_date">
                            <strong>Due Date:</strong>
                            <p class="m-0" t-field="o.date_due"/>
                        </div>
                        <div class="col-auto mw-100 mb-2" t-if="o.origin" name="origin">
                            <strong>Source:</strong>
                            <p class="m-0">
                                <t t-if="o.sale_id.company_id.country_id.code != 'MX' and o.sale_id.supplier_ref and o.move_type == 'out_invoice'">
                                    <t t-esc="o.sale_id.supplier_ref"/>
                                </t>
                                <t t-if="not(o.sale_id.company_id.country_id.code != 'MX' and o.sale_id.supplier_ref and o.move_type == 'out_invoice')">
                                    <t t-esc="o.origin"/>
                                </t>
                            </p>
                        </div>
                        <div class="col-auto mw-100 mb-2" t-if="o.partner_id.ref" name="customer_code">
                            <strong>Customer Code:</strong>
                            <p class="m-0" t-field="o.partner_id.ref"/>
                        </div>
                        <div name="reference" class="col-auto mw-100 mb-2" t-if="o.reference">
                            <strong>Reference:</strong>
                            <p class="m-0" t-field="o.reference"/>
                        </div>
                    </div>

                    <t t-set="display_discount" t-value="any([l.discount for l in o.invoice_line_ids])"/>

                    <table class="table table-sm o_main_table" name="invoice_line_table">
                        <thead>
                            <tr>
                                <!-- TODO: remove in master -->
                                <t t-set="colspan" t-value="6"/>
                                <th class="text-left"><span>Code</span></th>
                                <th class="text-left"><span>Description</span></th>
                                <th class="text-left"><span>Reference code</span></th>
                                <th class="d-none text-left"><span>Source Document</span></th>
                                <th class="text-right"><span>Quantity</span></th>
                                <th t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Unit Price</span></th>
                                <th t-if="display_discount" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                    <span>Disc.(%)</span>
                                    <!-- TODO: remove in master -->
                                    <t t-set="colspan" t-value="colspan+1"/>
                                </th>
                                <th t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Taxes</span></th>
                                <th class="text-right">
                                    <span groups="account.group_show_line_subtotals_tax_excluded">Amount</span>
                                    <span groups="account.group_show_line_subtotals_tax_included">Total Price</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="invoice_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-set="amount_downpayment_so" t-value="0"/>

                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <t t-if="line.price_subtotal &gt;= 0">

                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                    <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                        <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                            <td><span t-field="line.product_id.default_code"/></td> 
                                            <td> <span t-if="line.product_id.type == 'product'" t-field="line.product_id.name"></span>
                                            <span t-if="line.product_id.type != 'product'" t-field="line.name"></span></td>
                                            <td class="d-none"><span t-field="line.origin"/></td>
                                            <td t-if="line.sale_line_ids">
                                                <t t-foreach="line.sale_line_ids" t-as="sale_line">
                                                    <span t-esc="sale_line.reference_code"/>
                                                </t>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{0:,.2f}'.format(round(line.quantity,2))"/>
                                                <span t-field="line.uom_id"  groups="uom.group_uom"/>
                                            </td>
                                            <td t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                <span t-esc="'{0:,.2f}'.format(round(line.price_unit,2))"/>
                                            </td>
                                            <td t-if="display_discount" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                <span t-esc="'{0:,.2f}'.format(round(line.discount,2))"/>
                                            </td>
                                            <td t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.invoice_line_tax_ids))"/>
                                            </td>
                                            <td class="text-right o_price_total">
                                                <span t-esc="'{0:,.2f}'.format(round(line.price_subtotal,2))" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                <span t-esc="'{0:,.2f}'.format(round(line.price_total,2))" groups="account.group_show_line_subtotals_tax_included"/>
                                            </td>
                                        </t>
                                        <t t-if="line.display_type == 'line_section'">
                                            <td colspan="99">
                                                <span t-field="line.name"/>
                                            </td>
                                            <t t-set="current_section" t-value="line"/>
                                            <t t-set="current_subtotal" t-value="0"/>
                                        </t>
                                        <t t-if="line.display_type == 'line_note'">
                                            <td colspan="99">
                                                <span t-field="line.name"/>
                                            </td>
                                        </t>
                                    </tr>

                                    <t t-if="current_section and (line_last or o.invoice_line_ids[line_index+1].display_type == 'line_section')">
                                        <tr class="is-subtotal text-right">
                                            <td colspan="99">
                                                <strong class="mr16">Subtotal</strong>
                                                <span
                                                    t-esc="current_subtotal"
                                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                                />
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="line.price_subtotal &lt; 0">
                                    <t t-set="amount_downpayment_so" t-value="amount_downpayment_so + abs(line.price_subtotal)"/>
                                </t>
                            </t>
                        </tbody>
                    </table>

                    <div class="clearfix">
                        <div id="total" class="row">
                            <div t-attf-class="#{'col-4' if report_type != 'html' else 'col-sm-7 col-md-5'} ml-auto">
                                <table class="table table-sm;page-break-inside: avoid;">
                                    <tr class="border-black o_subtotal" style="">
                                        <td><strong>Subtotal</strong></td>
                                        <td class="text-right">
                                            <span t-esc="'{0:,.2f}'.format(round(o.amount_untaxed + amount_downpayment_so,2))"/>
                                        </td>
                                    </tr>

                                    <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                                        <tr style="">
                                            <t t-if="len(o.tax_line_ids) == 1 and o.amount_untaxed == amount_by_group[2]">
                                                <td><span t-esc="amount_by_group[0]"/></td>
                                                <td class="text-right o_price_total">
                                                    <span t-esc="amount_by_group[3][:-4]"/>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td>
                                                    <span t-esc="amount_by_group[0]"/>
                                                    <span>&amp;nbsp;<span>on</span>
                                                        <t t-esc="amount_by_group[4][:-4]"/>
                                                    </span>
                                                </td>
                                                <td class="text-right o_price_total">
                                                    <span t-esc="amount_by_group[3][:-4]"/>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                    <t t-set="amount_downpayment" t-value="0"/>
                                    <t t-foreach="o.advance_ids" t-as="downpayment">
                                        <t t-set="amount_downpayment" t-value="amount_downpayment + downpayment.amount_advance"/>
                                    </t>
                                    <t t-set="amount_downpayment" t-value="amount_downpayment + amount_downpayment_so"/>
                                    <tr class="o_subtotal">
                                        <td><strong>Downpayment</strong></td>
                                        <td class="text-right">
                                            <span t-esc="'{0:,.2f}'.format(round(amount_downpayment,2))"/>
                                        </td>
                                    </tr>
                                    <tr class="border-black o_total">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right">
                                            <span t-esc="'{0:,.2f}'.format(round(o.amount_total - amount_downpayment + amount_downpayment_so,2))"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <p t-if="o.reference">
                        Please use the following communication for your payment : <b><span t-field="o.reference"/></b>
                    </p>
                    <p t-if="o.comment" name="comment">
                        <span t-field="o.comment"/>
                    </p>
                    <p t-if="o.payment_term_id" name="payment_term">
                        <span t-field="o.payment_term_id.note"/>
                    </p>
                    <p t-if="o.fiscal_position_id.note" name="note">
                        <span t-field="o.fiscal_position_id.note"/>
                    </p>

                    <div class="row mt-4">
                        <div class="text-right col-6">
                            <div class="row">
                                <div class="col-12 text-center py-0 px-1">
                                    <strong>For wire/ACH Transfers:</strong>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>Bank:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>BANK OF AMERICA</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>Name of the account:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>GEBESA LLC</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>Account Number:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>457052005509</span>
                                </div>
                            </div>
                             <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>Wire Routing Number:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>026009593</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>ACH Routing Number:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>122101706</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6 text-right py-0 px-1">
                                    <strong>SWIFT NUMBER:</strong>
                                </div>
                                <div class="col-6 text-left py-0 px-1">
                                    <span>BOFAUS3N</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="row">
                                <div class="col-12 text-center py-0 px-1">
                                    <strong>For Checks:</strong>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4 text-right py-0 px-1">
                                    <strong>Address:  </strong>
                                </div>
                                <div class="col-8 text-left py-0 px-1">
                                    <span>1414 E Indian School Rd.</span>
                                </div>
                            </div>
                            <!--div class="row">
                                <div class="col-4 text-right py-0 px-1">
                                    <strong></strong>
                                </div>
                                <div class="col-8 text-left py-0 px-1">
                                    <span>Suite 100</span>
                                </div>
                            </div-->
                            <div class="row">
                                <div class="col-4 text-right py-0 px-1">
                                    <strong></strong>
                                </div>
                                <div class="col-8 text-left py-0 px-1">
                                    <span>Phoenix, Arizona 85014</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4 text-right py-0 px-1">
                                    <strong>Attention:  </strong>
                                </div>
                                <div class="col-8 text-left py-0 px-1">
                                    <span>GEBESA SHOWROOM</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="qrcode" t-if="(o.company_id.qr_code) and (o.currency_id.name == 'EUR') and (o.partner_bank_id.acc_number != False)">
                        <p t-if="(o.partner_bank_id.qr_code_valid)">
                            <strong class="text-center">Scan me with your banking app.</strong><br /><br />
                            <img class="border border-dark rounded" t-att-src="o.partner_bank_id.build_qr_code_url(o.residual,(o.reference) if (o.reference) else o.name)"/>
                        </p>
                        <p t-if="(o.partner_bank_id.qr_code_valid == False)">
                            <strong class="text-center">The SEPA QR Code informations are not set correctly.</strong><br />
                        </p>
                    </div>
                </div>
            </t>
    </template>
</odoo>


