<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_revalue_cost_usd" model="ir.cron">
            <field name="name">Revalue Product Cost USD</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="(DateTime.now() + timedelta(days= +1)).strftime('%Y-%m-%d 11:00:00')" name="nextcall"/>
            <field eval="False" name="doall"/>
            <field name="model_id" ref="model_product_product"/>
            <field name="state">code</field>
            <field name="code">model.revalue_cost_usd()</field>
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>