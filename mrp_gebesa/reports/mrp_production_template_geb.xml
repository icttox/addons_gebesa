<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mrporder_geb">
        <xpath expr="//t[@t-call='web.html_container']" position="replace">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.internal_layout">
                        <div class="page">
                            <div class="oe_structure"/>
                            <div class="row">
                                <div class="col-7">
                                    <h2>Orden de producción # : <span t-field="o.name"/></h2>
                                </div>
                                
                                <div class="col-5">
                                    <span class="text-right">
                                        <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.name, 600, 100)" style="width:350px;height:60px"/>
                                    </span>
                                </div>
                            </div>
                            
                            <div class="row mt32 mb32">
                                <div class="col-3" t-if="o.origin">
                                    <strong>Documento origen:</strong><br/>
                                    <span t-field="o.origin"/>
                                </div>
                                <div class="col-3">
                                    <strong>Responsable:</strong><br/>
                                    <span t-field="o.user_id"/>
                                </div>
                                <div class="col-3">
                                    <strong>Fecha planificada:</strong><br/>
                                    <span t-field="o.date_planned_start"/>
                                    <span t-if="o.date_planned_finished"> - <span t-field="o.date_planned_finished"/></span>
                                </div>
                            </div>

                            <div class="row mt32 mb32">
                                <div class="col-3">
                                    <strong>Producto producido:</strong><br/>
                                    <span t-field="o.product_id"/>
                                </div>
                                <div class="col-3">
                                    <strong>Cantidad a producir:</strong><br/>
                                    <span t-field="o.product_qty"/>
                                    <span t-field="o.product_uom_id.name" groups="uom.group_uom"/>
                                </div>
                                <div class="col-3">
                                    <strong>Fecha de impresión:</strong><br/>
                                    <span t-esc="time.strftime('%Y-%m-%d')"
                                          t-options='{"widget": "date"}'/>
                                </div>
                            </div>

                            <div t-if="o.workorder_ids">
                                <h3>
                                    <t t-if="o.state == 'done'">Operaciones hechas</t>
                                    <t t-else="">Operaciones planeadas</t>
                                </h3>
                                <table class="table table-sm">
                                    <tr>
                                        <th><strong>Operación</strong></th>
                                        <th><strong>Centro de trabajo</strong></th>
                                        <th><strong>No. de minutos</strong></th>
                                    </tr>
                                    <tr t-foreach="o.workorder_ids" t-as="line2">
                                        <td><span t-field="line2.name"/></td>
                                        <td><span t-field="line2.workcenter_id.name"/></td>
                                        <td>
                                            <span t-if="o.state != 'done'" t-field="line2.duration_expected"/>
                                            <span t-if="o.state == 'done'" t-field="line2.duration"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <h3 t-if="o.move_raw_ids">
                                <t>
                                    Lista de Materiales (LdM)
                                </t>
                            </h3> 

                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <t t-set="colspan" t-value="7"/>
                                        <th class="text-left">Producto</th>
                                        <th class="text-right">A consumir</th>
                                        <th class="text-right">Reserva</th>
                                        <th class="text-right">Consumido</th>
                                        <th class="text-left">Origen</th>
                                        <th class="text-left">Destino</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="o.move_raw_ids" >
                                        <t t-set="lines" t-value="o.move_raw_ids"/>
                                        <t t-foreach="lines" t-as="line">
                                            <tr>
                                                <td>
                                                    <span t-field="line.product_id"/>
                                                </td>                                                
                                                <td class="text-right">
                                                    <span t-esc="line.product_uom_qty"/>
                                                </td>
                                                <td class="text-right">                             
                                                    <span t-esc="line.reserved_availability"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="line.quantity_done"/>
                                                </td>
                                                <td>
                                                    <span t-field="line.location_id"/>
                                                </td>
                                                <td>
                                                    <span t-field="line.location_dest_id"/>
                                                </td>                                                   
                                            </tr>
                                        </t>
                                    </t>                                    
                                </tbody>
                            </table>
                            <div class="oe_structure"/>
                        </div>
                    </t>
                </t>
            </t>
        </xpath>
    </template>
</odoo>