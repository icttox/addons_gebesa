<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_order_form" model="ir.ui.view">
            <field name="name">view_order_counter_tag_form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="groups_id" eval="[(3, ref('system_administrator.group_system_administrator_gebesa'))]"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page/group/group/field[@name='origin']" position="after">
                    <field name="counter_tag" groups="system_administrator.group_system_administrator_gebesa"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>