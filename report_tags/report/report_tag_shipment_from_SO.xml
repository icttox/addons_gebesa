<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="shipment_tag_so"
            model="sale.order"
            string="Etiqueta Embarque"
            report_type="qweb-pdf"
            name="report_tags.report_so_shipment_tag"
            file="report_tags.report_so_shipment_tag"
        />

        <record id="report_tags.shipment_tag_so" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag" />
        </record>

        <report
            id="shipment_tag_so_debrand"
            model="sale.order"
            string="Etiqueta de Embarque Debranded"
            report_type="qweb-pdf"
            name="report_tags.report_so_shipment_tag_debranded"
            file="report_tags.report_so_shipment_tag_debranded"
        />

        <record id="report_tags.shipment_tag_so_debrand" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag" />
        </record>

        <template id="report_so_shipment_tag_document">
            <t t-call="report_tags.report_tag_layout_empty">
                <div class="page" style="font-size: small">
                    <t t-set="pag_n" t-value="1"/>
                    <t t-foreach="doc.order_line" t-as="line">
                        <t t-foreach="range(int(line.product_uom_qty))" t-as="qty">
                            <div class="row no-gutters" style="border: 1px solid #000000;height: 45px;">
                                <div class="col-6">
                                    <t t-if="doc.company_id.logo_invoice">
                                        <img t-if="print_debrand" t-att-src="image_data_uri(doc.company_id.logo_invoice)" style="max-height: 30px;max-width: 100px;margin-top: 10px;margin-left: 3px;" alt="Logo"/>
                                    </t>
                                </div>
                                <div class="col-6 text-right">
                                    <div t-if="print_debrand" class="mr-2">
                                        <strong>
                                            www.gebesa.com<br/>01 800 8432 372
                                        </strong>
                                    </div>
                                </div>
                            </div>
                            <div class="row no-gutters" style="border-left: 1px solid #000000;border-right: 1px solid #000000;border-bottom: 1px solid #000000;">
                                <div class="col-11 mx-auto" style="margin-top: 10px;">
                                    <div class="text-light bg-dark">
                                        <strong>CLIENTE/CUSTOMER:</strong>
                                    </div>
                                    <div style="height: 45px">
                                        <h5 class="align-items-center">
                                            <span t-field="doc.partner_id.name"/>
                                            <t t-if="doc.partner_dealer_id.id">
                                                (<span t-field="doc.partner_dealer_id.name"/>)
                                            </t>
                                        </h5>
                                    </div>
                                    <div class="text-light bg-dark">
                                        <strong>DESTINO/DESTINATION:</strong>
                                    </div>
                                    <div style="height: 40px">
                                        <h5><span t-field="doc.city_id"/>, <span t-field="doc.state_id.name"/></h5>
                                    </div>
                                    <div class="text-light bg-dark">
                                        <strong>DIRECCIÓN ENTREGA/DELIVERY ADDRESS:</strong>
                                    </div>
                                    <div style="height: 75px">
                                        <h5><span t-field="doc.partner_shipping_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/></h5>
                                    </div>
                                    <div class="row mx-auto">
                                        <div class="col-3 text-light bg-dark">
                                            <strong>O.C./P.O.:</strong>
                                        </div>
                                        <div class="col-9" style="border: 1px solid #000000;">
                                            <span t-field="doc.client_order_ref"/>
                                        </div>
                                    </div>
                                    <div style="margin-top: 8px;">
                                        PEDIDO/S.O.: 
                                        <t t-if="doc.is_manufacturer">
                                            <span t-field="doc.name"/>
                                        </t>
                                        <t t-if="not doc.is_manufacturer">
                                            <span t-field="doc.supplier_ref"/>
                                        </t>
                                    </div>
                                    <div class="text-right">
                                        <sub><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y')"/></sub>
                                    </div>
                                </div>
                            </div>
                            <div class="text-center">
                                <sub>Pagina <span t-esc="pag_n"/> de <span t-esc="pag_tot[doc.id]"/></sub>
                            </div>
                                <!--/t>
                            </t-->
                            <p style="page-break-after:always;">   </p>
                            <t t-set="pag_n" t-value="pag_n+1"/>
                        </t>
                    </t>
                    <!--/t-->
                </div>
            </t>
        </template>

        <template id="report_so_shipment_tag">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="print_debrand" t-value="True"/>
                    <t t-call="report_tags.report_so_shipment_tag_document"/>
                </t>
            </t>
        </template>

        <template id="report_so_shipment_tag_debranded">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="print_debrand" t-value="False"/>
                    <t t-call="report_tags.report_so_shipment_tag_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>