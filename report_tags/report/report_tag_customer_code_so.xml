<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="customer_code_sale_order_tag"
            model="sale.order"
            string="Etiqueta Código del Cliente"
            report_type="qweb-pdf"
            name="report_tags.report_customer_code_so_tag"
            file="report_tags.report_customer_code_so_tag"
        />
        <record id="report_tags.customer_code_sale_order_tag" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag" />
        </record>

        <template id="report_customer_code_so_tag_document">
            <div class="page" style="font-size: 7pt;">
                <t t-foreach="doc.order_line" t-as="line">
                    <t t-foreach="range(int(line.product_uom_qty))" t-as="qty">
                        <t t-set="paquete" t-value="cust_code[doc.id][line.product_id.id].pack_num"/>
                        <t t-if="paquete &gt; 1">
                            <t t-foreach="range(cust_code[doc.id][line.product_id.id].pack_num)" t-as="paque">
                                <div style="border: 2px solid #000000; border-radius:16px 16px 16px 16px;height: 350px">
                                    <div style="font-size: 14pt;">
                                        <div>
                                            <b style="font-size: 20pt;">&#160;(<span t-esc="cust_code[doc.id][line.product_id.id].qty"/>)</b>
                                            <b style="font-size: 20pt;"><span t-esc="cust_code[doc.id][line.product_id.id].customer_code"/></b>
                                            <b>&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<span t-esc="cust_code[doc.id][line.product_id.id].customer_description"/></b>
                                        </div>
                                        <br/><br/><br/><br/>
                                        <div align="center" style="font-size: 25pt;">
                                            <t t-set="code" t-value="'*'+cust_code[doc.id][line.product_id.id].customer_code+'*'"/>
                                            <div style="font-family: CCode39;">
                                                <span t-esc="code"/>
                                                <br/><br/>
                                            </div>
                                            <span t-esc="code"/>
                                        </div>
                                    </div>
                                </div>
                                <div style="page-break-after: always;">
                                    Paquete <span t-esc="paque + 1"/> de <span t-esc="'%.0f'%cust_code[doc.id][line.product_id.id].pack_num"/>
                                </div>
                            </t>
                        </t>
                        <t t-else="paquete &gt; 1">
                            <div style="border: 2px solid #000000; border-radius:16px 16px 16px 16px;height: 350px">
                                <div style="font-size: 14pt;">
                                    <div>
                                        <b style="font-size: 20pt;">&#160;(<span t-esc="cust_code[doc.id][line.product_id.id].qty"/>)</b>
                                        <b style="font-size: 20pt;"><span t-esc="cust_code[doc.id][line.product_id.id].customer_code"/></b>
                                        <b>&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<span t-esc="cust_code[doc.id][line.product_id.id].customer_description"/></b>
                                    </div>
                                    <br/><br/><br/><br/>
                                    <div align="center" style="font-size: 25pt;">
                                        <t t-set="code" t-value="'*'+cust_code[doc.id][line.product_id.id].customer_code+'*'"/>
                                        <div style="font-family: CCode39;">
                                            <span t-esc="code"/>
                                            <br/><br/>
                                        </div>
                                        <span t-esc="code"/>
                                    </div>
                                </div>
                            </div>
                            <div style="page-break-after: always;">
                                Pàgina <span t-esc="qty + 1"/> de <span t-esc="'%.0f'%line.product_uom_qty"/>
                            </div>
                        </t>
                    </t>
                </t>
            </div>
        </template>

        <template id="report_customer_code_so_tag">
            <t t-call="web.html_container">
                <t t-call="report_tags.report_tag_layout_empty">
                    <t t-foreach="docs" t-as="doc">
                        <t t-call="report_tags.report_customer_code_so_tag_document"/>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>