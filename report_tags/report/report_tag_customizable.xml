                                    <span t-esc="code_customer[doc.id]['customer_code'].customer_code" style="font-size: 23pt;"/>
                                </t>
                                <t t-if="len(code_customer[doc.id]['customer_code'].customer_code) &gt; 16">
                                    <span t-esc="code_customer[doc.id]['customer_code'].customer_code" style="font-size: 18pt;"/>
                                </t>
                                <br/>
                                <br/>
                                <b>Rev #:</b>
                                <br/>
                                <span t-esc="code_customer[doc.id]['customer_code'].version" style="font-size: 23pt;"/>
