<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="tag_customizable"
            model="mrp.production"
            string="Etiqueta Personalizable"
            report_type="qweb-pdf"
            name="report_tags.report_tag_customizable"
            file="report_tags.report_tag_customizable"
        />
        <record id="report_tags.tag_customizable" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag_vertical" />
        </record>

        <template id="report_tag_customizable_production_document_type1">
            <div class="page" style="font-size: 7pt;">
                <t t-foreach="line_ids" t-as="line_id">
                    <t t-foreach="range(int(line_ids[line_id]))" t-as="qty">
                        <div align="center" style="border: 1px solid #000000; height: 230px;">
                            <div>
                                <img t-att-src="'data:image/png;base64,%s' % code_customer[doc.id]['partner_id'].image" style="max-width: 290px;margin-top: 18px;"/>
                            </div>
                            <br/>
                            <div style="font-size: 16pt;">
                                <strong>
                                    (<span t-esc="code_customer[doc.id]['customer_code'].qty"/>) <span t-esc="code_customer[doc.id]['customer_code'].customer_code"/>
                                </strong>
                                <br />
                                <t t-if="code_customer[doc.id]['partner_id'].type_barcode == 'CCode39'">
                                    <div style="margin-top: 10px;font-size: 12pt;font-family: CCode39;">
                                        <t t-set="code" t-value="'*'+str(code_customer[doc.id]['customer_code'].qty)+' '+code_customer[doc.id]['customer_code'].customer_code+'*'"/>
                                        <span t-esc="code"/>
                                    </div>
                                </t>
                                <t t-if="code_customer[doc.id]['partner_id'].type_barcode == 'Code128bWin'">
                                    <t t-set="code" t-value="str(code_customer[doc.id]['customer_code'].qty)+' '+code_customer[doc.id]['customer_code'].customer_code"/>
                                    <t t-set="code_img" t-value="code128_image(code)"/>
                                    <img t-att-src="'data:image/png;base64,%s' % code_img" style="max-width: 290px;margin-top: 18px;"/>
                                </t>
                                <t t-if="code_customer[doc.id]['partner_id'].type_barcode == 'UPC_A'">
                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=%s' % ('UPCA', str(code_customer[doc.id]['customer_code'].qty)+' '+code_customer[doc.id]['customer_code'].customer_code, 1500, 400, 1)" style="max-width: 290px;"/>
                                </t>
                            </div>
                            <br />
                            <br />
                            <div style="font-size: 8pt;">
                                Made in Mexico / Hecho en México / Fabriqué au Mexique
                            </div>
                        </div>
                        <div align="center" style="border: 1px solid #000000; height: 160px;font-size: 8pt">
                            <br />
                            <t t-foreach="langs" t-as="lang">
                                <t t-set="trans" t-value="code_customer[doc.id]['customer_code'].with_context({'lang':lang})"/>
                                <span t-esc="trans.customer_description"/>
                                <br />
                            </t>
                        </div>
                        <div align="center" style="border: 1px solid #000000; height: 160px;font-size: 8pt">
                            <br />
                            Manufactured for / Manufacturado para / Fabriqué pour
                            <br />
                            <span t-esc="code_customer[doc.id]['partner_id'].tag_footer"/>
                        </div>
                        Página <span t-esc="qty + 1"/> de <span t-esc="'%.0f'%int(line_ids[line_id])"/>
                        <div style="page-break-after: always;">&#160;</div>
                    </t>
                </t>
            </div>
        </template>

