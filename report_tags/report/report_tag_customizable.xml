        <template id="report_tag_customizable">
            <t t-call="web.html_container">
                <t t-call="report_tags.report_tag_layout_empty">
                    <t t-foreach="docs" t-as="doc">
                        <t t-if="template != '6'">
                            <t t-set="partner_lang" t-value="code_customer[doc.id]['partner_id'].lang"/>
                        </t>
                        <t t-set="line_ids" t-value="line_qty[doc.id]"/>
                        <t t-if="template == '1'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type1"/>
                        </t>
                        <t t-if="template == '2'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type2"/>
                        </t>
                        <t t-if="template == '3'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type3"/>
                        </t>
                        <t t-if="template == '4'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type4"/>
                        </t>
                        <t t-if="template == '5'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type5"/>
                        </t>
                        <t t-if="template == '6'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type6"/>
                        </t>
                        <t t-if="template == '7'">
                            <t t-call="report_tags.report_tag_customizable_production_document_type7"/>
