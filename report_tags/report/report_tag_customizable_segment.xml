<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <report
            id="tag_customizable_segment"
            model="mrp.segment"
            string="Etiqueta Personalizable"
            report_type="qweb-pdf"
            name="report_tags.report_tag_customizable_segment"
            file="report_tags.report_tag_customizable_segment"
        />

        <record id="report_tags.tag_customizable_segment" model="ir.actions.report">
            <field name="paperformat_id" ref="report_tags.paperformat_tag_vertical" />
        </record>

        <template id="report_tag_customizable_segment">
            <t t-call="web.html_container">
                <t t-call="report_tags.report_tag_layout_empty">
                    <t t-foreach="docs" t-as="doc">
                        <t t-call="report_tags.report_tag_customizable_document"/>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>