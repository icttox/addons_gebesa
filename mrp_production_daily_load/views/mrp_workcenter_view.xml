<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MRP.WORKCENTER -->
    <record id="mrp_workcenter_view_form_inherit" model="ir.ui.view">
        <field name="name">mrp.workcenter.form.inherit</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="daily_load_available"/>
                <field name="hr_department_ids" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//field[@name='code']" position="replace">
                <field name="code" required="True"/>
            </xpath>
        </field>
    </record>
</odoo>