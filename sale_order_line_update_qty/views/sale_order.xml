<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_order_form" model="ir.ui.view">
            <field name="name">view_order_update_qty_form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="groups_id" eval="[(6,0, [ref('sale_order_line_update_qty.group_update_qty_sale_order_line')])]" />
            <field name="arch" type="xml">
                <xpath expr="//sheet/notebook/page/field[@name='order_line']/tree/field[@name='customer_lead']" position="after">
                    <button icon="fa-level-up" name="%(action_sale_order_line_update_qty)d" string="Update qty" type="action" context="{'default_product_uom_qty': product_uom_qty, 'default_product_id': product_id, 'default_qty_delivered': qty_delivered, 'default_qty_invoiced': qty_invoiced}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>