<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_line_update_qty_form" model="ir.ui.view">
            <field name="name">sale.order.line.update.qty.form</field>
            <field name="model">sale.order.line.update.qty</field>
            <field name="arch" type="xml">
                <form string="Update qty">
                    <group>
                        <group colspan="4">
                            <field name="product_id" readonly="True"/>
                            <field name="product_uom_qty" readonly="True"/>
                        </group>
                        <group>
                            <field name="qty_delivered" required="True"/>
                            <field name="qty_invoiced" required="True"/>
                        </group>
                    </group>
                    <footer>
                        <button icon="gtk-ok" name="update_qty" string="Update" type="object"/>
                        Or
                        <button icon="gtk-cancel" special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_sale_order_line_update_qty" model="ir.actions.act_window">
            <field name="name">Update qty</field>
            <field name="res_model">sale.order.line.update.qty</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>