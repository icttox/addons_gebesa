<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_company_form'>
            <field name='name'>view.company.form</field>
            <field name='model'>res.company</field>
            <field name='inherit_id' ref="base.view_company_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//div[@class='oe_title']" position="after">
                    <group>
                        <field name="is_manufacturer" groups="base.group_multi_company"/>
                        <field name="sale_project_id" groups="base.group_multi_company"/>
                        <field name="sale_warehouse_id" groups="base.group_multi_company"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
