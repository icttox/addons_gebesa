<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="assets_specific" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/flete_gebesa/static/src/css/travel_instructions.css"/>
            </xpath>
        </template>

        <report
            id="informe_gastos"
            model="tms.travel"
            string="Informe de Gastos"
            report_type="qweb-pdf"
            name="flete_gebesa.report_informe_gastos"
            file="flete_gebesa.report_informe_gastos"
        />

        <record id="flete_gebesa.informe_gastos" model="ir.actions.report">
            <field name="paperformat_informe_gastos_id" ref="flete_gebesa.paperformat_informe_gastos" />
        </record>

        <template id="informe_gastos_layout">
            <div class="header">
                <div id="cabezera">
                </div>
                <div width="100%">
                    <div id="logo">
                        <img class="logo_porte" t-if="doc.create_uid.partner_id.company_id.logo" t-att-src="'data:image/png;base64,%s' % doc.create_uid.partner_id.company_id.logo"/>
                    </div>
                    <div style="text-align:center;" id="titulo">
                        INSTRUCCIONES DE GASTOS
                    </div>
                </div>
                <div id="departamento">
                    <span t-esc="doc.user_id.company_id.name"/>
                </div>
                <div style="text-align:center;" id="titulo">
                        Fecha:&#160;<span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                </div>
            </div>

            <div class="article o_report_layout_standard">
                <t t-raw="0" />
            </div>
        </template>
