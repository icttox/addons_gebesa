            <div class="footer">
                <div  align="center" class="col-xs-4" style="border:1px solid black; border-radius:10px">
                    <b>OPERADOR DE UNIDAD</b>
                    <br/>
                    <br/>
                    _______________________________
                    <br/>
                    &#160;&#160;&#160;&#160;Nombre y Firma
                </div>
                <div align="center" class="col-xs-4" style="border:1px solid black; border-radius:10px">
                    <b>COORDINADOR OPERATIVO</b>
                    <br/>
                    <br/>
                    _______________________________
                    <br/>
                     &#160;&#160;&#160;Nombre y Firma Depto. Embarques
                </div>
                <div align="center" class="col-xs-4" style="border:1px solid black; border-radius:10px">
                    <strong>RESPONSABLE DE REPARACION</strong>
                    <br/>
                    <br/>
                    _______________________________
                     &#160;&#160;&#160;Nombre y Firma Credito y Cobranza
                </div>
            </div>-->
        </template>

