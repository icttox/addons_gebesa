<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="assets_specific" inherit_id="web.report_assets_common">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/flete_gebesa/static/src/css/travel_instructions.css"/>
            </xpath>
        </template>

        <report
            id="mantenimiento_correctivo"
            model="tms.travel"
            string="Mantenimiento Correctivo"
            report_type="qweb-pdf"
            name="flete_gebesa.report_mantenimiento_correctivo"
            file="flete_gebesa.report_mantenimiento_correctivo"
        />

        <template id="mantenimiento_correctivo_layout">
            <div class="header">
                <div class="row">
                    <div class="col-3" id="logo">
                        <img t-if="doc.create_uid.partner_id.company_id.logo" t-att-src="'data:image/png;base64,%s' % to_text(doc.create_uid.partner_id.company_id.logo)" style="max-width: 180px; max-height: 120px;" class="pull-left"/>
                    </div>
                    <div class="col-6 text-center">
                        MANTENIMIENTO CORRECTIVO
                        <br/>
                        <strong>
                             ORDEN DE REPARACION
                        </strong>
                    </div>
                    <div class="col-3" style="text-align:right;">
                        FOLIO: <span t-esc="doc.name"/>
                    </div>
                </div>
                <div class="row text-center">
                    <div class="col-12">
                        <strong>
                            <span t-esc="doc.create_uid.partner_id.company_id.name"/>
                        </strong>
                        <br/>
                            Fecha:&#160;<span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                    </div>
                </div>
            </div>

            <div class="article o_report_layout_standard">
                <t t-raw="0" />
            </div>

