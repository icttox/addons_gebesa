<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tms_toll_import_view_gebesa_pase" model="ir.ui.view">
            <field name="name">tms.toll.import.view.gebesa.pase</field>
            <field name="model">tms.toll.wizard.pase</field>
            <field name="arch" type="xml">
                <form string="Import information">
                    <separator colspan="4" string="Please upload the file with tollstations information"/>
                    <group>
                        <field name='filename' invisible='1'/>
                        <field widget="binary" height="64" name="file" filename="filename"/>
                    </group>
                    <footer>
                        <button name="update_tollstation_pase" class="oe_highlight" string="Confirm" type="object"/>
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="tms_toll_import_gebesa_pase_action" model="ir.actions.act_window">
            <field name="name">Import TollStations Pase</field>
            <field name="res_model">tms.toll.wizard.pase</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <menuitem action="tms_toll_import_gebesa_pase_action" id="tms_toll_import_gebesa_pase_action_menu" name="Import TollStations Pase"  parent="tms.menu_tms_settings" sequence="9"/>
    </data>
</odoo>
