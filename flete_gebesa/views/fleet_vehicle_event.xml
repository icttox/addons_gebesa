<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_fleet_vehicle_event_tree_view">
            <field name="name">view.fleet.vehicle.event.tree.view</field>
            <field name="model">fleet.vehicle.event</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="TMS Events">
                    <field name="name"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>

        <record id="view_fleet_vehicle_event_form" model="ir.ui.view">
            <field name="name">fleet.vehicle.event.form</field>
            <field name="model">fleet.vehicle.event</field>
            <field name="arch" type="xml">
                <form string="TMS Events">
                    <sheet>
                        <group col="4">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="type"/>
                            <!-- <field name="vehicle_id"/> -->
                            <field name="amount"/>
                            <field name="positive"/>
                        </group>
                        <group colspan="4" string="Notes">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
