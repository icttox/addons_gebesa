<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tms_travel_stop_tree" model="ir.ui.view">
            <field name="name">tms.travel.stop.tree</field>
            <field name="model">tms.travel.stop</field>
            <field name="arch" type="xml">
                <tree string="Stops">
                    <field name="address"/>
                    <field name="latitude"/>
                    <field name="longitude"/>
                    <field name="distance"/>
                    <field name="duration"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </tree>
            </field>
        </record>

        <record id="tms_travel_stop_form" model="ir.ui.view">
            <field name="name">tms.travel.stop.form</field>
            <field name="model">tms.travel.stop</field>
            <field name="arch" type="xml">
                <form string="Stops">
                    <sheet>
                        <h1>
                            <label for="address" class="oe_inline" style="font-size:30px;" string="Address - " attrs="{'invisible':[('address','=', False)]}"/>
                            <field class="oe_inline" name="address" readonly="0"/>
                        </h1>
                        <group>
                            <group>
                                <field name="latitude"/>
                                <field name="distance"/>
                                <field name="from_date"/>
                                <field name="travel_id"/>
                            </group>
                            <group>
                                <field name="longitude"/>
                                <field name="duration"/>
                                <field name="to_date"/>
                            </group>
                        </group>
                        <group>
                            
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" placeholder="Share a message..." widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_tms_travel_stop" model="ir.actions.act_window">
            <field name="name">Stops for travel</field>
            <field name="res_model">tms.travel.stop</field>
            <field name="context">{}</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>
        <menuitem action="action_tms_travel_stop" id="menu_tms_travel_stop" name="Stops for travel" parent="tms.menu_tms_settings" sequence="10"/>
    </data>
</odoo>