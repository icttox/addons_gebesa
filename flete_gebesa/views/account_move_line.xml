<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_move_line_acc_number_tree'>
            <field name='name'>view.move.line.acc.number.tree</field>
            <field name='model'>account.move.line</field>
            <field name='inherit_id' ref='account.view_move_line_tree'/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='account_id']" position="after">
                    <field name='acc_number'/>
                </xpath>
            </field>
        </record>

        <record model='ir.ui.view' id='view_move_line_acc_number_form'>
            <field name='name'>view.move.line.acc.number.form</field>
            <field name='model'>account.move.line</field>
            <field name='inherit_id' ref='account.view_move_line_form'/>
            <field name='arch' type='xml'>
                <xpath expr="//group/field[@name='partner_id']" position="after">
                    <field name='acc_number'/>
                </xpath>
            </field>
        </record>

        <record model='ir.ui.view' id='account_move_line_export_bank_tree'>
            <field name='name'>account.move.line.export.bank.tree</field>
            <field name='model'>account.move.line</field>
            <field name='arch' type='xml'>
                <tree string='Apuntes Contebles' create="false" edit="false" delete="false">
                    <field name="date"/>
                    <field name="move_id"/>
                    <field name="journal_id"/>
                    <field name="name"/>
                    <field name="ref"/>
                    <field name="partner_id"/>
                    <field name="account_id"/>
                    <field name="operating_unit_id"/>
                    <field name="analytic_account_id"/>
                    <field name="reconciled"/>
                    <field name="debit" sum="Débito Total"/>
                    <field name="credit" sum="Crédito total"/>
                    <field name="amount_currency"/>
                    <field name="currency_id"/>
                </tree>
            </field>
        </record>

        <record id="action_account_move_line_export_bank" model="ir.actions.act_window">
            <field name="name">Apuntes Contebles</field>
            <field name="res_model">account.move.line</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="account_move_line_export_bank_tree"/>
        </record>

        <menuitem id="account_move_line_export_bank_menu" name="Apuntes Contebles" parent="account.menu_finance_entries" action="action_account_move_line_export_bank"/>
    </data>
</odoo>