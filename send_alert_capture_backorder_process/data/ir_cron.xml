<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_send_capture_backorder_process_alert" model="ir.cron">
            <field name="name">Send Email Capture Backorder By Process</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="model_id" ref="model_sale_order_line"/>
            <field name="state">code</field>
            <field name="code">model.alert_capture_backorder_process()</field>
            <field name="active" eval="True" />
        </record>

        <record id="email_capture_backorder_process" model="ir.config_parameter">
            <field name="key">send_alert.capture_backorder_process</field>
            <field name="value"></field>
        </record>

    </data>
</odoo>