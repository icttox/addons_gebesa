<?xml version="1.0" encoding="UTF-8"?>
<!--Nodo requerido-->
<odoo>
    <data>
        <record id="account_payment_pivot" model="ir.ui.view">
            <field name="name">account.payment.pivot</field>
            <field name="model">account.payment</field>
            <field name="arch" type="xml">
                <pivot string="Account Payments">
                    <field name="partner_id" type="row" ref="pivot_tree"/>
                    <field name='payment_date' type="col" interval="week" ref="pivot_tree"/>
                    <field name="amount_currency" type="measure" ref="pivot_tree"/> 
                </pivot>
            </field>
        </record>

        <record id='action_pivot' model='ir.actions.act_window'>
            <field name='name'>Customer pay for week</field>
            <field name='res_model'>account.payment</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>pivot</field>
            <field name="domain">[('partner_type','=','customer'), ('payment_date', '&gt;=', datetime.date.today().strftime('%Y-01-01'))]</field>
            <!--Verificar domain, la ref es a pivot, checar el tree -->
            <field name="view_id" ref="account_payment_pivot"/>
        </record>

        <record id='action_pivot_purchase' model='ir.actions.act_window'>
            <field name='name'>Supplier pay for week</field>
            <field name='res_model'>account.payment</field>
            <field name='view_type'>form</field>
            <field name='view_mode'>pivot</field>
            <field name="domain">[('partner_type','=','supplier'), ('payment_date', '&gt;=', datetime.date.today().strftime('%Y-01-01'))]</field>
            <!--Verificar domain, la ref es a pivot, checar el tree -->
            <field name="view_id" ref="account_payment_pivot"/>
        </record>

        <menuitem id="pivot_menu" parent="account.menu_finance_receivables" name="Customer Payments for Week " action="action_pivot"/>
        <menuitem id="pivot_menu_purchase" parent="account.menu_finance_payables" name="Supplier Payments for Week " action="action_pivot_purchase"/>

        <record model="ir.ui.view" id="account_payment_inherit">
    		<field name="name">account_payment_inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='rate_mex']" position="after">
                    <field name="amount_currency"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
