<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_import_line_form" model="ir.ui.view">
        <field name="name">sale.order.form.import.lines</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_cancel']" position="before">
              <button name="%(sale_order_import_action)d" states="draft,sent" type="action" string="Import"/>
            </xpath>
        </field>
    </record>
</odoo>
