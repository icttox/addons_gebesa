<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='view_order_form'>
            <field name='name'>reposition.sale.order.form</field>
            <field name='model'>sale.order</field>
            <field name='inherit_id' ref="sale.view_order_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='order_line']/tree//field[@name='price_unit']" position="after">
                    <field name="rep_sale_id" invisible="1"/>
                    <field name="rep_sale_line_id" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/tree" position="attributes">
                    <attribute name="decoration-danger">rep_sale_id!=False
                    </attribute>
                </xpath>
        
                <xpath expr="//field[@name='order_line']/form/group" position="after">
                    <group>
                        <group>
                            <field name="rep_sale_id"/>
                            <field name="rep_sale_line_id"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
