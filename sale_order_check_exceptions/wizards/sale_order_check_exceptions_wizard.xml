<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='order_check_exceptions_wizard_form'>
            <field name='name'>order.check.exceptions.wizard.form</field>
            <field name='model'>order.check.exceptions.wizard</field>
            <field name='arch' type='xml'>
                <form string='Order Exceptions'>
                    <p class="oe_grey">
                        *Send the email with the exception.
                    </p>
                    <footer>
                        <button string="Send" name="check_exceptions_wizard" type="object" default_focus="1" class="btn-primary"/>
                        or
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_order_check_exceptions_wizard" model="ir.actions.act_window">
            <field name="name">Sale Order Check Exceptions</field>
            <field name="res_model">order.check.exceptions.wizard</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="order_check_exceptions_wizard_form"/>
            <field name="context">{}</field>
            <field name="target">new</field>
        </record>
        <menuitem action="action_order_check_exceptions_wizard" id="action_order_check_exceptions_wizard_id" name="Sale Order Check Exceptions" parent="stock_move_batch_validator.inventory_special_process"/>
        <!--
        <act_window id="action_order_check_exceptions_wizard"
            multi="True"
            key2="client_action_multi" name="Approve"
            res_model="order.check.exceptions.wizard" src_model="sale.order"
            view_mode="form" target="new" view_type="form"
            groups="sale_order_check_exceptions.group_sale_order_check_exceptions"/>-->
    </data>
</odoo>