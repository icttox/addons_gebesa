<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='invoice_number_readonly_form'>
            <field name='name'>invoice.number.readonly.form</field>
            <field name='model'>account.invoice</field>
            <field name='inherit_id' ref='account.invoice_form'/>
            <field name='arch' type='xml'>
                <xpath expr="//form/sheet/h1/div/field[@name='sequence_number_next_prefix']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
                <xpath expr="//form/sheet/h1/div/field[@name='sequence_number_next']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
            </field>
        </record>

        <record model='ir.ui.view' id='invoice_supplier_number_readonly_form'>
            <field name='name'>invoice.supplier.number.readonly.form</field>
            <field name='model'>account.invoice</field>
            <field name='inherit_id' ref='account.invoice_supplier_form'/>
            <field name='arch' type='xml'>
                <xpath expr="//form/sheet/div/h1/div/field[@name='sequence_number_next_prefix']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
                <xpath expr="//form/sheet/div/h1/div/field[@name='sequence_number_next']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>