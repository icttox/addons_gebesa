<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_invoice_not_sing_refund" model="ir.ui.view">
            <field name="name">account.invoice.refund.not.sing.form</field>
            <field name="model">account.invoice.refund</field>
            <field name="inherit_id" ref="account.view_account_invoice_refund"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='description']" position="before">
                    <field name="not_sing_invoice_refund" attrs="{'invisible': [('filter_refund', '!=', 'cancel')]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>