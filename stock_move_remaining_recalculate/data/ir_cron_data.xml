<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="ir_cron_move_remaining_recalculated" model="ir.cron">
            <field name="name">Recalculate Move Remaining</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="model_id" ref="model_stock_move"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:30:00')" />
            <field name="state">code</field>
            <field name="code">model.move_remaining_recalculated_auto()</field>
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>
