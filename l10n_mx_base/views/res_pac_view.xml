<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_pac_search" model="ir.ui.view">
        <field name="name">view.res.pac.search</field>
        <field name="model">res.pac</field>
        <field name="arch" type="xml">
            <search string="PACS">
                <filter name="inactive" string="Inactive" icon="terp-personal" domain="[('active','=',False)]"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
                <newline/>
                <group expand="0" string="Group By...">
                    <filter name="company" string="Company" icon="terp-partner" domain="[]" context="{'group_by':'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_res_pac_form" model="ir.ui.view">
        <field name="name">view.res.pac.form</field>
        <field name="model">res.pac</field>
        <field name="arch" type="xml">
            <form string="PACS">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url_webservice_sign"/>
                        <field name="url_webservice_cancel"/>
                        <field name="user"/>
                        <field name="password" password="True"/>
                        <field name="test_env"/>
                        <field name="active"/>
                        <field name="company_id" widget="selection" groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_res_pac_tree" model="ir.ui.view">
        <field name="name">view.res.pac.tree</field>
        <field name="model">res.pac</field>
        <field name="arch" type="xml">
            <tree string="PACS">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
                <field name="url_webservice_sign"/>
                <field name="url_webservice_cancel"/>
                <field name="user"/>
            </tree>
        </field>
    </record>
    <record id="action_res_pac" model="ir.actions.act_window">
        <field name="name">PACS</field>
        <field name="res_model">res.pac</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_pacs" name="PACS" parent="base.menu_custom"
        groups="l10n_mx_base.group_l10n_mx_base_manager"/>
    <menuitem action="action_res_pac" id="menu_res_pac" parent="menu_pacs" sequence="1"/>

</odoo>
