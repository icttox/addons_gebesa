<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="l10n_mx_base_report_payment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 11px;">
                        <!--<div class="row">
                            <div class="col-xs-5 col-xs-offset-7"/>
                        </div>-->
                        <t t-if="not o.l10n_mx_edi_cfdi_uuid and o.l10n_mx_edi_is_required()">
                            <div class="btn btn-danger">
                                <h1>A signature of this payment is required, but it is not signed.</h1>
                            </div>
                        </t>
                        <t t-if="o.l10n_mx_edi_cfdi_uuid">
                            <t t-set="xml" t-value="o.l10n_mx_edi_get_xml_etree()"/>
                            <t t-set="tfd" t-value="o.invoice_ids.l10n_mx_edi_get_tfd_etree(xml)"/>
                        </t>
                        <h3><strong>Payment Receipt: <span t-field="o.name"/></strong></h3>
                        <!--<div class="row mt64">
                            <div class="col-xs-6" t-if="o.payment_date">
                                <strong>Payment Date: </strong> <span t-field="o.payment_date"/>
                            </div>
                            <div class="col-xs-6" t-if="o.l10n_mx_edi_cfdi_uuid and o.l10n_mx_edi_cfdi_supplier_rfc">
                                <span t-if="o.partner_id.vat != o.l10n_mx_edi_cfdi_supplier_rfc">XML VAT: <span t-esc="o.l10n_mx_edi_cfdi_supplier_rfc"></span></span>
                            </div>
                            <div class="col-xs-6" t-if="o.l10n_mx_edi_cfdi_uuid and o.l10n_mx_edi_payment_method_id">
                                <strong>Payment Method CFDI:</strong>
                                <span t-esc="' - '.join([o.l10n_mx_edi_payment_method_id.code, o.l10n_mx_edi_payment_method_id.name])"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-6" t-if="o.partner_type">
                                <t t-if="o.partner_type == 'customer'">
                                    <strong>Customer: </strong>
                                </t>
                                <t t-if="o.partner_type == 'supplier'">
                                    <strong>Vendor: </strong>
                                </t><span t-field="o.partner_id"/>
                            </div>
                            <div class="col-xs-6" t-if="o.payment_method_id">
                                <strong>Payment Method: </strong><span t-field="o.payment_method_id.name"/>
                            </div>
                        </div>
                        <div class="row mb64">
                            <div class="col-xs-6" t-if="o.amount">
                                <strong>Payment Amount: </strong><span t-field="o.amount" t-options="{'widget': 'monetary', 'currency_field': o.currency_id}"/>
                             </div>
                            <div class="col-xs-6" t-if="o.communication">
                                <strong>Memo: </strong><span t-field="o.communication"/>
                             </div>
                        </div>-->
                        <div class="row mt64">
                            <div class="col-6">
                                <strong>RFC Receiver: </strong><span t-field="o.l10n_mx_edi_cfdi_customer_rfc"/>
                            </div>
                            <div class="col-6">
                                <strong>RFC Emitter: </strong><span t-field="o.l10n_mx_edi_cfdi_supplier_rfc"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6" t-if="o.partner_id">
                                <strong>Receiver Name: </strong><span t-field="o.partner_id.l10n_mx_edi_name"/>
                            </div>
                            <div class="col-6">
                                <strong>Emitter Name: </strong><span t-field="o.company_id.partner_id.l10n_mx_edi_name"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <strong>Receiver Postal Code: </strong><span t-field="o.partner_id.zip"/>
                            </div>
                            <div class="col-6">
                                <strong>Fiscal Regime of the Emitter: </strong><span t-esc="o.company_id.partner_id.commercial_partner_id.property_account_position_id.name"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <strong>Fiscal Regime of the Receiver: </strong><span t-field="o.partner_id.commercial_partner_id.property_account_position_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Export: </strong>01
                            </div>
                        </div>
                        <div class="row mb64">
                            <div class="col-6" t-if="o.amount">
                                <strong>Effect of the Voucher: </strong>P
                            </div>
                            <div class="col-6" t-if="o.communication">
                                <strong>Currency: </strong>xxx
                            </div>
                        </div>
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Code product and/or service</th>
                                    <th>Quantiti</th>
                                    <th>Unit code</th>
                                    <th class="text-right">Unit value</th>
                                    <th class="text-right">Amount</th>
                                    <th class="text-right">Tax object</th>
                                    <th class="text-right">Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <td>8411506</td>
                                <td>1</td>
                                <td>ACT</td>
                                <td class="text-right">0.00</td>
                                <td class="text-right">0.00</td>
                                <td class="text-right">Not subject to taxes</td>
                                <td class="text-right">Payment</td>
                            </tbody>
                        </table>
                        <br/>
                        <table class="table table-condensed">
                            <t t-if="o.l10n_mx_edi_cfdi_uuid">
                                <t t-set="docs_related" t-value="o.l10n_mx_edi_get_payment_etree(xml)"/>
                                <thead>
                                    <tr>
                                        <th>Date Invoice</th>
                                        <th>Invoice</th>
                                        <th>UUID</th>
                                        <th class="text-right">Partiality</th>
                                        <th class="text-right">Original Amount</th>
                                        <th class="text-right">Previous balance</th>
                                        <th class="text-right">Amount Paid</th>
                                        <th class="text-right">Balance</th>
                                        <th>Currency</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="docs_related" t-as="inv">
                                        <tr t-foreach="o.invoice_ids" t-as="inv3">
                                            <t t-if="inv3.l10n_mx_edi_cfdi_uuid == inv.get('IdDocumento')">
                                                <td><span t-field="inv3.date_invoice"/></td>
                                                <td><span t-field="inv3.number"/></td>
                                                <td><span t-esc="inv.get('IdDocumento')"/></td>
                                                <td class="text-right"><span t-esc="inv.get('NumParcialidad', '')"/></td>
                                                <td class="text-right"><span t-field="inv3.amount_total"/></td>
                                                <td class="text-right"><span t-esc="inv.get('ImpSaldoAnt', '')"/></td>
                                                <td class="text-right"><span t-esc="inv.get('ImpPagado', '')"/></td>
                                                <td class="text-right"><span t-esc="inv.get('ImpSaldoInsoluto', '')"/></td>
                                                <td><span t-esc="inv.get('MonedaDR')"/></td>
                                            </t>
                                        </tr>
                                    </tr>
                                </tbody>
                            </t>
                            <t t-if="not o.l10n_mx_edi_cfdi_uuid">
                                <thead>
                                    <tr>
                                        <th>Invoice Date</th>
                                        <th>Invoice Number</th>
                                        <th>Reference</th>
                                        <th class="text-right">Original Amount</th>
                                        <th class="text-right">Amount Paid</th>
                                        <th class="text-right">Balance</th>
                                    </tr>
                                 </thead>
                                <tbody>
                                    <tr t-foreach="o.invoice_ids" t-as="inv2">
                                        <td><span t-field="inv2.date_invoice"/></td>
                                        <td><span t-field="inv2.number"/></td>
                                        <td><span t-field="inv2.reference"/></td>
                                        <td class="text-right"><span t-field="inv2.amount_total"/></td>
                                        <td class="text-right"><span t-esc="inv2.amount_total - inv2.residual" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                                        <td class="text-right"><span t-field="inv2.residual"/></td>
                                    </tr>
                                </tbody>
                            </t>
                        </table>
                        <t t-if="o.l10n_mx_edi_cfdi_uuid">
                            <div id='complement'>
                                <div class='row'>
                                    <div class="col-3" style="float:left; padding-top: 0.3em; padding-bottom: 0.3em;">
                                        <img t-att-src="'/report/barcode/QR/%s' % quote_plus('?') + keep_query(
                                            re=o.l10n_mx_edi_cfdi_supplier_rfc, rr=o.l10n_mx_edi_cfdi_customer_rfc,
                                            tt=0, id=o.l10n_mx_edi_cfdi_uuid)" style="height: 180px;width: 180px;"/>
                                   </div>
                                   <div class="col-9" style="font-size:8px">
                                       <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                           <strong><span>Digital stamp of the emitter</span></strong>
                                       </div>
                                       <div style="padding-top: 0.3em; padding-bottom: 0.3em; width: 93%;">
                                           <span t-esc="xml.get('Sello', 'No identificado')"/>
                                       </div>
                                       <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                           <strong><span>Digital stamp SAT</span></strong>
                                       </div>
                                       <div style="padding-top: 0.3em; padding-bottom: 0.3em; width: 93%;">
                                           <span t-esc="tfd.get('SelloSAT', 'No identificado')"/>
                                       </div>
                                       <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                           <strong><span>Original chain complement of digital certification SAT</span></strong>
                                       </div>
                                       <div style="padding-top: 0.3em; padding-bottom: 0.3em; width: 93%;">
                                           <span style="white-space: pre;" t-esc="o.l10n_mx_edi_original_string"/>
                                       </div>
                                       <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                           <strong><span>Extra Info</span></strong>
                                       </div>
                                       <div style="padding-top: 0.3em; padding-bottom: 0.3em; width: 93%;">
                                            <span>Emitter certificate:</span> <span t-esc="xml.get('NoCertificado')"/>
                                            <span> | Expedition place:</span> <span t-esc="xml.get('LugarExpedicion')"/>
                                            <span> | Fiscal Regime:</span> <span t-esc="xml.Emisor.get('RegimenFiscal', '')"/>
                                            <span> | Emission Date:</span> <span t-esc="xml.get('Fecha', '').replace('T', ' ')"/>
                                            <span> | Certification Date:</span> <span t-esc="tfd.get('FechaTimbrado', '').replace('T', ' ')"/>
                                            <span> | Fiscal Folio:</span> <span t-esc="tfd.get('UUID')"/>
                                            <span> | Use CFDI:</span> CP01
                                       </div>
                                   </div>
                               </div>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
