<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_account_inherit_form" model="ir.ui.view">
        <field name="name">view.account.account.inherit.form</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="domain">[('applicability', '=', 'accounts')]</attribute>
            </xpath>
        </field>
    </record>

    <!--record id="view_account_tax_inherit_l10n_mx_base" model="ir.ui.view">
