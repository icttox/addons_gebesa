<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record  model="ir.ui.view" id="res_partner_account_form_oml">
        <field name="name">res.partner.account.form.oml</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='property_account_payable_id']" position="after">
                <!--separator string="Mexican Information"/>
                <newline/>
                <field name="l10n_mx_edi_payment_method_id" colspan="2"/-->
                <field name="l10n_mx_edi_usage" colspan="2"/>
            </xpath>
        </field>
    </record>

    <record  model="ir.ui.view" id="res_partner_form_l10n_mx_base">
        <field name="name">res.partner.form.l10n_mx_base</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='o_address_format']/field[@name='country_id']" position="before">
                <field name="l10n_mx_locality" placeholder="Locality..." class="o_address_street"
                    attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
            </xpath>
            <xpath expr="//div[@name='div_address']/field[@name='country_id']" position="before">
                <field name="l10n_mx_locality" placeholder="Locality..." class="o_address_street"/>
            </xpath>
        </field>
    </record>

    <record  model="ir.ui.view" id="res_partner_address_form_l10n_mx_base">
        <field name="name">res.partner.address.form.l10n_mx_base</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_address_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='o_address_format']/field[@name='country_id']" position="before">
                <field name="l10n_mx_locality" placeholder="Locality..." class="o_address_street"/>
            </xpath>
        </field>
    </record>

    <!-- mx partner address -->
    <record id="mx_partner_address_form" model="ir.ui.view">
        <field name="name">mx.partner.form.address</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="900"/>
        <field name="arch" type="xml">
            <form>
                <div class="o_address_format">
                    <field name="street" invisible="1"/>
                    <field name="street2" placeholder="Street 2..."/>
                    <field name="l10n_mx_locality" placeholder="Locality..."/>
                    <field name="type" invisible="1"/>
                    <field name="parent_id" invisible="1"/>
                    <field name="country_enforce_cities" invisible="1"/>
                    <field name="city" placeholder="City..." class="o_address_street" attrs="{ 'readonly': [('type', '=', 'contact'), ('parent_id', '!=', False)]}"/>
                    <div class="o_row">
                        <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                        <field name="state_id" placeholder="State" options='{"no_open": True}'/>
                    </div>
                    <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}'/>
                </div>
            </form>
        </field>
    </record>

</odoo>
