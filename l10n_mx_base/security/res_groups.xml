<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Module category-->
    <record model="ir.module.category" id="module_l10n_mx_base">
        <field name="name">Electronic Invoicing of Mexico</field>
        <field name="description">User: This user has limitations to create or modify. Manager: The user will have an access to the Electronic Invoice data and configuration</field>
        <field name="sequence">999</field>
    </record>

    <!--MX groups-->
    <record id="res_group_pacs" model="res.groups">
        <field name="name">Parameters PAC Configuration</field>
        <field name="users" eval="[(4, ref('base.user_root'))]"/>
    </record>
    <record id="group_l10n_mx_xml_regenerate_xml" model="res.groups">
      <field name="name">Re-generate XML</field>
    </record>
    <record id="res_group_l10n_mx_edi_customs_number" model="res.groups">
        <field name="name">View customs in invoice</field>
        <field name="users" eval="[(4, ref('base.user_root'))]"/>
    </record>
    <record id="group_l10n_mx_base_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">This user has limitations to create or modify sensible Mexico Localization elements</field>
        <field name="category_id" ref="module_l10n_mx_base"/>
    </record>
    <record id="group_l10n_mx_base_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="comment">The user will have an access to the Electronic Invoice data and configuration</field>
        <field name="category_id" ref="module_l10n_mx_base"/>
        <field name="users" eval="[(4, ref('base.user_root'))]"/>
        <field name="implied_ids" eval="[(4, ref('group_l10n_mx_base_user'))]"/>
    </record>

    <!--account groups-->
    <!--Billing-->
    <record id="account.group_account_invoice" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_l10n_mx_base_user'))]"/>
    </record>
    <!--Accountant-->
    <record id="account.group_account_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_l10n_mx_base_manager'))]"/>
    </record>

</odoo>
