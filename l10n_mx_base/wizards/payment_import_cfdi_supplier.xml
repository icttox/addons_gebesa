<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="payment_import_cfdi_supplier_form" model="ir.ui.view">
            <field name="name">payment.import.cfdi.supplier.form</field>
            <field name="model">payment.import.cfdi.supplier</field>
            <field name="arch" type="xml">
                <form string="Import CFD-I file">
                    <field name="cfdi" required="True"/>
                    <field invisible="True" name="state" readonly="True"/>
                    <footer>
                        <button icon="gtk-cancel" special="cancel" states="init" string="Cancel"/>
                        <button icon="gtk-ok" name="import_cfdi" states="init" string="Import" type="object"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_payment_import_cfdi_supplier" model="ir.actions.act_window">
            <field name="name">Import CFDi paymet</field>
            <field name="res_model">payment.import.cfdi.supplier</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="payment_import_cfdi_supplier_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>