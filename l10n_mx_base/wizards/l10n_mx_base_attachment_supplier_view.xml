<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_invoice_attachment_mx_supplier" model="ir.ui.view">
        <field name="name">view.account.invoice.attachment.mx.supplier</field>
        <field name="model">l10n_mx_base.attachment.wizard</field>
        <field name="arch" type="xml">
            <form string="Attach Fiscal Documents Of Supplier" version="8.0">
                <group>
                    <big><i class="fa fa-file-code-o fa-2x text-primary"></i><label for="file_xml_sign"/><field name="file_xml_sign" filename="xml_name" nolabel="1"/> </big>
                    <big><i class="fa fa-file-pdf-o fa-2x text-danger"></i><label for="file_pdf"/><field name="file_pdf" filename="pdf_name" nolabel="1"/></big>
                    <field name="xml_name" invisible="1" class="oe_inline oe_right"/>
                    <field name="pdf_name" invisible="1" class="oe_inline oe_right"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <footer>
                    <button string='Save' name="attach" type="object" class="oe_highlight"/>
                    or
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
           </form>
        </field>
    </record>

    <record id="action_invoice_document_supplier" model="ir.actions.act_window">
        <field name="name">Attach Fiscal Documents</field>
        <field name="res_model">l10n_mx_base.attachment.wizard</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
       <field name="view_id" ref="view_account_invoice_attachment_mx_supplier"/>
       <field name="target">new</field>
    </record>

</odoo>
