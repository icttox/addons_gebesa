<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_tms" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.tms</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="85"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Freights" string="Freights" data-key="tms" groups="tms.group_supervisor_traffic">
                        <h2>GPS</h2>
                        <div class="row mt16 o_settings_container" id="webservice_gps_settings">
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="usuariogps"/>
                                    <div class="text-muted">
                                        User to connect to gps web service
                                    </div>
                                    <field name="usuariogps" readonly="False"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="passwordgps"/>
                                    <div class="text-muted">
                                        Password to connect to gps web service
                                    </div>
                                    <field name="passwordgps" readonly="False"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="urlecho"/>
                                    <div class="text-muted">
                                        URL to connect to gps web service
                                    </div>
                                    <field name="urlecho" readonly="False"/>
                                </div>
                            </div>
                        </div>

                        <h2>Diesel</h2>
                        <div class="row mt16 o_settings_container" id="tms_diesel_settings">
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="tms_product_id"/>
                                    <div class="text-muted">
                                        Product used for inventory adjustments
                                    </div>
                                    <field name="tms_product_id"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="tms_location_id"/>
                                    <div class="text-muted">
                                        Source location used for inventory adjustments
                                    </div>
                                    <field name="tms_location_id"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="tms_location_dest_id"/>
                                    <div class="text-muted">
                                        Destination location used for inventory adjustments
                                    </div>
                                    <field name="tms_location_dest_id"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="tms_type_adjustment_id"/>
                                    <div class="text-muted">
                                        Type of adjustment used for inventory adjustments
                                    </div>
                                    <field name="tms_type_adjustment_id"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="tms_type_adjustment_ret_id"/>
                                    <div class="text-muted">
                                        Type of adjustment used for return inventory adjustments
                                    </div>
                                    <field name="tms_type_adjustment_ret_id"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="action_tms_config" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module' : 'tms'}</field>
        </record>

    <menuitem id="menu_custom_config" name="Settings" parent="tms.menu_tms_settings"
        sequence="0" action="action_tms_config" groups="base.group_system"/>
    </data>
</odoo>
