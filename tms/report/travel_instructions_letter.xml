    <template id="travel_instructions_letter_layout">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-if="not company">
            <!-- Multicompany -->
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-elif="o and 'operating_unit_id' in o">
                <t t-set="company" t-value="o.operating_unit_id.company_id.sudo()"/>
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>
        <div class="header">
            <div class="row">
                <div class="col-8 text-center">
                    <strong>
                        Carta de viaje<br/>
                        <span t-field="company.name"/><br/>
                        <span t-esc="str(company.partner_id.street_name) + ' No. ' + str(company.partner_id.street_number) + ' Col. ' + str(company.partner_id.l10n_mx_edi_colony) + ' ' + str(company.partner_id.l10n_mx_edi_locality) + ' ' + str(company.partner_id.state_id.name) + ', ' + str(company.partner_id.country_id.name) + ' CP: ' + str(company.partner_id.zip)"/>
                    </strong>
                </div>
                <div class="col-4">
                    <img t-if="company.logo_invoice" t-att-src="'data:image/png;base64,%s' % to_text(company.logo_invoice)" style="max-width: 180px; max-height: 120px;" class="pull-left"/>
                </div>
            </div>
        </div>
        <div class="article o_report_layout_standard">
            <t t-raw="0" />
        </div>
        <div class="footer">
        </div>
    </template>

    <template id="travel_instructions_letter">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="tms.travel_instructions_letter_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-12 table-bordered">
                                Folio odoo: <span t-field="doc.name"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row">
                            <div class="col-12 table-bordered text-center">
                                Carga
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-2 table-bordered">
                                Cliente:
                            </div>
                            <div class="col-10 table-bordered text-center">
                                <span t-field="doc.partner_id"/>
                            </div>
                        </div>
                        <t t-foreach="doc.transportable_line_ids" t-as="line">
                            <div class="row">
                                <div class="col-2 table-bordered">
                                    Carga:
                                </div>
                                <div class="col-4 table-bordered text-center">
                                    <span t-field="line.name"/>
                                </div>
                                <div class="col-2 table-bordered">
                                    Peso:
                                </div>
                                <div class="col-4 table-bordered text-center">
                                    <span t-field="line.quantity"/> <span t-field="line.transportable_uom_id"/>
                                </div>
                            </div>
                        </t>
                        <div class="row">
                            <div class="col-4 table-bordered">
                                Tipo de remolque solicitado:
                            </div>
                            <div class="col-8 table-bordered text-center">
                                <span t-if="doc.trailer1_id" t-field="doc.trailer1_id.type_box"/>
                                <span t-if="doc.trailer1_id and doc.trailer2_id">-</span>
                                <span t-if="doc.trailer2_id" t-field="doc.trailer2_id.type_box"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Direccion de carga:
                            </div>
                            <div class="col-9 table-bordered text-center">
                                <span t-esc="str(doc.departure_address_id.street_name) + ' No. ' + str(doc.departure_address_id.street_number) + ' Col. ' + str(doc.departure_address_id.l10n_mx_edi_colony) + ' ' + str(doc.departure_address_id.l10n_mx_edi_locality) + ' ' + str(doc.departure_address_id.state_id.name) + ', ' + str(doc.departure_address_id.country_id.name) + ' CP: ' + str(doc.departure_address_id.zip)"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Fecha de carga
                            </div>
                            <div class="col-3 table-bordered">
                                <t t-esc="context_timestamp(doc.date_start).date()"/>
                            </div>
                            <div class="col-3 table-bordered">
                                Hora de carga
                            </div>
                            <div class="col-3 table-bordered">
                                <t t-esc="context_timestamp(doc.date_start).time()"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Observaciones:
                            </div>
                            <div class="col-9 table-bordered text-center">
                                <span t-field="doc.upload_point"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Contacto:
                            </div>
                            <div class="col-9 table-bordered">
                                <span t-field="doc.partner_order_id"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row">
                            <div class="col-12 table-bordered text-center">
                                Entrega
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-2 table-bordered">
                                Destinatario:
                            </div>
                            <div class="col-10 table-bordered text-center">
                                <span t-field="doc.arrival_address_id"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Direccion de Entrega:
                            </div>
                            <div class="col-9 table-bordered text-center">
                                <span t-esc="str(doc.arrival_address_id.street_name) + ' No. ' + str(doc.arrival_address_id.street_number) + ' Col. ' + str(doc.arrival_address_id.l10n_mx_edi_colony) + ' ' + str(doc.arrival_address_id.l10n_mx_edi_locality) + ' ' + str(doc.arrival_address_id.state_id.name) + ', ' + str(doc.arrival_address_id.country_id.name) + ' CP: ' + str(doc.arrival_address_id.zip)"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Fecha de entrega
                            </div>
                            <div class="col-3 table-bordered">
                                <t t-esc="context_timestamp(doc.date_end).date()"/>
                            </div>
                            <div class="col-3 table-bordered">
                                Hora de entrega
                            </div>
                            <div class="col-3 table-bordered">
                                <t t-esc="context_timestamp(doc.date_end).time()"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Observaciones:
                            </div>
                            <div class="col-9 table-bordered text-center">
                                <span t-field="doc.download_point"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Contacto:
                            </div>
                            <div class="col-9 table-bordered">
                                
                            </div>
                        </div>
                        <br/>
                        <div class="row">
                            <div class="col-3 table-bordered">
                                Instrucciones al chofer:
                            </div>
                            <div class="col-9 table-bordered text-center">
                                <span t-field="doc.instructions_driver"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row">
                            <div class="col-12 table-bordered text-center">
                                Evidencias
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Factura Firmada y sellada
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Carta porte Firmada y sellada
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Comprobante de maniobra
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Certificado de Peso y Calidad Firmado y sellado
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Bascula Firmada y sellada (Donde Aplica)
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Pase de entrada a planta (Bimsa)
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Remision y entrada de producto (Bimsa)
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                        <div class="row">
                            <div class="col-8 table-bordered text-center">
                                Reporte condiciones de embarque firmada y sellada (Quimicas del rey)
                            </div>
                            <div class="col-2 table-bordered"/>
                            <div class="col-2 table-bordered"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

