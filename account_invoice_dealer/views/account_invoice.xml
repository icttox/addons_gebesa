<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='account_invoice_dealer'>
            <field name='name'>account.invoice.dealer</field>
            <field name='model'>account.invoice</field>
            <field name='inherit_id' ref='invoice_refund_validate.account_invoice_sale_order_ref'/>
            <field name='arch' type='xml'>
                <xpath expr="//field[@name='order_ref_id']" position="after">
                    <!--field name='dealer_id' domain="[('customer', '=', True),
                                                     ('active', '=', True)]"/-->
                    <field name="requires_dealer" invisible="1" /> 
                    <field name='partner_dealer_id' domain="[('partner_id','=',partner_id)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>