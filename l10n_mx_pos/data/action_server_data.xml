<?xml version='1.0' encoding='UTF-8'?>
<odoo noupdate="1">

    <record model="ir.actions.server" id="create_invoice_pos_server_action">
        <field name="name">Create invoice PoS</field>
        <field name="model_id" eval="ref('point_of_sale.model_pos_order')"/>
        <field name="state">code</field>
        <field name="condition"></field>
        <field name="sequence">5</field>
        <field name="code">
# When is created a new register, verify that partner have VAT, and
# create invoice
object.action_create_invoice()
object.action_validate_invoice()
        </field>
    </record>

    <record id="orders_filter_paid" model="ir.filters">
        <field name="name">Paid orders with partner</field>
        <field name="model_id">pos.order</field>
        <field name="user_id" eval="False"/>
        <field name="domain">[('state', '=', 'paid'), ('partner_id', '!=', False)]</field>
    </record>

    <record model="base.action.rule" id="action_rule_create_invoice_pos">
        <field name="name">Create invoice PoS</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="sequence">0</field>
        <field name="active">True</field>
        <field name="kind">on_write</field>
        <field name="filter_pre_id" ref="orders_filter_paid"/>
        <field name="server_action_ids" eval="[(6, 0, [ref('create_invoice_pos_server_action')])]"/>
    </record>
</odoo>
