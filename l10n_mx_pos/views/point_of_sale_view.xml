<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_pos_session_inherit_form_l10n_mx_base">
        <field name="name">view.pos.session.inherit.form.l10n_mx_base</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr='//button[@name="action_pos_session_closing_control"]' position="after">
                <button name="create_xml_session" type="object" string="Generate XMLs"
                    class="oe_highlight" attrs="{'invisible': [('state', '!=', 'closed')]}"/>
                <button name="cancelate_xml_session" type="object" string="Cancel XMLs"
                    class="oe_highlight" attrs="{'invisible': [('state', '!=', 'closed')]}"/>
            </xpath>
            <xpath expr='//sheet' position="after">
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
