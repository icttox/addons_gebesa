<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_xml_session_document">
        <!-- <t t-call="report.external_layout"> -->
        <t t-set="o" t-value="o.with_context({'lang':o.user_id.lang})"/>
        <t t-set="xml_data" t-value="get_xml_data(o)"></t>
        <t t-call="l10n_mx_base.external_layout">
            <div class="page">
                <br/>
                <br/>
                <br/>
                <div class="col-xs-12" id="payment_method">
                    <div class="row" style="font-size:9px">
                        <div class="col-xs-6" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                            <strong><span>Payment Method</span></strong>
                        </div>
                        <div class="col-xs-6" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                            <strong><span>Account Number</span></strong>
                        </div>
                    </div>
                    <div class="row" style="font-size:9px">
                        <div class="col-xs-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                            <span t-esc="xml_data.get('metodoDePago','NA')"/>
                        </div>
                        <div class="col-xs-6" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                            <span t-esc="xml_data.get('NumCtaPago', 'NA')"/>
                        </div>
                    </div>
                </div>
                <div class="row" id="concepts">
                    <div class="col-xs-12">
                        <table class="table table-striped" style="font-size:9px;">
                            <tr>
                                <th width="3%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>R</span></th>
                                <th width="8%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>QUANTITY</span></th>
                                <th width="10%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>PART NO</span></th>
                                <th width="52%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>DESCRIPTION</span></th>
                                <th width="7%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>UoM</span></th>
                                <th width="10%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>UNIT PRICE</span></th>
                                <th width="10%" class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>TOTAL</span></th>
                            </tr>
                            <t t-set="row_count" t-value="0"/>
                            <t t-set="concepts" t-value="xml_data.Conceptos.get('Concepto', ())"/>
                            <t t-foreach="[concept for concept in xml_data.Conceptos.Concepto]" t-as="concept">
                                <tr class="text-center">
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-center"><span t-esc="row_count"></span></td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-center"><span t-esc="concept.get('cantidad', '0.0')"></span></td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;"><span t-esc="concept.get('noIdentificacion', '0.0')"></span></td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-left">
                                        <span t-esc="concept.get('descripcion', '')"/>
                                    </td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-center"><span t-esc="concept.get('unidad', '0.0')"></span></td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-right"><span t-esc="concept.get('valorUnitario', '0.0')"></span></td>
                                    <td style="padding-top: 0.3em; padding-bottom: 0.3em;" class="text-right"><span t-esc="concept.get('importe', '0.0')"></span></td>
                                </tr>
                                <t t-set="row_count" t-value="row_count+1"/>
                            </t>
                        </table>
                    </div>
                </div>
                <div class="col-xs-3" style="font-size:8px">
                    <div>
                        <b><span>No. Items: </span></b><span t-esc="row_count"/>
                    </div>
                </div>
                <div class="row">
                    <div class="col-xs-12 text-center" style="font-size:8px">
                        <span>THE PAYMENT OF THIS INVOICE IS </span><span t-esc="xml_data.get('formaDePago', '').upper()"/>,
                        <span>PLACE OF EXPEDITION </span><span t-esc="xml_data.get('LugarExpedicion', '').upper()"/>
                        <span>THIS IS A PRINTED REPRESENTATION OF A CFDI</span>
                    </div>
                </div>

                <br/>
                <div class="row" id="totals">
                    <div class="row col-xs-offset-9 col-xs-3">
                        <table class="table" style="font-size:10px">
                            <tr>
                                <th class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>Sub Total</span></th>
                                <td class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;"><span t-esc="xml_data.get('subTotal', '0.0')"/></td>
                            </tr>
                            <t t-set="desc_amount" t-value="xml_data.get('descuento', False)"/>
                            <t t-if="desc_amount and desc_amount != '0.0'">
                                <tr>
                                    <th class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>Discount</span></th>
                                    <td class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;"><span t-esc="desc_amount"/></td>
                                </tr>
                            </t>
                            <t t-if="xml_data.Impuestos.find('{http://www.sat.gob.mx/cfd/3}Traslados') is not None and xml_data.Impuestos.Traslados.find('{http://www.sat.gob.mx/cfd/3}Traslado') is not None">
                                <t t-set="taxes" t-value="xml_data.Impuestos.Traslados.Traslado"/>
                                <t t-foreach="taxes" t-as="tax">
                                    <t t-set="tax_amount" t-value="tax.get('importe', False)"/>
                                    <t t-if="tax_amount">
                                        <tr>
                                            <th class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                            <t t-set="tax_name" t-value="tax.get('impuesto', '')"/>
                                            <t t-set="tasa" t-value="tax.get('tasa', '')"/>
                                            <t t-set="text" t-value="tax_name+' ('+tasa+') %'"/>
                                            <span t-esc="text or '0.0'"/> </th>
                                            <td class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <t t-set="importe" t-value="tax.get('importe', 0.0)"/>
                                                <span t-esc="importe"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>
                            <t t-if="xml_data.Impuestos.find('{http://www.sat.gob.mx/cfd/3}Retenciones') is not None and xml_data.Impuestos.Retenciones.find('{http://www.sat.gob.mx/cfd/3}Retencion') is not None">
                                <t t-set="taxes" t-value="xml_data.Impuestos.Retenciones.Retencion"/>
                                <t t-foreach="taxes" t-as="ret">
                                    <t t-set="ret_amount" t-value="ret.get('importe', False)"/>
                                    <t t-if="ret_amount">
                                        <tr style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                            <th class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                            <t t-set="ret_name" t-value="ret.get('impuesto', '')"/>
                                            <span>Ret.</span><span t-esc="('%s' % (ret_name or '' ))"/> </th>
                                            <td class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                                <span t-esc="ret_amount or '0.0'"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>
                            <tr align="left">
                                <th class="text-right" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><b><span>Total</span></b></th>
                                <td class="text-right" align="right" style="padding-top: 0.3em; padding-bottom: 0.3em;"><b><span t-esc="xml_data.get('total', '0.0')"/></b></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="row">
                    <div class="col-xs-12">
                        <table class="table table-striped" style="font-size:10px;padding-top: 0.1em; padding-bottom: 0.1em;" width="100%">
                            <tr>
                                <th class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;"><span>Total amount with letters</span></th>
                            </tr>
                            <tr>
                                <td style="padding-top: 0.1em; padding-bottom: 0.1em;">
                                    <span t-esc="'*( %s )*' % ( amount_to_text(xml_data.get('total')))"></span>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div id='complement'>
                    <div class='row'>
                        <div class="col-xs-3" style="float:left; padding-top: 0.3em; padding-bottom: 0.3em;">
                            <t t-set="img" t-value="create_qrcode(xml_data)"/>
                            <img t-if="img" t-att-src="'data:image/png;base64,%s' % img" style="max-height: 180; max-width: 180;"/>
                        </div>
                        <div class="col-xs-9" style="font-size:8px">
                            <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Digital stamp of the emitter</span></strong>
                            </div>
                            <div style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="split_string(xml_data.get('sello', ''))"/>
                            </div>
                            <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Digital stamp SAT</span></strong>
                            </div>
                            <div style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="split_string(invoice_obj.l10n_mx_edi_get_tfd_etree(xml_data).get('selloSAT', ''))"/>
                            </div>
                            <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <strong><span>Original chain complement of digital certification SAT</span></strong>
                            </div>
                            <div style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span t-esc="split_string(context.get('cfdi_original_string', ''))"/>
                            </div>
                            <div class="text-center" style="padding-top: 0.3em; padding-bottom: 0.3em;background-color: #848484;color: #ffffff;">
                                <span t-esc="''"/>
                            </div>
                            <div style="padding-top: 0.3em; padding-bottom: 0.3em;">
                                <span>Emitter:</span><span t-esc="' %s |' % (xml_data.Emisor.get('nombre', ''))"/>
                                <span>Serial number of emitter certificate:</span><span t-esc="'%s |' % xml_data.get('noCertificado', 'No identificado')"/>
                                <span>Serial number of SAT certificate:</span><span t-esc="'%s |' % (invoice_obj.l10n_mx_edi_get_tfd_etree(xml_data).get('noCertificadoSAT', '') or 'No identificado')"/>
                                <span>Fiscal folio:</span><span t-esc="'%s |' % (invoice_obj.l10n_mx_edi_get_tfd_etree(xml_data).get('UUID', '') or 'No identificado')"/>
                                <span>Certification date and time:</span><span t-esc="'%s' % datetime.strptime(invoice_obj.l10n_mx_edi_get_tfd_etree(xml_data).get('FechaTimbrado', '').encode('ascii','replace'), '%Y-%m-%dT%H:%M:%S').strftime('%d/%m/%Y %H:%M:%S') or 'No identificado'"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_xml_session">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="l10n_mx_pos.report_xml_session_document" t-lang="o.user_id.lang"/>
            </t>
        </t>
    </template>

    <template id="name_report">
        <t t-call="web.html_container">
        </t>
    </template>

    <!-- QWeb Reports -->
    <report
        id="report_xmlsession"
        model="pos.session"
        string="XML Session"
        report_type="qweb-pdf"
        multi="False"
        menu="False"
        name="l10n_mx_pos.report_xml_session"
        file="l10n_mx_pos.report_xml_session"
        attachment_use="False"
        />

</odoo>
