<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model='ir.ui.view' id='product_template_form_view'>
            <field name='name'>product_template_structure_gebesaform_view</field>
            <field name='model'>product.template</field>
            <field name='inherit_id' ref="product.product_template_form_view"/>
            <field name='arch' type='xml'>
                <xpath expr="//notebook/page/group/group/field[@name='type']" position="attributes">
                    <attribute name="attrs">{'readonly': True}</attribute>
                </xpath>
                <xpath expr="//notebook/page/group/group/field[@name='type']" position="after">
                    <field name='cutting_detail'/>
                </xpath>
                <xpath expr="//notebook/page[1]" position="after">
                    <page string="Product classification" name="product_classification">
                        <group>
                           <group>
                                <field name='family_id' domain="[('analytic_id', '!=', False)]"/>
                                <field name='group_id'/>
                           </group>
                           <group>
                                <field name='is_line'/>
                                <field name='line_id'/>
                                <field name='type_id'/>
                                <field name='type_product'/>
                           </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

         <record model='ir.ui.view' id='product_template_form_view2'>
            <field name='name'>product_template_structure_gebesa_form_view2</field>
            <field name='model'>product.template</field>
            <field name='inherit_id' ref="product_structure_gebesa.product_template_form_view"/>
            <field name="groups_id" eval="[(6, 0, [ref('account.group_account_manager') ])]"/>
            <field name='arch' type='xml'>
                <xpath expr="//notebook/page/group/group/field[@name='type']" position="attributes">
                    <attribute name="attrs">{'readonly': False}</attribute>
                </xpath>
            </field>
        </record>

        <record id="product_template_only_form_view_editcost" model="ir.ui.view">
            <field name="name">product.template.only.form.view.editcost</field>
            <field name="model">product.template</field>
            <field name="priority">16</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <!--field name="groups_id" eval="[(4, ref('mrp.group_mrp_user'))]"/-->
            <field name="arch" type="xml">
                <xpath expr="//field[@name='standard_price']" position="before">
                    <field name="bom_count" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="attrs">{'readonly': [('bom_count', '!=', 0), ('valuation', '=', 'real_time')]}</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>