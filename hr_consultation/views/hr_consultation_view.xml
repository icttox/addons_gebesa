<?xml version = "1.0" encoding = "UTF-8"?> 
<odoo>
    <data>
        <record model="ir.actions.act_window" id="consultation_action">
            <field name="name">Consultation</field>
            <field name="res_model">hr.consultation</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the Consultation
                </p>
            </field>
        </record>

        <menuitem id="consultation_menu" name="Nursing" parent="hr.menu_hr_root"/>
        <menuitem id="cons_menu" name="Consultation" parent="consultation_menu" action="consultation_action" sequence="1"/>

        <record model="ir.ui.view" id="consultation_form">
            <field name="name">hr.consultation.form</field>
            <field name="model">hr.consultation</field>
            <field name="arch" type="xml">
                <form string="Form Consultation">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="nurse_id"/>
                                <field name="diagnosis"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="employee_id"/>
                                <field name="symptoms"/>
                            </group>
                            <field name="medications_ids" widget="one2many_list">
                                <tree editable="bottom" string="Consultation Prescription">
                                    <field name="name"/>
                                    <field name="dose"/>
                                </tree>    
                            </field>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div> 
                </form>
            </field>
        </record>    

        <record model="ir.ui.view" id="consultation_tree_view">
            <field name="name">hr.consultation.tree</field>
            <field name="model">hr.consultation</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Employee Consultation">
                    <field name="name" select="1"/>
                    <field name="nurse_id"/>
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="diagnosis"/>
                    <field name="symptoms"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>